<%
// Get the currentPath from the include data or set default
var currentPath = typeof currentPath !== 'undefined' ? currentPath : '';
var user = typeof currentUser !== 'undefined' ? currentUser : null;
var role = user ? user.role : 'guest';

// Helper function to check if current path is active
function isActive(path) {
    if (!currentPath) return '';
    return currentPath.indexOf(path) === 0 ? 'bg-amber-100 text-amber-800' : 'text-gray-700 hover:bg-gray-100';
}
%>

<nav class="bg-white shadow-lg border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <!-- Left side: Logo and main navigation -->
            <div class="flex items-center space-x-8">
                <!-- Logo -->
                <a href="/" class="flex items-center space-x-2 text-xl font-bold text-blue-900">
                    <i class="fas fa-hand-holding-heart text-2xl text-amber-600"></i>
                    <span class="tracking-tight">Barang<span class="text-amber-600">Chan</span></span>
                </a>

                <!-- Navigation Links - Different per role -->
                <div class="hidden md:flex items-center space-x-1">
                    <% if (!user) { %>
                        <!-- Guest Navigation -->
                        <a href="/" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/') %> transition duration-150">
                            <i class="fas fa-home mr-1"></i>Home
                        </a>
                        <a href="/about" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/about') %> transition duration-150">
                            <i class="fas fa-info-circle mr-1"></i>About
                        </a>
                    <% } else if (role === 'resident') { %>
                        <!-- CLIENT / RESIDENT Navigation -->
                        <a href="/client/dashboard" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/client/dashboard') %> transition duration-150">
                            <i class="fas fa-home mr-1"></i>Home
                        </a>
                        <a href="/client/forum" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/client/forum') %> transition duration-150">
                            <i class="fas fa-comments mr-1"></i>Forums
                        </a>
                        <a href="/client/requests" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/client/requests') %> transition duration-150">
                            <i class="fas fa-file-alt mr-1"></i>My Requests
                        </a>
                        <a href="/client/complaints" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/client/complaints') %> transition duration-150">
                            <i class="fas fa-bullhorn mr-1"></i>Complaints
                        </a>
                        <a href="/client/govforms" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/client/govforms') %> transition duration-150">
                            <i class="fas fa-file-alt mr-1"></i>Government Forms
                        </a>
                        <a href="/contacts" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/contacts') %> transition duration-150">
                            <i class="fas fa-address-book mr-1"></i>Contacts
                        </a>
                    <% } else if (role === 'moderator') { %>
                        <!-- MODERATOR Navigation -->
                        <a href="/moderator/dashboard" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/moderator/dashboard') %> transition duration-150">
                            <i class="fas fa-chart-pie mr-1"></i>Dashboard
                        </a>
                        <a href="/moderator/posts" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/moderator/posts') %> transition duration-150">
                            <i class="fas fa-comments mr-1"></i>Manage Posts
                        </a>
                        <a href="/moderator/requests" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/moderator/requests') %> transition duration-150">
                            <i class="fas fa-file-signature mr-1"></i>Document Requests
                        </a>
                        <a href="/moderator/complaints" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/moderator/complaints') %> transition duration-150">
                            <i class="fas fa-gavel mr-1"></i>Complaints
                        </a>
                        <a href="/moderator/help-desk" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/moderator/help-desk') %> transition duration-150">
                            <i class="fas fa-headset mr-1"></i>Help Desk
                        </a>
                        <a href="/contacts" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/contacts') %> transition duration-150">
                            <i class="fas fa-address-book mr-1"></i>Contacts
                        </a>
                    <% } else if (role === 'administrator') { %>
                        <!-- ADMINISTRATOR Navigation -->
                        <a href="/administrator/dashboard" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/administrator/dashboard') %> transition duration-150">
                            <i class="fas fa-tachometer-alt mr-1"></i>Dashboard
                        </a>
                        <a href="/administrator/users" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/administrator/users') %> transition duration-150">
                            <i class="fas fa-users-cog mr-1"></i>Manage Users
                        </a>
                        <a href="/administrator/moderators" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/administrator/moderators') %> transition duration-150">
                            <i class="fas fa-user-shield mr-1"></i>Moderators
                        </a>
                        <a href="/contacts" class="px-3 py-2 rounded-md text-sm font-medium <%= isActive('/contacts') %> transition duration-150">
                            <i class="fas fa-address-book mr-1"></i>Contacts
                        </a>
                    <% } %>
                </div>
            </div>

            <!-- Right side: User menu and notifications -->
            <div class="flex items-center space-x-4">
                <% if (user) { %>
                    <!-- User Info and Profile Link -->
                    <!-- Profile dropdown or link -->
                    <a href="/profile" class="flex items-center gap-2 text-gray-700 hover:text-amber-600 transition">
                        <i class="fas fa-user-circle text-xl"></i>
                        <span class="hidden md:inline"><%= currentUser.first_name %></span>
                    </a>
        
                    <a href="/logout" class="px-3 py-2 text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition duration-150">
                        <i class="fas fa-sign-out-alt mr-1"></i>Logout
                    </a>
                <% } else { %>
                    <!-- Guest buttons -->
                    <a href="/login" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-amber-600 hover:bg-gray-100 rounded-lg transition duration-150">
                        <i class="fas fa-sign-in-alt mr-1"></i>Login
                    </a>
                    <a href="/register" class="px-4 py-2 text-sm font-medium bg-gradient-to-r from-amber-600 to-amber-700 text-white rounded-lg hover:from-amber-700 hover:to-amber-800 shadow-md transition duration-150">
                        <i class="fas fa-user-plus mr-1"></i>Register
                    </a>
                <% } %>

                <!-- Mobile menu button -->
                <button class="md:hidden p-2 rounded-lg text-gray-600 hover:text-amber-600 hover:bg-gray-100 transition duration-150">
                    <i class="fas fa-bars text-xl"></i>
                </button>
            </div>
        </div>
    </div>
</nav>