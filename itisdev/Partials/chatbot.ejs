<!-- AI CHATBOT - Fixed at Bottom Right -->
<div class="fixed bottom-6 right-6 z-50">
    <!-- Chatbot Toggle Button -->
    <button id="chatbotToggle" class="bg-gradient-to-r from-amber-600 to-amber-700 text-white p-4 rounded-full shadow-2xl hover:from-amber-700 hover:to-amber-800 transition-all duration-300 transform hover:scale-110">
        <i class="fas fa-comment-dots text-2xl"></i>
    </button>

    <!-- Chatbot Window -->
    <div id="chatbotWindow" class="absolute bottom-20 right-0 w-96 bg-white rounded-2xl shadow-2xl overflow-hidden hidden">
        <!-- Chatbot Header -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 p-4 text-white">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="bg-white/20 p-2 rounded-lg">
                        <i class="fas fa-robot text-amber-300"></i>
                    </div>
                    <div>
                        <h4 class="font-bold">BarangChan AI Assistant</h4>
                        <p class="text-xs text-white/80">Online • Ready to help kabayan!</p>
                    </div>
                </div>
                <button id="closeChatbot" class="text-white/80 hover:text-white">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Chatbot Messages -->
        <div class="h-96 overflow-y-auto p-4 bg-gray-50" id="chatMessages">
            <!-- Welcome Message -->
            <div class="flex items-start gap-3 mb-4 message-bubble">
                <div class="w-8 h-8 bg-amber-600 rounded-full flex items-center justify-center text-white text-xs flex-shrink-0">
                    <i class="fas fa-robot text-sm"></i>
                </div>
                <div class="bg-white rounded-2xl rounded-tl-none p-3 max-w-[80%] shadow-sm">
                    <p class="text-sm text-gray-700">
                        <span class="font-bold text-amber-600">Mabuhay kabayan!</span> 👋 
                        I'm your BarangChan AI assistant. How can I help you today?
                    </p>
                </div>
            </div>

            <!-- Quick Action Buttons Container -->
            <div id="quickActionsContainer" class="flex flex-wrap gap-2 mb-4 ml-11">
                <!-- Quick actions will be dynamically populated based on page -->
            </div>

            <!-- Templates (hidden) -->
            <div class="hidden user-message-template">
                <div class="flex items-start gap-3 mb-4 justify-end">
                    <div class="bg-amber-600 text-white rounded-2xl rounded-tr-none p-3 max-w-[80%] shadow-sm">
                        <p class="text-sm"></p>
                    </div>
                    <div class="w-8 h-8 bg-gray-600 rounded-full flex items-center justify-center text-white text-xs flex-shrink-0">
                        <i class="fas fa-user text-sm"></i>
                    </div>
                </div>
            </div>

            <div class="hidden typing-indicator-container">
                <div class="flex items-start gap-3 mb-4">
                    <div class="w-8 h-8 bg-amber-600 rounded-full flex items-center justify-center text-white text-xs flex-shrink-0">
                        <i class="fas fa-robot text-sm"></i>
                    </div>
                    <div class="bg-white rounded-2xl rounded-tl-none p-4 shadow-sm">
                        <div class="typing-indicator flex space-x-1">
                            <span class="w-2 h-2 bg-amber-600 rounded-full"></span>
                            <span class="w-2 h-2 bg-amber-600 rounded-full"></span>
                            <span class="w-2 h-2 bg-amber-600 rounded-full"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chatbot Input -->
        <div class="p-4 border-t border-gray-200 bg-white">
            <div class="flex items-center gap-2">
                <input type="text" 
                       id="chatInput"
                       placeholder="Type your message here..." 
                       class="flex-1 border border-gray-300 rounded-full px-4 py-2 focus:ring-2 focus:ring-amber-400 focus:border-transparent text-sm">
                <button id="sendMessage" class="bg-amber-600 text-white p-2 rounded-full hover:bg-amber-700 transition w-10 h-10 flex items-center justify-center">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
            <p class="text-xs text-gray-400 mt-2 text-center">
                <i class="fas fa-shield-alt text-amber-600"></i> 
                AI assistant helps you navigate BarangChan services
            </p>
        </div>
    </div>
</div>

<!-- Chatbot JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize chatbot
        initChatbot();
    });

    function initChatbot() {
        const toggleBtn = document.getElementById('chatbotToggle');
        const closeBtn = document.getElementById('closeChatbot');
        const chatbotWindow = document.getElementById('chatbotWindow');
        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendMessage');
        
        // Template elements
        const userMessageTemplate = document.querySelector('.user-message-template');
        const typingIndicator = document.querySelector('.typing-indicator-container');

        // Toggle chatbot
        if (toggleBtn) {
            toggleBtn.addEventListener('click', function() {
                chatbotWindow.classList.remove('hidden');
                toggleBtn.classList.add('hidden');
            });
        }

        if (closeBtn) {
            closeBtn.addEventListener('click', function() {
                chatbotWindow.classList.add('hidden');
                toggleBtn.classList.remove('hidden');
            });
        }

        // Send message function
        function sendUserMessage(message) {
            if (!message.trim()) return;

            // Show user message
            const userMsg = userMessageTemplate.cloneNode(true);
            userMsg.classList.remove('hidden', 'user-message-template');
            userMsg.querySelector('p').textContent = message;
            chatMessages.appendChild(userMsg);

            // Clear input
            if (chatInput) chatInput.value = '';

            // Scroll to bottom
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // Show typing indicator
            const typingClone = typingIndicator.cloneNode(true);
            typingClone.classList.remove('hidden', 'typing-indicator-container');
            chatMessages.appendChild(typingClone);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // Get page context for better responses
            const pageContext = document.body.getAttribute('data-page-context') || 'general';

            // Simulate AI response after delay
            setTimeout(() => {
                // Remove typing indicator
                typingClone.remove();

                // Add AI response
                const aiMsg = document.createElement('div');
                aiMsg.className = 'flex items-start gap-3 mb-4 message-bubble';
                aiMsg.innerHTML = `
                    <div class="w-8 h-8 bg-amber-600 rounded-full flex items-center justify-center text-white text-xs flex-shrink-0">
                        <i class="fas fa-robot text-sm"></i>
                    </div>
                    <div class="bg-white rounded-2xl rounded-tl-none p-3 max-w-[80%] shadow-sm">
                        <p class="text-sm text-gray-700">${getAIResponse(message, pageContext)}</p>
                    </div>
                `;
                chatMessages.appendChild(aiMsg);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }, 1500);
        }

        // Send button click
        if (sendBtn) {
            sendBtn.addEventListener('click', function() {
                sendUserMessage(chatInput.value);
            });
        }

        // Enter key press
        if (chatInput) {
            chatInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    sendUserMessage(chatInput.value);
                }
            });
        }

        // Attach quick action buttons if they exist
        const quickActions = document.querySelectorAll('.quick-action');
        quickActions.forEach(btn => {
            btn.addEventListener('click', function() {
                const message = this.getAttribute('data-message') || this.textContent.trim();
                sendUserMessage(message);
            });
        });
    }

    // AI response generator with context awareness
    function getAIResponse(message, context) {
        const msg = message.toLowerCase();
        
        // Context-specific responses
        if (context === 'dashboard') {
            if (msg.includes('post') || msg.includes('create')) {
                return "To create a post, use the 'What's on your mind' section at the top of the dashboard. You can share updates, concerns, or suggestions! 📝";
            } else if (msg.includes('request') || msg.includes('clearance')) {
                return "To request a Barangay Clearance, go to Quick Actions and click 'Request Barangay Clearance'. You can also visit the Barangay Hall from 8AM-5PM. 📄";
            } else if (msg.includes('emergency') || msg.includes('hotline')) {
                return "🚨 EMERGENCY HOTLINES:\n• Barangay Hall: 8123-4567\n• Police/Ambulance: 911\n• Fire Dept: 160\nIs this an emergency?";
            } else {
                return "I can help you with dashboard features: creating posts, requesting documents, tracking requests, or finding emergency contacts. What do you need? 🤗";
            }
        } 
        else if (context === 'forum') {
            if (msg.includes('how to post') || msg.includes('create topic')) {
                return "To create a new topic, click the 'Create New Topic' button at the top of the forum page. Fill in the title, category, and your message, then click submit! 📝";
            } else if (msg.includes('category')) {
                return "Forum categories include: General Discussion, Announcements, Community Concerns, Suggestions, Emergency Alerts, and Events & Activities. Choose the most appropriate one for your topic! 🏷️";
            } else if (msg.includes('trending') || msg.includes('hot')) {
                return "Check out the topics with 'Hot' badges or sort by 'Most Viewed' to see what's trending in your barangay right now! 🔥";
            } else {
                return "Welcome to the forum! I can help you create topics, find discussions, or explain categories. What would you like to know? 🤗";
            }
        }
        else {
            // General responses
            if (msg.includes('hello') || msg.includes('hi') || msg.includes('kumusta')) {
                return "Kumusta kabayan! 👋 How can I assist you with BarangChan today?";
            } else if (msg.includes('thank')) {
                return "Walang anuman po! 🫶 Is there anything else I can help you with?";
            } else {
                return "Thanks for your message! I'm here to help you navigate BarangChan. You can ask about:\n• Creating posts\n• Requesting documents\n• Forum discussions\n• Emergency contacts\nWhat would you like to know? 🤗";
            }
        }
    }
</script>

<!-- Chatbot Styles (include these in your main CSS or head section) -->
<style>
    .message-bubble {
        animation: fadeInUp 0.3s ease-out;
    }
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .typing-indicator span {
        animation: blink 1.4s infinite;
        animation-fill-mode: both;
    }
    .typing-indicator span:nth-child(2) {
        animation-delay: 0.2s;
    }
    .typing-indicator span:nth-child(3) {
        animation-delay: 0.4s;
    }
    @keyframes blink {
        0% { opacity: 0.1; }
        20% { opacity: 1; }
        100% { opacity: 0.1; }
    }
</style>