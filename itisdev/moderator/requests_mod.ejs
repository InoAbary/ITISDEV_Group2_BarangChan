            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-700"><span id="selectedCount" class="text-blue-600 font-bold">0</span> requests selected</span>
                    <button id="clearSelection" class="text-xs text-gray-500 hover:text-blue-600 transition">
                        <i class="fas fa-times mr-1"></i>Clear selection
                    </button>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button id="bulkProcess" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium transition">
                        <i class="fas fa-play-circle mr-1"></i> Start Processing
                    </button>
                    <button id="bulkApprove" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium transition">
                        <i class="fas fa-check-circle mr-1"></i> Approve
                    </button>
                    <button id="bulkComplete" class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 text-sm font-medium transition">
                        <i class="fas fa-check-double mr-1"></i> Mark Complete
                    </button>
                    <button id="bulkReject" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 text-sm font-medium transition">
                        <i class="fas fa-times-circle mr-1"></i> Reject
                    </button>
                    <button id="bulkPrint" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 text-sm font-medium transition">
                        <i class="fas fa-print mr-1"></i> Print Forms
                    </button>
                </div>
            </div>
        </div>

        <!-- Loading Spinner -->
        <div id="loadingSpinner" class="hidden flex justify-center items-center py-12">
            <div class="spinner"></div>
        </div>

