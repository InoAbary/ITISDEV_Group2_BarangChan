<!-- moderator/requests_mod.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Manage Document Requests</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .status-pending { background-color: #fff3e0; color: #ef6c00; }
        .status-accepted { background-color: #e3f2fd; color: #1565c0; }
        .status-cancelled { background-color: #ffebee; color: #c62828; }

        .priority-urgent { background-color: #fce4ec; color: #880e4f; animation: pulse 2s infinite; }
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }

        .table-row-hover:hover {
            background-color: #f9fafb;
        }

        .modal-overlay {
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
        }
        .modal-content {
            animation: modalSlideIn 0.3s ease-out;
        }
        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #f59e0b;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: slideInRight 0.3s ease-out;
        }
        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .filter-tab {
            transition: all 0.2s ease;
        }
        .filter-tab.active {
            background-color: #3b82f6;
            color: white;
        }
        
        .progress-step {
            position: relative;
            z-index: 1;
        }
        .progress-step.completed .step-indicator {
            background-color: #10b981;
            border-color: #10b981;
            color: white;
        }
        .progress-step.active .step-indicator {
            background-color: #3b82f6;
            border-color: #3b82f6;
            color: white;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
        }
        .progress-line {
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            height: 2px;
            background-color: #e5e7eb;
            z-index: 0;
        }
        .progress-line.completed {
            background-color: #10b981;
        }
        
        .doc-badge {
            background-color: #e0f2fe;
            color: #0369a1;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/moderator/requests', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header -->
        <div class="bg-gradient-to-r from-blue-800 to-blue-700 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-file-signature"></i> 
                        Document Request Management
                    </h1>
                    <p class="text-blue-100 mt-1 text-sm md:text-base">
                        <i class="fas fa-shield-alt mr-1"></i> 
                        Process, track, and manage all document requests from residents
                    </p>
                </div>
                <div class="mt-3 md:mt-0 flex items-center gap-3">
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-clock mr-2"></i>Last updated: just now
                    </span>
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-hourglass-half mr-2"></i><%= statusCounts?.find(s => s.status === 'Pending')?.count || 0 %> pending
                    </span>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-blue-500">
                <p class="text-xs text-gray-500">Total Requests</p>
                <p class="text-2xl font-bold text-gray-800"><%= totalRequests || 0 %></p>
                <p class="text-xs text-green-600">+<%= monthlyCounts?.reduce((sum, m) => sum + m.count, 0) || 0 %> this month</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-yellow-500">
                <p class="text-xs text-gray-500">Pending</p>
                <p class="text-2xl font-bold text-gray-800"><%= statusCounts?.find(s => s.status === 'Pending')?.count || 0 %></p>
                <p class="text-xs text-amber-600">Awaiting review</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-green-500">
                <p class="text-xs text-gray-500">Accepted</p>
                <p class="text-2xl font-bold text-gray-800"><%= statusCounts?.find(s => s.status === 'Accepted')?.count || 0 %></p>
                <p class="text-xs text-green-600">In progress</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-purple-500">
                <p class="text-xs text-gray-500">Completed</p>
                <p class="text-2xl font-bold text-gray-800"><%= statusCounts?.find(s => s.status === 'Completed')?.count || 0 %></p>
                <p class="text-xs text-purple-600">Released documents</p>
            </div>
        </div>

        <!-- Secondary Stats - Document Type Distribution -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <% if (topDocuments && topDocuments.length > 0) { %>
                <% topDocuments.forEach(function(doc) { %>
                <div class="bg-white rounded-lg shadow-sm p-3 border border-gray-100">
                    <p class="text-xs text-gray-500"><%= doc.document_type %></p>
                    <p class="text-lg font-bold text-gray-800"><%= doc.count %></p>
                    <div class="w-full bg-gray-200 h-1.5 rounded-full mt-1">
                        <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= (doc.count / totalRequests) * 100 %>%"></div>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <div class="bg-white rounded-lg shadow-sm p-3 border border-gray-100 col-span-4 text-center text-gray-500">
                    No document data available
                </div>
            <% } %>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
                <!-- Search Bar -->
                <div class="flex-1 w-full md:w-auto">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" 
                               id="searchInput"
                               placeholder="Search by request ID, resident name, or document type..." 
                               value="<%= query?.search || '' %>"
                               class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400 focus:border-blue-400">
                    </div>
                </div>
                
                <!-- Filter Dropdowns -->
                <div class="flex flex-wrap gap-2 w-full md:w-auto">
                    <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="all" <%= query?.status === 'all' || !query?.status ? 'selected' : '' %>>All Status</option>
                        <option value="Pending" <%= query?.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Accepted" <%= query?.status === 'Accepted' ? 'selected' : '' %>>Accepted</option>
                        <option value="Cancelled" <%= query?.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                    
                    <select id="barangayFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="all" <%= query?.barangay === 'all' || !query?.barangay ? 'selected' : '' %>>All Barangays</option>
                        <% if (barangays && barangays.length > 0) { %>
                            <% barangays.forEach(function(barangay) { %>
                                <option value="<%= barangay %>" <%= query?.barangay === barangay ? 'selected' : '' %>><%= barangay %></option>
                            <% }); %>
                        <% } %>
                    </select>
                    
                    <select id="dateFromFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="">Date From</option>
                    </select>
                    
                    <select id="dateToFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="">Date To</option>
                    </select>
                    
                    <select id="sortFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="latest" <%= query?.sort === 'latest' || !query?.sort ? 'selected' : '' %>>Newest First</option>
                        <option value="oldest" <%= query?.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                        <option value="pending_first" <%= query?.sort === 'pending_first' ? 'selected' : '' %>>Pending First</option>
                    </select>
                    
                    <button id="applyFilters" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium transition">
                        <i class="fas fa-filter mr-1"></i> Apply
                    </button>
                    
                    <a href="/moderator/requests" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
                        <i class="fas fa-redo-alt mr-1"></i> Reset
                    </a>
                </div>
            </div>
            
            <!-- Quick Filter Tabs -->
            <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-gray-200">
                <a href="?status=all" class="filter-tab <%= !query?.status || query?.status === 'all' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    All Requests (<%= totalRequests %>)
                </a>
                <a href="?status=Pending" class="filter-tab <%= query?.status === 'Pending' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    Pending (<%= statusCounts?.find(s => s.status === 'Pending')?.count || 0 %>)
                </a>
                <a href="?status=Accepted" class="filter-tab <%= query?.status === 'Accepted' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    Accepted (<%= statusCounts?.find(s => s.status === 'Accepted')?.count || 0 %>)
                </a>
                <a href="?status=Cancelled" class="filter-tab <%= query?.status === 'Cancelled' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    Cancelled (<%= statusCounts?.find(s => s.status === 'Cancelled')?.count || 0 %>)
                </a>
            </div>
        </div>

        <!-- Bulk Actions Bar -->
        <div id="bulkActionsBar" class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6 hidden">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-700"><span id="selectedCount" class="text-blue-600 font-bold">0</span> requests selected</span>
                    <button id="clearSelection" class="text-xs text-gray-500 hover:text-blue-600 transition">
                        <i class="fas fa-times mr-1"></i>Clear selection
                    </button>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button id="bulkApprove" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium transition">
                        <i class="fas fa-check-circle mr-1"></i> Approve
                    </button>
                    <button id="bulkReject" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 text-sm font-medium transition">
                        <i class="fas fa-times-circle mr-1"></i> Cancel
                    </button>
                </div>
            </div>
        </div>

        <!-- Loading Spinner -->
        <div id="loadingSpinner" class="hidden flex justify-center items-center py-12">
            <div class="spinner"></div>
        </div>

        <!-- Requests Table -->
        <div id="requestsTable" class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden mb-8">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <input type="checkbox" id="selectAll" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Request ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Resident</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Barangay</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Document Type</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Submitted</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Days Pending</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="requestsTableBody" class="bg-white divide-y divide-gray-200">
                        <% if (requests && requests.length > 0) { %>
                            <% requests.forEach(function(req) { %>
                            <tr class="table-row-hover" data-request-id="<%= req.id %>">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <input type="checkbox" class="request-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" value="<%= req.id %>">
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900"><%= req.reference_number %></p>
                                        <p class="text-xs text-gray-500">ID: <%= req.id %></p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gradient-to-br from-blue-600 to-amber-600 flex items-center justify-center text-white text-xs font-bold">
                                            <%= req.requester_name ? req.requester_name.charAt(0).toUpperCase() : 'U' %>
                                        </div>
                                        <div class="ml-3">
                                            <p class="text-sm font-medium text-gray-900"><%= req.requester_name %></p>
                                            <p class="text-xs text-gray-500"><%= req.email || req.phone || 'No contact' %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 text-xs rounded-full bg-amber-100 text-amber-700">
                                        <i class="fas fa-map-pin mr-1"></i> <%= req.barangay || 'N/A' %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="doc-badge px-2 py-1 text-xs rounded-full">
                                        <i class="fas fa-file-alt mr-1"></i> <%= req.document_type %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="status-<%= req.status_class %> px-3 py-1 rounded-full text-xs font-medium">
                                        <%= req.status_display %>
                                    </span>
                                    <% if (req.file_count > 0) { %>
                                        <span class="ml-1 text-xs text-blue-500" title="<%= req.file_count %> file(s) attached">
                                            <i class="fas fa-paperclip"></i>
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <div><%= req.formatted_date %></div>
                                    <div class="text-xs text-gray-400"><%= req.time_ago %></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm <%= req.days_pending > 7 ? 'text-red-600 font-medium' : 'text-gray-600' %>">
                                        <%= req.days_pending %> days
                                    </span>
                                    <% if (req.days_pending > 7 && req.status !== 'Cancelled') { %>
                                        <span class="ml-1 text-xs text-red-500">(Overdue)</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <div class="flex items-center gap-1">
                                        <button class="text-blue-600 hover:text-blue-700 hover:bg-blue-50 p-2 rounded-lg transition" title="View Details" onclick='openViewModal("<%= req.id %>")'>
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button class="text-green-600 hover:text-green-700 hover:bg-green-50 p-2 rounded-lg transition" title="Update Status" onclick='openStatusModal("<%= req.id %>", "<%= req.status %>")'>
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <% if (req.status !== 'Cancelled') { %>
                                        <button class="text-red-600 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition" title="Cancel Request" onclick='openCancelModal("<%= req.id %>")'>
                                            <i class="fas fa-times"></i>
                                        </button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="9" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fas fa-inbox text-4xl mb-3"></i>
                                    <p>No document requests found.</p>
                                    <a href="/moderator/requests" class="mt-2 inline-block text-blue-600 hover:text-blue-700">Clear all filters</a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            
            <!-- Table Footer with Pagination -->
            <% if (totalPages > 1) { %>
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="text-sm text-gray-500">
                    Showing <span class="font-medium"><%= (currentPage - 1) * limit + 1 %></span> to 
                    <span class="font-medium"><%= Math.min(currentPage * limit, totalRequests) %></span> of 
                    <span class="font-medium"><%= totalRequests %></span> requests
                </div>
                <div class="flex items-center gap-2">
                    <% if (currentPage > 1) { %>
                        <a href="?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>" 
                           class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    <% } %>
                    
                    <% for(let i = 1; i <= Math.min(5, totalPages); i++) { 
                        let pageNum = i;
                        if (currentPage > 3 && i === 1) { %>
                            <a href="?<%= new URLSearchParams({...query, page: 1}).toString() %>" class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">1</a>
                            <% if (currentPage > 4) { %>
                                <span class="text-gray-400">...</span>
                            <% } %>
                            <% pageNum = currentPage - 2;
                        } else if (currentPage > 3 && i === 2) {
                            pageNum = currentPage - 1;
                        } else if (currentPage > 3 && i === 3) {
                            pageNum = currentPage;
                        } else if (currentPage > 3 && i === 4) {
                            pageNum = currentPage + 1;
                        } else if (currentPage > 3 && i === 5) {
                            pageNum = currentPage + 2;
                        }
                        
                        if (pageNum <= totalPages && pageNum >= 1) { %>
                            <a href="?<%= new URLSearchParams({...query, page: pageNum}).toString() %>" 
                               class="px-3 py-1 border border-gray-300 rounded-lg text-sm <%= pageNum === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'text-gray-600 hover:bg-gray-100' %> transition">
                                <%= pageNum %>
                            </a>
                        <% } 
                    } %>
                    
                    <% if (currentPage + 2 < totalPages) { %>
                        <span class="text-gray-400">...</span>
                        <a href="?<%= new URLSearchParams({...query, page: totalPages}).toString() %>" 
                           class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                            <%= totalPages %>
                        </a>
                    <% } %>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>" 
                           class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </main>

    <!-- View Request Modal -->
    <div id="viewModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto modal-content">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-file-alt text-blue-600"></i>
                    Document Request Details
                </h3>
                <button onclick="closeViewModal()" class="text-gray-400 hover:text-gray-600">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="p-6" id="viewModalContent">
                <!-- Content will be dynamically populated -->
            </div>
        </div>
    </div>

    <!-- Update Status Modal -->
    <div id="statusModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Update Request Status</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                        <select id="updateStatus" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400">
                            <option value="Pending">Pending</option>
                            <option value="Accepted">Accepted (In Progress)</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Notes (Optional)</label>
                        <textarea id="statusNotes" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400" placeholder="Add notes about this update..."></textarea>
                    </div>
                </div>
                
                <div class="flex gap-3 mt-6">
                    <button onclick="closeStatusModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="updateStatusBtn" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Update Status</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Cancel Modal -->
    <div id="cancelModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <div class="text-center mb-4">
                    <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-ban text-red-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Cancel Request</h3>
                    <p class="text-gray-600">Are you sure you want to cancel this request?</p>
                </div>
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Reason for cancellation</label>
                        <textarea id="cancelReason" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400" placeholder="Enter reason for cancellation..."></textarea>
                    </div>
                </div>
                
                <div class="flex gap-3 mt-6">
                    <button onclick="closeCancelModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="confirmCancelBtn" class="flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">Confirm Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]">
        <div class="flex items-center gap-3">
            <i id="toastIcon" class="fas fa-check-circle text-green-500 text-xl"></i>
            <div>
                <p id="toastTitle" class="font-medium text-gray-800">Success</p>
                <p id="toastMessage" class="text-sm text-gray-600">Action completed successfully</p>
            </div>
            <button onclick="hideToast()" class="ml-auto text-gray-400 hover:text-gray-600">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>

    <!-- Include chatbot -->
    <%- include('../partials/chatbot') %>
    <!-- Include footer -->
    <%- include('../partials/footer') %>

    <script>
        // Store requests data from backend
        const requestsData = <%- JSON.stringify(requests || []) %>;
        let currentRequestId = null;
        let selectedRequests = new Set();

        // ========== MODAL FUNCTIONS ==========
        
        // View Modal
        function openViewModal(requestId) {
            currentRequestId = requestId;
            const request = requestsData.find(r => r.id == requestId);
            
            if (request) {
                const modalContent = document.getElementById('viewModalContent');
                modalContent.innerHTML = `
                    <div class="grid grid-cols-3 gap-6">
                        <div class="col-span-1">
                            <div class="bg-gray-50 rounded-lg p-4">
                                <h4 class="font-medium text-gray-700 mb-3">Resident Information</h4>
                                <div class="space-y-3">
                                    <div class="flex items-center gap-2">
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-600 to-amber-600 flex items-center justify-center text-white font-bold">
                                            ${request.requester_name ? request.requester_name.charAt(0).toUpperCase() : 'U'}
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-800">${request.requester_name}</p>
                                            <p class="text-xs text-gray-500">${request.barangay || 'N/A'}</p>
                                        </div>
                                    </div>
                                    <div class="text-sm">
                                        <p class="flex items-center gap-2 text-gray-600"><i class="fas fa-phone w-4 text-blue-500"></i> ${request.phone || 'N/A'}</p>
                                        <p class="flex items-center gap-2 text-gray-600"><i class="fas fa-envelope w-4 text-blue-500"></i> ${request.email || 'N/A'}</p>
                                        <p class="flex items-center gap-2 text-gray-600"><i class="fas fa-map-marker-alt w-4 text-blue-500"></i> ${request.address || 'N/A'}</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="bg-gray-50 rounded-lg p-4 mt-4">
                                <h4 class="font-medium text-gray-700 mb-3">Request Information</h4>
                                <div class="space-y-2 text-sm">
                                    <p><span class="text-gray-500">Request ID:</span> <span class="font-medium">${request.reference_number}</span></p>
                                    <p><span class="text-gray-500">Document Type:</span> ${request.document_type}</p>
                                    <p><span class="text-gray-500">Submitted:</span> ${request.formatted_date} (${request.time_ago})</p>
                                    <p><span class="text-gray-500">Days Pending:</span> <span class="${request.days_pending > 7 ? 'text-red-600 font-medium' : ''}">${request.days_pending} days</span></p>
                                    <p><span class="text-gray-500">Files Attached:</span> ${request.file_count || 0} file(s)</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-span-2">
                            <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
                                <h4 class="font-medium text-gray-700 mb-3">Document Details</h4>
                                <div class="space-y-3">
                                    <div class="p-3 bg-gray-50 rounded-lg">
                                        <p class="text-sm text-gray-700 whitespace-pre-wrap">${request.document_request || 'No details provided'}</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="bg-white border border-gray-200 rounded-lg p-4">
                                <h4 class="font-medium text-gray-700 mb-3">Status History</h4>
                                <div class="space-y-3">
                                    <div class="flex items-center gap-3 text-sm">
                                        <div class="w-8 h-8 rounded-full bg-${request.status === 'Pending' ? 'yellow' : (request.status === 'Accepted' ? 'green' : 'red')}-100 flex items-center justify-center">
                                            <i class="fas fa-${request.status === 'Pending' ? 'clock' : (request.status === 'Accepted' ? 'check' : 'times')} text-${request.status === 'Pending' ? 'yellow' : (request.status === 'Accepted' ? 'green' : 'red')}-600"></i>
                                        </div>
                                        <div>
                                            <p class="font-medium">${request.status_display}</p>
                                            <p class="text-xs text-gray-500">Current status as of ${request.formatted_date}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-3 mt-6 pt-4 border-t border-gray-200">
                        <button onclick="closeViewModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Close</button>
                        <button onclick="openStatusModal('${request.id}', '${request.status}')" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Update Status</button>
                    </div>
                `;
            }
            
            document.getElementById('viewModal').classList.remove('hidden');
        }
        
        function closeViewModal() {
            document.getElementById('viewModal').classList.add('hidden');
        }
        
        // Status Modal
        let currentRequestStatus = '';
        function openStatusModal(requestId, currentStatus) {
            currentRequestId = requestId;
            currentRequestStatus = currentStatus;
            const statusSelect = document.getElementById('updateStatus');
            if (statusSelect) {
                statusSelect.value = currentStatus;
            }
            document.getElementById('statusModal').classList.remove('hidden');
        }
        
        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
            document.getElementById('statusNotes').value = '';
        }
        
        // Cancel Modal
        function openCancelModal(requestId) {
            currentRequestId = requestId;
            document.getElementById('cancelModal').classList.remove('hidden');
        }
        
        function closeCancelModal() {
            document.getElementById('cancelModal').classList.add('hidden');
            document.getElementById('cancelReason').value = '';
        }

        // ========== BULK ACTIONS ==========
        
        // Select All functionality
        document.getElementById('selectAll')?.addEventListener('change', function(e) {
            const checkboxes = document.querySelectorAll('.request-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
                if (e.target.checked) {
                    selectedRequests.add(cb.value);
                } else {
                    selectedRequests.delete(cb.value);
                }
            });
            updateBulkActionsBar();
        });

        // Individual checkbox selection
        document.querySelectorAll('.request-checkbox').forEach(cb => {
            cb.addEventListener('change', function(e) {
                if (e.target.checked) {
                    selectedRequests.add(e.target.value);
                } else {
                    selectedRequests.delete(e.target.value);
                }
                updateBulkActionsBar();
                
                // Update select all checkbox
                const allCheckboxes = document.querySelectorAll('.request-checkbox');
                const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
                if (document.getElementById('selectAll')) {
                    document.getElementById('selectAll').checked = allChecked;
                }
            });
        });

        // Clear selection
        document.getElementById('clearSelection')?.addEventListener('click', function() {
            document.querySelectorAll('.request-checkbox').forEach(cb => {
                cb.checked = false;
            });
            selectedRequests.clear();
            if (document.getElementById('selectAll')) {
                document.getElementById('selectAll').checked = false;
            }
            updateBulkActionsBar();
        });

        function updateBulkActionsBar() {
            const bar = document.getElementById('bulkActionsBar');
            const countSpan = document.getElementById('selectedCount');
            const count = selectedRequests.size;
            
            if (bar && countSpan) {
                if (count > 0) {
                    countSpan.textContent = count;
                    bar.classList.remove('hidden');
                } else {
                    bar.classList.add('hidden');
                }
            }
        }

        // ========== FILTERS ==========
        
        // Apply filters button
        document.getElementById('applyFilters')?.addEventListener('click', function() {
            const status = document.getElementById('statusFilter').value;
            const barangay = document.getElementById('barangayFilter').value;
            const dateFrom = document.getElementById('dateFromFilter').value;
            const dateTo = document.getElementById('dateToFilter').value;
            const sort = document.getElementById('sortFilter').value;
            const search = document.getElementById('searchInput').value;
            
            let url = '/moderator/requests?';
            const params = [];
            if (status !== 'all') params.push(`status=${encodeURIComponent(status)}`);
            if (barangay !== 'all') params.push(`barangay=${encodeURIComponent(barangay)}`);
            if (dateFrom) params.push(`date_from=${encodeURIComponent(dateFrom)}`);
            if (dateTo) params.push(`date_to=${encodeURIComponent(dateTo)}`);
            if (sort !== 'latest') params.push(`sort=${encodeURIComponent(sort)}`);
            if (search) params.push(`search=${encodeURIComponent(search)}`);
            
            window.location.href = url + params.join('&');
        });

        // ========== BULK ACTION BUTTONS ==========
        
        document.getElementById('bulkApprove')?.addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            
            const requestIds = Array.from(selectedRequests);
            Promise.all(requestIds.map(id => 
                fetch(`/moderator/requests/${id}/update`, { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'Accepted', notes: 'Bulk approval' })
                })
            )).then(() => {
                showToast('success', 'Bulk Approve', `${selectedRequests.size} requests approved`);
                setTimeout(() => location.reload(), 1500);
            }).catch(() => {
                showToast('error', 'Error', 'Failed to approve requests');
            });
        });

        document.getElementById('bulkReject')?.addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            
            const requestIds = Array.from(selectedRequests);
            Promise.all(requestIds.map(id => 
                fetch(`/moderator/requests/${id}/update`, { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'Cancelled', notes: 'Bulk cancellation' })
                })
            )).then(() => {
                showToast('error', 'Bulk Cancel', `${selectedRequests.size} requests cancelled`);
                setTimeout(() => location.reload(), 1500);
            }).catch(() => {
                showToast('error', 'Error', 'Failed to cancel requests');
            });
        });

        // ========== CONFIRMATION BUTTONS ==========
        
        document.getElementById('updateStatusBtn')?.addEventListener('click', function() {
            const status = document.getElementById('updateStatus').value;
            const notes = document.getElementById('statusNotes').value;
            
            fetch(`/moderator/requests/${currentRequestId}/update`, { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status, notes: notes })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('success', 'Status Updated', `Request ${currentRequestId} marked as ${status}`);
                        closeStatusModal();
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('error', 'Error', data.message || 'Failed to update status');
                    }
                })
                .catch(() => {
                    showToast('error', 'Error', 'Failed to update status');
                });
        });

        document.getElementById('confirmCancelBtn')?.addEventListener('click', function() {
            const reason = document.getElementById('cancelReason').value;
            
            fetch(`/moderator/requests/${currentRequestId}/update`, { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: 'Cancelled', notes: `Cancelled: ${reason}` })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('error', 'Request Cancelled', `Request ${currentRequestId} has been cancelled`);
                        closeCancelModal();
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('error', 'Error', data.message || 'Failed to cancel request');
                    }
                })
                .catch(() => {
                    showToast('error', 'Error', 'Failed to cancel request');
                });
        });

        // ========== TOAST NOTIFICATION ==========
        
        function showToast(type, title, message) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastMessage = document.getElementById('toastMessage');
            
            if (!toast) return;
            
            if (type === 'success') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-check-circle text-green-500 text-xl';
            } else if (type === 'error') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-red-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-times-circle text-red-500 text-xl';
            } else {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-blue-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-info-circle text-blue-500 text-xl';
            }
            
            toastTitle.textContent = title;
            toastMessage.textContent = message;
            toast.classList.remove('hidden');
            setTimeout(hideToast, 3000);
        }
        
        function hideToast() {
            const toast = document.getElementById('toast');
            if (toast) toast.classList.add('hidden');
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList && event.target.classList.contains('modal-overlay')) {
                closeViewModal();
                closeStatusModal();
                closeCancelModal();
            }
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeViewModal();
                closeStatusModal();
                closeCancelModal();
            }
        });
    </script>
</body>
</html>