    <textarea id="requestsDataJson" class="hidden"><%- JSON.stringify(requests) %></textarea>
    <script>
        // Store requests data for JavaScript access
        const requestsDataElement = document.getElementById('requestsDataJson');
        const requestsData = requestsDataElement ? JSON.parse(requestsDataElement.textContent || '[]') : [];
        let currentRequestId = null;
        let selectedRequests = new Set();

        // ========== MODAL FUNCTIONS ==========
        
        // View Modal
        function openViewModal(requestId) {
            currentRequestId = requestId;
            const request = requestsData.find(r => r.id === requestId);
            
            if (request) {
                const modalContent = document.getElementById('viewModalContent');
                
                // Generate requirements list
                const requirementsList = request.requirements.map(req => `
                    <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
                        <span class="text-sm text-gray-700">${req.name}</span>
                        <span class="text-xs px-2 py-1 rounded-full 
                            ${req.status === 'verified' ? 'bg-green-100 text-green-700' : 
                              req.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : 
                              req.status === 'rejected' ? 'bg-red-100 text-red-700' : 
                              'bg-gray-100 text-gray-700'}">
                            ${req.status.charAt(0).toUpperCase() + req.status.slice(1)}
                        </span>
                    </div>
                `).join('');
                
                modalContent.innerHTML = `
                    <div class="grid grid-cols-3 gap-6">
                        <!-- Left Column - Resident Info -->
                        <div class="col-span-1">
                            <div class="bg-gray-50 rounded-lg p-4">
                                <h4 class="font-medium text-gray-700 mb-3">Resident Information</h4>
                                <div class="space-y-3">
                                    <div class="flex items-center gap-2">
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-600 to-amber-600 flex items-center justify-center text-white font-bold">
                                            ${request.residentAvatar}
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-800">${request.resident}</p>
                                            <p class="text-xs text-gray-500">${request.residentAddress}</p>
                                        </div>
                                    </div>
                                    <div class="text-sm">
                                        <p class="flex items-center gap-2 text-gray-600"><i class="fas fa-phone w-4 text-blue-500"></i> ${request.contact}</p>
                                        <p class="flex items-center gap-2 text-gray-600"><i class="fas fa-envelope w-4 text-blue-500"></i> ${request.email}</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="bg-gray-50 rounded-lg p-4 mt-4">
                                <h4 class="font-medium text-gray-700 mb-3">Tracking Information</h4>
                                <div class="space-y-2 text-sm">
                                    <p><span class="text-gray-500">Request ID:</span> <span class="font-medium">${request.id}</span></p>
                                    <p><span class="text-gray-500">Tracking Code:</span> <span class="font-medium">${request.trackingCode}</span></p>
                                    <p><span class="text-gray-500">Submitted:</span> ${request.submitted} (${request.submittedAgo})</p>
                                    <p><span class="text-gray-500">Due Date:</span> <span class="${new Date(request.dueDate) < new Date() ? 'text-red-600 font-medium' : ''}">${request.dueDate}</span></p>
                                    <p><span class="text-gray-500">Assigned To:</span> ${request.assignedTo}</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Right Column - Request Details -->
                        <div class="col-span-2">
                            <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
                                <div class="flex items-center justify-between mb-3">
                                    <h4 class="font-medium text-gray-700">Document Request</h4>
                                    <span class="px-3 py-1 rounded-full text-xs font-bold 
                                        ${request.documentType === 'clearance' ? 'doc-clearance' : ''}
                                        ${request.documentType === 'indigency' ? 'doc-indigency' : ''}
                                        ${request.documentType === 'permit' ? 'doc-permit' : ''}
                                        ${request.documentType === 'residency' ? 'doc-residency' : ''}
                                        ${request.documentType === 'business' ? 'doc-business' : ''}">
                                        ${request.documentName}
                                    </span>
                                </div>
                                <p class="text-sm text-gray-600 mb-2"><span class="font-medium">Purpose:</span> ${request.purpose}</p>
                                <p class="text-sm text-gray-600"><span class="font-medium">Notes:</span> ${request.notes}</p>
                            </div>
                            
                            <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
                                <h4 class="font-medium text-gray-700 mb-3">Requirements Checklist</h4>
                                <div class="space-y-2">
                                    ${requirementsList}
                                </div>
                            </div>
                            
                            <div class="bg-white border border-gray-200 rounded-lg p-4">
                                <h4 class="font-medium text-gray-700 mb-3">Progress & Status</h4>
                                <div class="mb-3">
                                    <div class="flex items-center justify-between mb-1">
                                        <span class="text-sm text-gray-600">Overall Progress</span>
                                        <span class="text-sm font-medium">${request.progress}%</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-blue-600 h-2 rounded-full" style="width: ${request.progress}%"></div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-sm text-gray-600">Current Status:</span>
                                    ${request.status === 'pending' ? '<span class="status-pending px-3 py-1 rounded-full text-xs font-medium">Pending</span>' : ''}
                                    ${request.status === 'processing' ? '<span class="status-processing px-3 py-1 rounded-full text-xs font-medium">Processing</span>' : ''}
                                    ${request.status === 'review' ? '<span class="status-review px-3 py-1 rounded-full text-xs font-medium">Under Review</span>' : ''}
                                    ${request.status === 'approved' ? '<span class="status-approved px-3 py-1 rounded-full text-xs font-medium">Approved</span>' : ''}
                                    ${request.status === 'completed' ? '<span class="status-completed px-3 py-1 rounded-full text-xs font-medium">Completed</span>' : ''}
                                    ${request.status === 'rejected' ? '<span class="status-rejected px-3 py-1 rounded-full text-xs font-medium">Rejected</span>' : ''}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-3 mt-6 pt-4 border-t border-gray-200">
                        <button onclick="closeViewModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Close</button>
                        <button onclick="openProcessModal('${request.id}')" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Process Request</button>
                        <button onclick="printRequest('${request.id}')" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">Print Form</button>
                    </div>
                `;
            }
            
            document.getElementById('viewModal').classList.remove('hidden');
        }
        
        function closeViewModal() {
            document.getElementById('viewModal').classList.add('hidden');
        }
        
        // Process Modal
        function openProcessModal(requestId) {
            currentRequestId = requestId;
            document.getElementById('processModal').classList.remove('hidden');
        }
        
        function closeProcessModal() {
            document.getElementById('processModal').classList.add('hidden');
        }
        
        // Status Modal
        function openStatusModal(requestId) {
            currentRequestId = requestId;
            document.getElementById('statusModal').classList.remove('hidden');
        }
        
        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
            document.getElementById('statusRemarks').value = '';
        }
        
        // Reject Modal
        function openRejectModal(requestId) {
            currentRequestId = requestId;
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            document.getElementById('rejectComments').value = '';
            document.getElementById('rejectReasonSelect').value = 'incomplete';
        }
        
        // Requirements Modal
        function openRequirementsModal(requestId) {
            currentRequestId = requestId;
            document.getElementById('requirementsModal').classList.remove('hidden');
        }
        
        function closeRequirementsModal() {
            document.getElementById('requirementsModal').classList.add('hidden');
        }
        
        // Print Request
        function printRequest(requestId) {
            showToast('info', 'Print', `Preparing print for request ${requestId}`);
            // In real implementation, this would open a print-friendly version
        }

        // ========== BULK ACTIONS ==========
        
        // Select All functionality
        document.getElementById('selectAll').addEventListener('change', function(e) {
            const checkboxes = document.querySelectorAll('.request-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
                if (e.target.checked) {
                    selectedRequests.add(cb.value);
                } else {
                    selectedRequests.delete(cb.value);
                }
            });
            updateBulkActionsBar();
        });

        // Individual checkbox selection
        document.querySelectorAll('.request-checkbox').forEach(cb => {
            cb.addEventListener('change', function(e) {
                if (e.target.checked) {
                    selectedRequests.add(e.target.value);
                } else {
                    selectedRequests.delete(e.target.value);
                }
                updateBulkActionsBar();
                
                // Update select all checkbox
                const allCheckboxes = document.querySelectorAll('.request-checkbox');
                const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
                document.getElementById('selectAll').checked = allChecked;
            });
        });

        // Clear selection
        document.getElementById('clearSelection').addEventListener('click', function() {
            document.querySelectorAll('.request-checkbox').forEach(cb => {
                cb.checked = false;
            });
            selectedRequests.clear();
            document.getElementById('selectAll').checked = false;
            updateBulkActionsBar();
        });

        function updateBulkActionsBar() {
            const bar = document.getElementById('bulkActionsBar');
            const countSpan = document.getElementById('selectedCount');
            const count = selectedRequests.size;
            
            if (count > 0) {
                countSpan.textContent = count;
                bar.classList.remove('hidden');
            } else {
                bar.classList.add('hidden');
            }
        }

        // ========== FILTERS ==========
        
        // Quick filter tabs
        document.querySelectorAll('.filter-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.filter-tab').forEach(t => {
                    t.classList.remove('active', 'bg-blue-600', 'text-white');
                });
                this.classList.add('active', 'bg-blue-600', 'text-white');
                
                const filter = this.dataset.filter;
                applyQuickFilter(filter);
            });
        });

        function applyQuickFilter(filter) {
            // Show loading spinner
            document.getElementById('loadingSpinner').classList.remove('hidden');
            document.getElementById('requestsTable').classList.add('hidden');
            
            // Simulate API call
            setTimeout(() => {
                document.getElementById('loadingSpinner').classList.add('hidden');
                document.getElementById('requestsTable').classList.remove('hidden');
                
                showToast('success', 'Filter Applied', `Showing ${filter} requests`);
            }, 500);
        }

        // Apply filters button
        document.getElementById('applyFilters').addEventListener('click', function() {
            const status = document.getElementById('statusFilter').value;
            const docType = document.getElementById('documentFilter').value;
            const priority = document.getElementById('priorityFilter').value;
            const date = document.getElementById('dateFilter').value;
            const search = document.getElementById('searchInput').value;
            
            showToast('info', 'Filters Applied', `Status: ${status}, Type: ${docType}, Priority: ${priority}`);
        });

        // Reset filters
        document.getElementById('resetFilters').addEventListener('click', function() {
            document.getElementById('statusFilter').value = 'all';
            document.getElementById('documentFilter').value = 'all';
            document.getElementById('priorityFilter').value = 'all';
            document.getElementById('dateFilter').value = 'newest';
            document.getElementById('searchInput').value = '';
            
            showToast('info', 'Filters Reset', 'All filters have been cleared');
        });

        // Search with debounce
        let searchTimeout;
        document.getElementById('searchInput').addEventListener('input', function(e) {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                showToast('info', 'Searching', `Searching for: ${e.target.value}`);
            }, 500);
        });

        // ========== BULK ACTION BUTTONS ==========
        
        document.getElementById('bulkProcess').addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            showToast('success', 'Bulk Process', `${selectedRequests.size} requests marked for processing`);
            clearSelection();
        });

        document.getElementById('bulkApprove').addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            showToast('success', 'Bulk Approve', `${selectedRequests.size} requests approved`);
            clearSelection();
        });

        document.getElementById('bulkComplete').addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            showToast('success', 'Bulk Complete', `${selectedRequests.size} requests marked as complete`);
            clearSelection();
        });

        document.getElementById('bulkReject').addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            showToast('error', 'Bulk Reject', `${selectedRequests.size} requests rejected`);
            clearSelection();
        });

        document.getElementById('bulkPrint').addEventListener('click', function() {
            if (selectedRequests.size === 0) return;
            showToast('info', 'Bulk Print', `Preparing ${selectedRequests.size} forms for printing`);
            clearSelection();
        });

        // ========== CONFIRMATION BUTTONS ==========
        
        document.getElementById('saveProcessBtn').addEventListener('click', function() {
            const status = document.getElementById('processStatus').value;
            const assignTo = document.getElementById('assignTo').value;
            const notes = document.getElementById('processNotes').value;
            const estimatedDate = document.getElementById('estimatedDate').value;
            const priority = document.getElementById('priorityLevel').value;
            
            showToast('success', 'Request Updated', `Request ${currentRequestId} updated successfully`);
            closeProcessModal();
        });

        document.getElementById('updateStatusBtn').addEventListener('click', function() {
            const status = document.getElementById('updateStatus').value;
            const remarks = document.getElementById('statusRemarks').value;
            const notify = document.getElementById('notifyResident').checked;
            
            showToast('success', 'Status Updated', `Request ${currentRequestId} marked as ${status}`);
            closeStatusModal();
        });

        document.getElementById('confirmRejectBtn').addEventListener('click', function() {
            const reason = document.getElementById('rejectReasonSelect').value;
            const comments = document.getElementById('rejectComments').value;
            const allowResubmit = document.getElementById('allowResubmit').checked;
            
            showToast('error', 'Request Rejected', `Request ${currentRequestId} rejected: ${reason}`);
            closeRejectModal();
        });

        // ========== TOAST NOTIFICATION ==========
        
        function showToast(type, title, message) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastMessage = document.getElementById('toastMessage');
            
            // Set colors based on type
            if (type === 'success') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-check-circle text-green-500 text-xl';
            } else if (type === 'error') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-red-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-times-circle text-red-500 text-xl';
            } else if (type === 'warning') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-yellow-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-exclamation-triangle text-yellow-500 text-xl';
            } else if (type === 'info') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-blue-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-info-circle text-blue-500 text-xl';
            }
            
            toastTitle.textContent = title;
            toastMessage.textContent = message;
            
            toast.classList.remove('hidden');
            
            // Auto hide after 3 seconds
            setTimeout(hideToast, 3000);
        }
        
        function hideToast() {
            document.getElementById('toast').classList.add('hidden');
        }

        // Clear selection helper
        function clearSelection() {
            document.querySelectorAll('.request-checkbox').forEach(cb => {
                cb.checked = false;
            });
            selectedRequests.clear();
            document.getElementById('selectAll').checked = false;
            updateBulkActionsBar();
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal-overlay')) {
                closeViewModal();
                closeProcessModal();
                closeStatusModal();
                closeRejectModal();
                closeRequirementsModal();
            }
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            // Escape key closes modals
            if (e.key === 'Escape') {
                closeViewModal();
                closeProcessModal();
                closeStatusModal();
                closeRejectModal();
                closeRequirementsModal();
            }
        });
    </script>
</body>
</html>
