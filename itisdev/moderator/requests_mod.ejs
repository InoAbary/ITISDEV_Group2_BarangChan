<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Manage Document Requests</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        /* Status badges */
        .status-pending { background-color: #fff3e0; color: #ef6c00; }
        .status-processing { background-color: #e3f2fd; color: #1565c0; }
        .status-review { background-color: #f3e5f5; color: #7b1fa2; }
        .status-approved { background-color: #e8f5e8; color: #2e7d32; }
        .status-rejected { background-color: #ffebee; color: #c62828; }
        .status-completed { background-color: #e0f2f1; color: #00695c; }
        .status-hold { background-color: #fff8e1; color: #f57f17; }

        /* Document type badges */
        .doc-clearance { background-color: #e8f5e8; color: #2e7d32; }
        .doc-indigency { background-color: #fff3e0; color: #ef6c00; }
        .doc-permit { background-color: #e3f2fd; color: #1565c0; }
        .doc-residency { background-color: #f3e5f5; color: #7b1fa2; }
        .doc-business { background-color: #e0f2f1; color: #00695c; }
        .doc-certificate { background-color: #fce4ec; color: #880e4f; }

        /* Priority badges */
        .priority-low { background-color: #e6f7e6; color: #2e7d32; }
        .priority-medium { background-color: #fff3e0; color: #ef6c00; }
        .priority-high { background-color: #ffebee; color: #c62828; }
        .priority-urgent { background-color: #fce4ec; color: #880e4f; animation: pulse 2s infinite; }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }

        /* Table row hover */
        .table-row-hover:hover {
            background-color: #f9fafb;
        }

        /* Modal styles */
        .modal-overlay {
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
        }
        .modal-content {
            animation: modalSlideIn 0.3s ease-out;
        }
        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Loading spinner */
        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #f59e0b;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Toast notification */
        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: slideInRight 0.3s ease-out;
        }
        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Progress tracker */
        .progress-step {
            position: relative;
            z-index: 1;
        }
        .progress-step.completed .step-indicator {
            background-color: #10b981;
            border-color: #10b981;
            color: white;
        }
        .progress-step.active .step-indicator {
            background-color: #f59e0b;
            border-color: #f59e0b;
            color: white;
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
        }
        .progress-line {
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            height: 2px;
            background-color: #e5e7eb;
            z-index: 0;
        }
        .progress-line.completed {
            background-color: #10b981;
        }

        /* Filter tabs */
        .filter-tab {
            transition: all 0.2s ease;
        }
        .filter-tab.active {
            background-color: #f59e0b;
            color: white;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../Partials/topnavigation', { currentPath: '/moderator/requests', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header -->
        <div class="bg-gradient-to-r from-blue-800 to-blue-700 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-file-signature"></i> 
                        Document Request Management
                    </h1>
                    <p class="text-blue-100 mt-1 text-sm md:text-base">
                        <i class="fas fa-shield-alt mr-1"></i> 
                        Process, track, and manage all document requests from residents
                    </p>
                </div>
                <div class="mt-3 md:mt-0 flex items-center gap-3">
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-clock mr-2"></i>Last updated: just now
                    </span>
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-hourglass-half mr-2"></i>28 pending
                    </span>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-blue-500">
                <p class="text-xs text-gray-500">Total Requests</p>
                <p class="text-2xl font-bold text-gray-800">847</p>
                <p class="text-xs text-green-600">+45 this week</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-yellow-500">
                <p class="text-xs text-gray-500">Pending</p>
                <p class="text-2xl font-bold text-gray-800">28</p>
                <p class="text-xs text-amber-600">12 awaiting review</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-green-500">
                <p class="text-xs text-gray-500">Processing</p>
                <p class="text-2xl font-bold text-gray-800">42</p>
                <p class="text-xs text-green-600">15 almost done</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-purple-500">
                <p class="text-xs text-gray-500">Completed</p>
                <p class="text-2xl font-bold text-gray-800">731</p>
                <p class="text-xs text-purple-600">86% completion rate</p>
            </div>
        </div>

        <!-- Secondary Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-lg shadow-sm p-3 border border-gray-100">
                <p class="text-xs text-gray-500">Barangay Clearance</p>
                <p class="text-lg font-bold text-gray-800">342</p>
                <div class="w-full bg-gray-200 h-1.5 rounded-full mt-1">
                    <div class="bg-blue-600 h-1.5 rounded-full" style="width: 40%"></div>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-3 border border-gray-100">
                <p class="text-xs text-gray-500">Indigency</p>
                <p class="text-lg font-bold text-gray-800">156</p>
                <div class="w-full bg-gray-200 h-1.5 rounded-full mt-1">
                    <div class="bg-green-600 h-1.5 rounded-full" style="width: 18%"></div>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-3 border border-gray-100">
                <p class="text-xs text-gray-500">Business Permit</p>
                <p class="text-lg font-bold text-gray-800">98</p>
                <div class="w-full bg-gray-200 h-1.5 rounded-full mt-1">
                    <div class="bg-purple-600 h-1.5 rounded-full" style="width: 12%"></div>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-3 border border-gray-100">
                <p class="text-xs text-gray-500">Residency Cert</p>
                <p class="text-lg font-bold text-gray-800">251</p>
                <div class="w-full bg-gray-200 h-1.5 rounded-full mt-1">
                    <div class="bg-amber-600 h-1.5 rounded-full" style="width: 30%"></div>
                </div>
            </div>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
                <!-- Search Bar -->
                <div class="flex-1 w-full md:w-auto">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" 
                               id="searchInput"
                               placeholder="Search by request ID, resident name, or document type..." 
                               class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400 focus:border-blue-400">
                    </div>
                </div>
                
                <!-- Filter Dropdowns -->
                <div class="flex flex-wrap gap-2 w-full md:w-auto">
                    <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="all">All Status</option>
                        <option value="pending">Pending</option>
                        <option value="processing">Processing</option>
                        <option value="review">Under Review</option>
                        <option value="approved">Approved</option>
                        <option value="rejected">Rejected</option>
                        <option value="completed">Completed</option>
                        <option value="hold">On Hold</option>
                    </select>
                    
                    <select id="documentFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="all">All Documents</option>
                        <option value="clearance">Barangay Clearance</option>
                        <option value="indigency">Certificate of Indigency</option>
                        <option value="residency">Certificate of Residency</option>
                        <option value="business">Business Permit</option>
                        <option value="permit">Building Permit</option>
                        <option value="certificate">Other Certificates</option>
                    </select>
                    
                    <select id="priorityFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="all">All Priorities</option>
                        <option value="urgent">Urgent</option>
                        <option value="high">High</option>
                        <option value="medium">Medium</option>
                        <option value="low">Low</option>
                    </select>
                    
                    <select id="dateFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400">
                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                        <option value="due">Due Date</option>
                        <option value="completed">Recently Completed</option>
                    </select>
                    
                    <button id="applyFilters" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium transition">
                        <i class="fas fa-filter mr-1"></i> Apply Filters
                    </button>
                    
                    <button id="resetFilters" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
                        <i class="fas fa-redo-alt mr-1"></i> Reset
                    </button>
                </div>
            </div>
            
            <!-- Quick Filter Tabs -->
            <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-gray-200">
                <button class="filter-tab active px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white" data-filter="all">All Requests</button>
                <button class="filter-tab px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100" data-filter="pending">Pending (28)</button>
                <button class="filter-tab px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100" data-filter="processing">Processing (42)</button>
                <button class="filter-tab px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100" data-filter="review">Under Review (15)</button>
                <button class="filter-tab px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100" data-filter="urgent">Urgent (8)</button>
