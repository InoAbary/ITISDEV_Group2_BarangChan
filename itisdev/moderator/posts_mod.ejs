                        %>
                        <% posts.forEach(function(post) { %>
                        <tr class="table-row-hover" data-post-id="<%= post.id %>">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <input type="checkbox" class="post-checkbox rounded border-gray-300 text-amber-600 focus:ring-amber-500" value="<%= post.id %>">
                            </td>
                            <td class="px-6 py-4">
                                <div>
                                    <p class="text-sm font-medium text-gray-900"><%= post.title %></p>
                                    <p class="text-xs text-gray-500 mt-1"><%= post.excerpt %></p>
                                    <p class="text-xs text-gray-400 mt-1">ID: <%= post.id %></p>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gradient-to-br <%= post.isOfficial ? 'from-blue-600 to-amber-600' : 'from-gray-400 to-gray-500' %> flex items-center justify-center text-white text-xs font-bold">
                                        <%= post.authorAvatar %>
                                    </div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-gray-900"><%= post.author %></p>
                                        <p class="text-xs text-gray-500"><%= post.authorRole %></p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs rounded-full 
                                    <%= post.type === 'announcement' ? 'bg-blue-100 text-blue-700' : '' %>
                                    <%= post.type === 'concern' ? 'bg-orange-100 text-orange-700' : '' %>
                                    <%= post.type === 'emergency' ? 'bg-red-100 text-red-700' : '' %>
                                    <%= post.type === 'suggestion' ? 'bg-green-100 text-green-700' : '' %>
                                    <%= post.type === 'complaint' ? 'bg-purple-100 text-purple-700' : '' %>
                                    <%= post.type === 'query' ? 'bg-gray-100 text-gray-700' : '' %>">
                                    <i class="fas 
                                        <%= post.type === 'announcement' ? 'fa-bullhorn' : '' %>
                                        <%= post.type === 'concern' ? 'fa-exclamation-triangle' : '' %>
                                        <%= post.type === 'emergency' ? 'fa-exclamation-circle' : '' %>
                                        <%= post.type === 'suggestion' ? 'fa-lightbulb' : '' %>
                                        <%= post.type === 'complaint' ? 'fa-flag' : '' %>
                                        <%= post.type === 'query' ? 'fa-question-circle' : '' %> mr-1"></i>
                                    <%= post.type.charAt(0).toUpperCase() + post.type.slice(1) %>
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if (post.urgency === 'low') { %>
                                    <span class="urgency-low px-3 py-1 rounded-full text-xs font-medium">Low</span>
                                <% } else if (post.urgency === 'medium') { %>
                                    <span class="urgency-medium px-3 py-1 rounded-full text-xs font-medium">Medium</span>
                                <% } else if (post.urgency === 'high') { %>
                                    <span class="urgency-high px-3 py-1 rounded-full text-xs font-medium">High</span>
                                <% } else if (post.urgency === 'emergency') { %>
                                    <span class="urgency-emergency px-3 py-1 rounded-full text-xs font-medium">🚨 Emergency</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if (post.status === 'pending') { %>
                                    <span class="status-pending px-3 py-1 rounded-full text-xs font-medium">Pending</span>
                                <% } else if (post.status === 'approved') { %>
                                    <span class="status-approved px-3 py-1 rounded-full text-xs font-medium">Approved</span>
                                <% } else if (post.status === 'rejected') { %>
                                    <span class="status-rejected px-3 py-1 rounded-full text-xs font-medium">Rejected</span>
                                <% } else if (post.status === 'flagged') { %>
                                    <span class="status-flagged px-3 py-1 rounded-full text-xs font-medium">Flagged</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <% if (post.reports > 0) { %>
                                    <span class="<%= post.reports >= 5 ? 'bg-red-100 text-red-600' : 'bg-yellow-100 text-yellow-600' %> px-2 py-1 rounded-full text-xs font-medium">
                                        <i class="fas fa-flag mr-1"></i><%= post.reports %> reports
                                    </span>
                                <% } else { %>
                                    <span class="text-gray-400 text-xs">None</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <span title="<%= post.timestamp %>"><%= post.timeAgo %></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                <div class="flex items-center gap-1">
                                    <button class="text-green-600 hover:text-green-700 hover:bg-green-50 p-2 rounded-lg transition" title="Approve" onclick='openApproveModal("<%= post.id %>")'>
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button class="text-red-600 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition" title="Reject" onclick='openRejectModal("<%= post.id %>")'>
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <button class="text-amber-600 hover:text-amber-700 hover:bg-amber-50 p-2 rounded-lg transition" title="View Details" onclick='openViewModal("<%= post.id %>")'>
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="text-blue-600 hover:text-blue-700 hover:bg-blue-50 p-2 rounded-lg transition" title="Flag/Report" onclick='openFlagModal("<%= post.id %>")'>
                                        <i class="fas fa-flag"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            
            <!-- Table Footer with Pagination -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="text-sm text-gray-500">
                    Showing <span class="font-medium">1</span> to <span class="font-medium">8</span> of <span class="font-medium">1,284</span> posts
                </div>
                <div class="flex items-center gap-2">
                    <button class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition" disabled>
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="px-3 py-1 bg-amber-600 text-white rounded-lg text-sm">1</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">2</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">3</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">4</button>
                    <span class="text-gray-400">...</span>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">161</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- View Post Modal -->
    <div id="viewModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto modal-content">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-eye text-amber-600"></i>
                    Post Details
                </h3>
                <button onclick="closeViewModal()" class="text-gray-400 hover:text-gray-600">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="p-6" id="viewModalContent">
                <!-- Content will be dynamically populated -->
            </div>
        </div>
    </div>

    <!-- Approve Confirmation Modal -->
    <div id="approveModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <div class="text-center mb-4">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-check-circle text-green-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Approve Post</h3>
                    <p class="text-gray-600" id="approveModalText">Are you sure you want to approve this post? It will be published immediately.</p>
                </div>
                <div class="flex gap-3">
                    <button onclick="closeApproveModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="confirmApproveBtn" class="flex-1 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">Confirm Approve</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Reject Modal with Reason -->
    <div id="rejectModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <div class="text-center mb-4">
                    <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-times-circle text-red-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Reject Post</h3>
                    <p class="text-gray-600">Please provide a reason for rejection</p>
                </div>
                <textarea id="rejectReason" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 mb-4" placeholder="Enter reason for rejection..."></textarea>
                <div class="flex gap-3">
                    <button onclick="closeRejectModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="confirmRejectBtn" class="flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">Confirm Reject</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Flag Modal -->
    <div id="flagModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <div class="text-center mb-4">
                    <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-flag text-blue-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Flag Post</h3>
                    <p class="text-gray-600">Please select a reason for flagging this post:</p>
                </div>
                <div class="space-y-2 mb-4">
                    <label class="flex items-center gap-2 p-2 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                        <input type="radio" name="flagReason" value="inappropriate" class="text-amber-600 focus:ring-amber-500">
                        <span class="text-sm text-gray-700">Inappropriate content</span>
                    </label>
                    <label class="flex items-center gap-2 p-2 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                        <input type="radio" name="flagReason" value="spam" class="text-amber-600 focus:ring-amber-500">
                        <span class="text-sm text-gray-700">Spam or misleading</span>
                    </label>
                    <label class="flex items-center gap-2 p-2 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                        <input type="radio" name="flagReason" value="harassment" class="text-amber-600 focus:ring-amber-500">
                        <span class="text-sm text-gray-700">Harassment or bullying</span>
                    </label>
                    <label class="flex items-center gap-2 p-2 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                        <input type="radio" name="flagReason" value="false-info" class="text-amber-600 focus:ring-amber-500">
                        <span class="text-sm text-gray-700">False information</span>
                    </label>
                </div>
                <textarea id="flagComments" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 mb-4" placeholder="Additional comments (optional)..."></textarea>
                <div class="flex gap-3">
                    <button onclick="closeFlagModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="confirmFlagBtn" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Submit Flag</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]">
        <div class="flex items-center gap-3">
            <i id="toastIcon" class="fas fa-check-circle text-green-500 text-xl"></i>
            <div>
                <p id="toastTitle" class="font-medium text-gray-800">Success</p>
                <p id="toastMessage" class="text-sm text-gray-600">Action completed successfully</p>
            </div>
            <button onclick="hideToast()" class="ml-auto text-gray-400 hover:text-gray-600">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>

    <!-- Include chatbot -->
    <%- include('../Partials/chatbot') %>
    <!-- Include footer -->
    <%- include('../Partials/footer') %>

    <script id="postsDataJson" type="application/json"><%- JSON.stringify(posts) %></script>
    <script>
        // Store posts data for JavaScript access
        const postsDataElement = document.getElementById('postsDataJson');
        const postsData = postsDataElement ? JSON.parse(postsDataElement.textContent || '[]') : [];
        let currentPostId = null;
        let selectedPosts = new Set();

        // ========== MODAL FUNCTIONS ==========
        
        // View Modal
        function openViewModal(postId) {
            currentPostId = postId;
            const post = postsData.find(p => p.id === postId);
            
            if (post) {
                const modalContent = document.getElementById('viewModalContent');
                modalContent.innerHTML = `
                    <div class="mb-4">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br ${post.isOfficial ? 'from-blue-600 to-amber-600' : 'from-gray-400 to-gray-500'} flex items-center justify-center text-white font-bold text-xl">
                                ${post.authorAvatar}
                            </div>
                            <div>
                                <p class="font-semibold text-gray-800">${post.author}</p>
                                <p class="text-sm text-gray-500">${post.authorRole} • Posted ${post.timeAgo}</p>
                            </div>
                            <span class="ml-auto urgency-${post.urgency} px-3 py-1 rounded-full text-xs font-medium">
                                ${post.urgency === 'emergency' ? '🚨 ' : ''}${post.urgency.charAt(0).toUpperCase() + post.urgency.slice(1)} Urgency
                            </span>
                        </div>
                        <h4 class="text-xl font-bold text-gray-800 mb-2">${post.title}</h4>
                        <p class="text-gray-700 leading-relaxed mb-4">
                            ${post.content}
                        </p>
                        <div class="bg-gray-50 rounded-lg p-4 mb-4">
                            <p class="text-sm font-medium text-gray-700 mb-2">Additional Information:</p>
                            <ul class="text-sm text-gray-600 space-y-1">
                                <li><i class="fas fa-map-pin text-amber-600 w-5"></i> Location: ${post.location}</li>
                                <li><i class="fas fa-clock text-amber-600 w-5"></i> Posted: ${new Date(post.timestamp).toLocaleString()}</li>
                                <li><i class="fas fa-users text-amber-600 w-5"></i> Affected residents: ${post.affectedResidents}</li>
                                ${post.reports > 0 ? `<li><i class="fas fa-flag text-red-600 w-5"></i> Reports: ${post.reports}</li>` : ''}
                            </ul>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
                        <button onclick="closeViewModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Close</button>
                        <button onclick="openApproveModal('${post.id}')" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">Approve Post</button>
                        <button onclick="openRejectModal('${post.id}')" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">Reject Post</button>
                    </div>
                `;
            }
            
            document.getElementById('viewModal').classList.remove('hidden');
        }
        
        function closeViewModal() {
            document.getElementById('viewModal').classList.add('hidden');
        }
        
        // Approve Modal
        function openApproveModal(postId) {
            currentPostId = postId;
            document.getElementById('approveModal').classList.remove('hidden');
        }
        
        function closeApproveModal() {
            document.getElementById('approveModal').classList.add('hidden');
        }
        
        // Reject Modal
        function openRejectModal(postId) {
            currentPostId = postId;
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            document.getElementById('rejectReason').value = '';
        }
        
        // Flag Modal
        function openFlagModal(postId) {
            currentPostId = postId;
            document.getElementById('flagModal').classList.remove('hidden');
        }
        
        function closeFlagModal() {
            document.getElementById('flagModal').classList.add('hidden');
            document.getElementById('flagComments').value = '';
            document.querySelectorAll('input[name="flagReason"]').forEach(r => r.checked = false);
        }

        // ========== BULK ACTIONS ==========
        
        // Select All functionality
        document.getElementById('selectAll').addEventListener('change', function(e) {
            const checkboxes = document.querySelectorAll('.post-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
                if (e.target.checked) {
                    selectedPosts.add(cb.value);
                } else {
                    selectedPosts.delete(cb.value);
                }
            });
            updateBulkActionsBar();
        });

        // Individual checkbox selection
        document.querySelectorAll('.post-checkbox').forEach(cb => {
            cb.addEventListener('change', function(e) {
                if (e.target.checked) {
                    selectedPosts.add(e.target.value);
                } else {
                    selectedPosts.delete(e.target.value);
                }
                updateBulkActionsBar();
                
                // Update select all checkbox
                const allCheckboxes = document.querySelectorAll('.post-checkbox');
                const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
                document.getElementById('selectAll').checked = allChecked;
            });
        });

        // Clear selection
        document.getElementById('clearSelection').addEventListener('click', function() {
            document.querySelectorAll('.post-checkbox').forEach(cb => {
                cb.checked = false;
            });
            selectedPosts.clear();
            document.getElementById('selectAll').checked = false;
            updateBulkActionsBar();
        });

        function updateBulkActionsBar() {
            const bar = document.getElementById('bulkActionsBar');
            const countSpan = document.getElementById('selectedCount');
            const count = selectedPosts.size;
            
            if (count > 0) {
                countSpan.textContent = count;
                bar.classList.remove('hidden');
            } else {
                bar.classList.add('hidden');
            }
        }

        // ========== FILTERS ==========
        
        // Quick filter tabs
        document.querySelectorAll('.filter-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.filter-tab').forEach(t => {
                    t.classList.remove('active', 'bg-amber-600', 'text-white');
                });
                this.classList.add('active', 'bg-amber-600', 'text-white');
                
                const filter = this.dataset.filter;
                applyQuickFilter(filter);
            });
        });

        function applyQuickFilter(filter) {
            // Show loading spinner
            document.getElementById('loadingSpinner').classList.remove('hidden');
            document.getElementById('postsTable').classList.add('hidden');
            
            // Simulate API call
            setTimeout(() => {
                // In real implementation, this would fetch filtered data
                document.getElementById('loadingSpinner').classList.add('hidden');
                document.getElementById('postsTable').classList.remove('hidden');
                
                showToast('success', 'Filter Applied', `Showing ${filter} posts`);
            }, 500);
        }

        // Apply filters button
        document.getElementById('applyFilters').addEventListener('click', function() {
            const status = document.getElementById('statusFilter').value;
            const urgency = document.getElementById('urgencyFilter').value;
            const type = document.getElementById('typeFilter').value;
            const sort = document.getElementById('sortFilter').value;
            const search = document.getElementById('searchInput').value;
            
            showToast('info', 'Filters Applied', `Status: ${status}, Urgency: ${urgency}, Type: ${type}`);
        });

        // Reset filters
        document.getElementById('resetFilters').addEventListener('click', function() {
            document.getElementById('statusFilter').value = 'all';
            document.getElementById('urgencyFilter').value = 'all';
            document.getElementById('typeFilter').value = 'all';
            document.getElementById('sortFilter').value = 'newest';
            document.getElementById('searchInput').value = '';
            
            showToast('info', 'Filters Reset', 'All filters have been cleared');
        });

        // Search with debounce
        let searchTimeout;
        document.getElementById('searchInput').addEventListener('input', function(e) {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                showToast('info', 'Searching', `Searching for: ${e.target.value}`);
            }, 500);
        });

        // ========== BULK ACTION BUTTONS ==========
        
        document.getElementById('bulkApprove').addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            showToast('success', 'Bulk Approve', `${selectedPosts.size} posts approved successfully`);
            clearSelection();
        });

        document.getElementById('bulkReject').addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            showToast('error', 'Bulk Reject', `${selectedPosts.size} posts rejected`);
            clearSelection();
        });

        document.getElementById('bulkFlag').addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            showToast('warning', 'Bulk Flag', `${selectedPosts.size} posts flagged for review`);
            clearSelection();
        });

        document.getElementById('bulkArchive').addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            showToast('info', 'Bulk Archive', `${selectedPosts.size} posts archived`);
            clearSelection();
        });

        // ========== CONFIRMATION BUTTONS ==========
        
        document.getElementById('confirmApproveBtn').addEventListener('click', function() {
            showToast('success', 'Post Approved', `Post ${currentPostId} has been approved`);
            closeApproveModal();
        });

        document.getElementById('confirmRejectBtn').addEventListener('click', function() {
            const reason = document.getElementById('rejectReason').value;
            showToast('error', 'Post Rejected', `Post ${currentPostId} rejected: ${reason || 'No reason provided'}`);
            closeRejectModal();
        });

        document.getElementById('confirmFlagBtn').addEventListener('click', function() {
            const reason = document.querySelector('input[name="flagReason"]:checked')?.value || 'No reason selected';
            const comments = document.getElementById('flagComments').value;
            showToast('warning', 'Post Flagged', `Post ${currentPostId} flagged: ${reason}`);
            closeFlagModal();
        });

        // ========== TOAST NOTIFICATION ==========
        
        function showToast(type, title, message) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastMessage = document.getElementById('toastMessage');
            
            // Set colors based on type
            if (type === 'success') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-check-circle text-green-500 text-xl';
            } else if (type === 'error') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-red-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-times-circle text-red-500 text-xl';
            } else if (type === 'warning') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-yellow-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-exclamation-triangle text-yellow-500 text-xl';
            } else if (type === 'info') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-blue-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-info-circle text-blue-500 text-xl';
            }
            
            toastTitle.textContent = title;
            toastMessage.textContent = message;
            
            toast.classList.remove('hidden');
            
            // Auto hide after 3 seconds
            setTimeout(hideToast, 3000);
        }
        
        function hideToast() {
            document.getElementById('toast').classList.add('hidden');
        }

        // Clear selection helper
        function clearSelection() {
            document.querySelectorAll('.post-checkbox').forEach(cb => {
                cb.checked = false;
            });
            selectedPosts.clear();
            document.getElementById('selectAll').checked = false;
            updateBulkActionsBar();
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal-overlay')) {
                closeViewModal();
                closeApproveModal();
                closeRejectModal();
                closeFlagModal();
            }
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            // Escape key closes modals
            if (e.key === 'Escape') {
                closeViewModal();
                closeApproveModal();
                closeRejectModal();
                closeFlagModal();
            }
        });
    </script>
</body>
</html>
