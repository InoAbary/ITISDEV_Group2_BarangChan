<!-- moderator/posts_mod.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Manage Posts</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .status-pending { background-color: #fff3e0; color: #ef6c00; }
        .status-resolved { background-color: #e8f5e8; color: #2e7d32; }
        .status-closed { background-color: #ffebee; color: #c62828; }

        .urgency-low { background-color: #e6f7e6; color: #2e7d32; }
        .urgency-medium { background-color: #fff3e0; color: #ef6c00; }
        .urgency-high { background-color: #ffebee; color: #c62828; }
        .urgency-emergency { background-color: #fce4ec; color: #880e4f; animation: pulse 2s infinite; }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }

        .post-management-card {
            transition: all 0.2s ease;
        }
        .post-management-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .filter-tab {
            transition: all 0.2s ease;
        }
        .filter-tab.active {
            background-color: #f59e0b;
            color: white;
        }

        .table-row-hover:hover {
            background-color: #f9fafb;
        }

        .modal-overlay {
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
        }
        .modal-content {
            animation: modalSlideIn 0.3s ease-out;
        }
        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #f59e0b;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: slideInRight 0.3s ease-out;
        }
        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/moderator/posts', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header -->
        <div class="bg-gradient-to-r from-amber-800 to-amber-700 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-comments"></i> 
                        Manage Community Posts
                    </h1>
                    <p class="text-amber-100 mt-1 text-sm md:text-base">
                        <i class="fas fa-shield-alt mr-1"></i> 
                        Review, approve, and moderate all community posts
                    </p>
                </div>
                <div class="mt-3 md:mt-0 flex items-center gap-3">
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-clock mr-2"></i>Last updated: just now
                    </span>
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-chart-line mr-2"></i><%= totalPosts %> total posts
                    </span>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Stats Cards - Dynamic from Backend -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-6">
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-amber-500">
                <p class="text-xs text-gray-500">Total Posts</p>
                <p class="text-2xl font-bold text-gray-800"><%= totalPosts || 0 %></p>
                <p class="text-xs text-green-600">+<%= statusCounts?.find(s => s.status === 'Resolved')?.count || 0 %> resolved</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-yellow-500">
                <p class="text-xs text-gray-500">Pending Review</p>
                <p class="text-2xl font-bold text-gray-800"><%= statusCounts?.find(s => s.status === 'Pending')?.count || 0 %></p>
                <p class="text-xs text-amber-600"><%= urgencyCounts?.find(u => u.urgency === 'emergency')?.count || 0 %> urgent</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-green-500">
                <p class="text-xs text-gray-500">Resolved</p>
                <p class="text-2xl font-bold text-gray-800"><%= statusCounts?.find(s => s.status === 'Resolved')?.count || 0 %></p>
                <p class="text-xs text-green-600">Approved posts</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-red-500">
                <p class="text-xs text-gray-500">Flagged/Reported</p>
                <p class="text-2xl font-bold text-gray-800"><%= posts?.filter(p => p.reports_count > 0).length || 0 %></p>
                <p class="text-xs text-red-600">Need review</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-4 border-l-4 border-purple-500">
                <p class="text-xs text-gray-500">Closed</p>
                <p class="text-2xl font-bold text-gray-800"><%= statusCounts?.find(s => s.status === 'Closed')?.count || 0 %></p>
                <p class="text-xs text-purple-600">Rejected/Archived</p>
            </div>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
                <!-- Search Bar -->
                <div class="flex-1 w-full md:w-auto">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" 
                               id="searchInput"
                               placeholder="Search posts by title, author, or content..." 
                               value="<%= query?.search || '' %>"
                               class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
                    </div>
                </div>
                
                <!-- Filter Dropdowns -->
                <div class="flex flex-wrap gap-2 w-full md:w-auto">
                    <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all" <%= query?.status === 'all' || !query?.status ? 'selected' : '' %>>All Status</option>
                        <option value="Pending" <%= query?.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Resolved" <%= query?.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                        <option value="Closed" <%= query?.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                    
                    <select id="urgencyFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all" <%= query?.urgency === 'all' || !query?.urgency ? 'selected' : '' %>>All Urgency</option>
                        <option value="emergency" <%= query?.urgency === 'emergency' ? 'selected' : '' %>>Emergency</option>
                        <option value="high" <%= query?.urgency === 'high' ? 'selected' : '' %>>High</option>
                        <option value="medium" <%= query?.urgency === 'medium' ? 'selected' : '' %>>Medium</option>
                        <option value="low" <%= query?.urgency === 'low' ? 'selected' : '' %>>Low</option>
                    </select>
                    
                    <select id="typeFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all" <%= query?.type === 'all' || !query?.type ? 'selected' : '' %>>All Types</option>
                        <option value="announcement" <%= query?.type === 'announcement' ? 'selected' : '' %>>Announcement</option>
                        <option value="complaint" <%= query?.type === 'complaint' ? 'selected' : '' %>>Complaint</option>
                        <option value="suggestion" <%= query?.type === 'suggestion' ? 'selected' : '' %>>Suggestion</option>
                        <option value="query" <%= query?.type === 'query' ? 'selected' : '' %>>Query</option>
                        <option value="update" <%= query?.type === 'update' ? 'selected' : '' %>>Update</option>
                        <option value="emergency" <%= query?.type === 'emergency' ? 'selected' : '' %>>Emergency</option>
                    </select>
                    
                    <select id="barangayFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all" <%= query?.barangay === 'all' || !query?.barangay ? 'selected' : '' %>>All Barangays</option>
                        <% if (barangays && barangays.length > 0) { %>
                            <% barangays.forEach(function(barangay) { %>
                                <option value="<%= barangay %>" <%= query?.barangay === barangay ? 'selected' : '' %>><%= barangay %></option>
                            <% }); %>
                        <% } %>
                    </select>
                    
                    <select id="sortFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="latest" <%= query?.sort === 'latest' || !query?.sort ? 'selected' : '' %>>Newest First</option>
                        <option value="oldest" <%= query?.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                        <option value="most_urgent" <%= query?.sort === 'most_urgent' ? 'selected' : '' %>>Most Urgent</option>
                        <option value="most_reported" <%= query?.sort === 'most_reported' ? 'selected' : '' %>>Most Reported</option>
                        <option value="most_commented" <%= query?.sort === 'most_commented' ? 'selected' : '' %>>Most Commented</option>
                        <option value="most_liked" <%= query?.sort === 'most_liked' ? 'selected' : '' %>>Most Liked</option>
                    </select>
                    
                    <button id="applyFilters" class="px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 text-sm font-medium transition">
                        <i class="fas fa-filter mr-1"></i> Apply
                    </button>
                    
                    <a href="/moderator/posts" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
                        <i class="fas fa-redo-alt mr-1"></i> Reset
                    </a>
                </div>
            </div>
            
            <!-- Quick Filter Tabs -->
            <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-gray-200">
                <a href="?status=all" class="filter-tab <%= !query?.status || query?.status === 'all' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-amber-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    All Posts (<%= totalPosts %>)
                </a>
                <a href="?status=Pending" class="filter-tab <%= query?.status === 'Pending' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-amber-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    Pending (<%= statusCounts?.find(s => s.status === 'Pending')?.count || 0 %>)
                </a>
                <a href="?status=Resolved" class="filter-tab <%= query?.status === 'Resolved' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-amber-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    Resolved (<%= statusCounts?.find(s => s.status === 'Resolved')?.count || 0 %>)
                </a>
                <a href="?urgency=emergency" class="filter-tab <%= query?.urgency === 'emergency' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-amber-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    Emergency (<%= urgencyCounts?.find(u => u.urgency === 'emergency')?.count || 0 %>)
                </a>
                <a href="?urgency=high" class="filter-tab <%= query?.urgency === 'high' ? 'active px-4 py-2 rounded-lg text-sm font-medium bg-amber-600 text-white' : 'px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100' %>">
                    High Priority (<%= urgencyCounts?.find(u => u.urgency === 'high')?.count || 0 %>)
                </a>
            </div>
        </div>

        <!-- Bulk Actions Bar -->
        <div id="bulkActionsBar" class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6 hidden">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-700"><span id="selectedCount" class="text-amber-600 font-bold">0</span> posts selected</span>
                    <button id="clearSelection" class="text-xs text-gray-500 hover:text-amber-600 transition">
                        <i class="fas fa-times mr-1"></i>Clear selection
                    </button>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button id="bulkApprove" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium transition">
                        <i class="fas fa-check-circle mr-1"></i> Approve Selected
                    </button>
                    <button id="bulkReject" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 text-sm font-medium transition">
                        <i class="fas fa-times-circle mr-1"></i> Reject Selected
                    </button>
                    <button id="bulkArchive" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 text-sm font-medium transition">
                        <i class="fas fa-archive mr-1"></i> Archive
                    </button>
                </div>
            </div>
        </div>

        <!-- Loading Spinner -->
        <div id="loadingSpinner" class="hidden flex justify-center items-center py-12">
            <div class="spinner"></div>
        </div>

        <!-- Posts Table -->
        <div id="postsTable" class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden mb-8">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <input type="checkbox" id="selectAll" class="rounded border-gray-300 text-amber-600 focus:ring-amber-500">
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Post Details</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Author</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Urgency</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reports</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Posted</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="postsTableBody" class="bg-white divide-y divide-gray-200">
                        <% if (posts && posts.length > 0) { %>
                            <% posts.forEach(function(post) { %>
                            <tr class="table-row-hover" data-post-id="<%= post.id %>">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <input type="checkbox" class="post-checkbox rounded border-gray-300 text-amber-600 focus:ring-amber-500" value="<%= post.id %>">
                                </td>
                                <td class="px-6 py-4">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900"><%= post.title || 'Untitled Post' %></p>
                                        <p class="text-xs text-gray-500 mt-1"><%= post.content ? (post.content.length > 80 ? post.content.substring(0, 80) + '...' : post.content) : 'No content' %></p>
                                        <p class="text-xs text-gray-400 mt-1">ID: <%= post.id %> • Barangay: <%= post.barangay || 'N/A' %></p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gradient-to-br <%= post.is_official ? 'from-blue-600 to-amber-600' : 'from-gray-400 to-gray-500' %> flex items-center justify-center text-white text-xs font-bold">
                                            <%= post.user_avatar %>
                                        </div>
                                        <div class="ml-3">
                                            <p class="text-sm font-medium text-gray-900"><%= post.author_name %></p>
                                            <p class="text-xs text-gray-500"><%= post.author_email %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 text-xs rounded-full 
                                        <%= post.type === 'announcement' ? 'bg-blue-100 text-blue-700' : '' %>
                                        <%= post.type === 'complaint' ? 'bg-purple-100 text-purple-700' : '' %>
                                        <%= post.type === 'emergency' ? 'bg-red-100 text-red-700' : '' %>
                                        <%= post.type === 'suggestion' ? 'bg-green-100 text-green-700' : '' %>
                                        <%= post.type === 'query' ? 'bg-gray-100 text-gray-700' : '' %>
                                        <%= post.type === 'update' ? 'bg-amber-100 text-amber-700' : '' %>">
                                        <i class="fas 
                                            <%= post.type === 'announcement' ? 'fa-bullhorn' : '' %>
                                            <%= post.type === 'complaint' ? 'fa-flag' : '' %>
                                            <%= post.type === 'emergency' ? 'fa-exclamation-circle' : '' %>
                                            <%= post.type === 'suggestion' ? 'fa-lightbulb' : '' %>
                                            <%= post.type === 'query' ? 'fa-question-circle' : '' %>
                                            <%= post.type === 'update' ? 'fa-pen' : '' %> mr-1"></i>
                                        <%= post.type.charAt(0).toUpperCase() + post.type.slice(1) %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (post.urgency === 'low') { %>
                                        <span class="urgency-low px-3 py-1 rounded-full text-xs font-medium">Low</span>
                                    <% } else if (post.urgency === 'medium') { %>
                                        <span class="urgency-medium px-3 py-1 rounded-full text-xs font-medium">Medium</span>
                                    <% } else if (post.urgency === 'high') { %>
                                        <span class="urgency-high px-3 py-1 rounded-full text-xs font-medium">High</span>
                                    <% } else if (post.urgency === 'emergency') { %>
                                        <span class="urgency-emergency px-3 py-1 rounded-full text-xs font-medium">🚨 Emergency</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (post.status === 'Pending') { %>
                                        <span class="status-pending px-3 py-1 rounded-full text-xs font-medium">Pending</span>
                                    <% } else if (post.status === 'Resolved') { %>
                                        <span class="status-resolved px-3 py-1 rounded-full text-xs font-medium">Resolved</span>
                                    <% } else if (post.status === 'Closed') { %>
                                        <span class="status-closed px-3 py-1 rounded-full text-xs font-medium">Closed</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    <% if (post.reports_count > 0) { %>
                                        <span class="<%= post.reports_count >= 5 ? 'bg-red-100 text-red-600' : 'bg-yellow-100 text-yellow-600' %> px-2 py-1 rounded-full text-xs font-medium">
                                            <i class="fas fa-flag mr-1"></i><%= post.reports_count %>
                                        </span>
                                    <% } else { %>
                                        <span class="text-gray-400 text-xs">None</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <span title="<%= post.created_at %>"><%= post.time_ago %></span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <div class="flex items-center gap-1">
                                        <button class="text-green-600 hover:text-green-700 hover:bg-green-50 p-2 rounded-lg transition" title="Approve" onclick='openApproveModal("<%= post.id %>")'>
                                            <i class="fas fa-check"></i>
                                        </button>
                                        <button class="text-red-600 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition" title="Reject" onclick='openRejectModal("<%= post.id %>")'>
                                            <i class="fas fa-times"></i>
                                        </button>
                                        <button class="text-amber-600 hover:text-amber-700 hover:bg-amber-50 p-2 rounded-lg transition" title="View Details" onclick='openViewModal("<%= post.id %>")'>
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="9" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fas fa-inbox text-4xl mb-3"></i>
                                    <p>No posts found matching your filters.</p>
                                    <a href="/moderator/posts" class="mt-2 inline-block text-amber-600 hover:text-amber-700">Clear all filters</a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            
            <!-- Table Footer with Pagination -->
            <% if (totalPages > 1) { %>
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="text-sm text-gray-500">
                    Showing <span class="font-medium"><%= (currentPage - 1) * limit + 1 %></span> to 
                    <span class="font-medium"><%= Math.min(currentPage * limit, totalPosts) %></span> of 
                    <span class="font-medium"><%= totalPosts %></span> posts
                </div>
                <div class="flex items-center gap-2">
                    <% if (currentPage > 1) { %>
                        <a href="?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>" 
                           class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    <% } %>
                    
                    <% for(let i = 1; i <= Math.min(5, totalPages); i++) { 
                        let pageNum = i;
                        if (currentPage > 3 && i === 1) { %>
                            <a href="?<%= new URLSearchParams({...query, page: 1}).toString() %>" class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">1</a>
                            <% if (currentPage > 4) { %>
                                <span class="text-gray-400">...</span>
                            <% } %>
                            <% pageNum = currentPage - 2;
                        } else if (currentPage > 3 && i === 2) {
                            pageNum = currentPage - 1;
                        } else if (currentPage > 3 && i === 3) {
                            pageNum = currentPage;
                        } else if (currentPage > 3 && i === 4) {
                            pageNum = currentPage + 1;
                        } else if (currentPage > 3 && i === 5) {
                            pageNum = currentPage + 2;
                        }
                        
                        if (pageNum <= totalPages && pageNum >= 1) { %>
                            <a href="?<%= new URLSearchParams({...query, page: pageNum}).toString() %>" 
                               class="px-3 py-1 border border-gray-300 rounded-lg text-sm <%= pageNum === currentPage ? 'bg-amber-600 text-white border-amber-600' : 'text-gray-600 hover:bg-gray-100' %> transition">
                                <%= pageNum %>
                            </a>
                        <% } 
                    } %>
                    
                    <% if (currentPage + 2 < totalPages) { %>
                        <span class="text-gray-400">...</span>
                        <a href="?<%= new URLSearchParams({...query, page: totalPages}).toString() %>" 
                           class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                            <%= totalPages %>
                        </a>
                    <% } %>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>" 
                           class="px-3 py-1 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </main>

    <!-- View Post Modal -->
    <div id="viewModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto modal-content">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-eye text-amber-600"></i>
                    Post Details
                </h3>
                <button onclick="closeViewModal()" class="text-gray-400 hover:text-gray-600">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="p-6" id="viewModalContent">
                <!-- Content will be dynamically populated -->
            </div>
        </div>
    </div>

    <!-- Approve Confirmation Modal -->
    <div id="approveModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <div class="text-center mb-4">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-check-circle text-green-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Approve Post</h3>
                    <p class="text-gray-600" id="approveModalText">Are you sure you want to approve this post? It will be published immediately.</p>
                </div>
                <div class="flex gap-3">
                    <button onclick="closeApproveModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="confirmApproveBtn" class="flex-1 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">Confirm Approve</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Reject Modal with Reason -->
    <div id="rejectModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full modal-content">
            <div class="p-6">
                <div class="text-center mb-4">
                    <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-times-circle text-red-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Reject Post</h3>
                    <p class="text-gray-600">Please provide a reason for rejection</p>
                </div>
                <textarea id="rejectReason" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 mb-4" placeholder="Enter reason for rejection..."></textarea>
                <div class="flex gap-3">
                    <button onclick="closeRejectModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                    <button id="confirmRejectBtn" class="flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">Confirm Reject</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]">
        <div class="flex items-center gap-3">
            <i id="toastIcon" class="fas fa-check-circle text-green-500 text-xl"></i>
            <div>
                <p id="toastTitle" class="font-medium text-gray-800">Success</p>
                <p id="toastMessage" class="text-sm text-gray-600">Action completed successfully</p>
            </div>
            <button onclick="hideToast()" class="ml-auto text-gray-400 hover:text-gray-600">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>

    <!-- Include chatbot -->
    <%- include('../partials/chatbot') %>
    <!-- Include footer -->
    <%- include('../partials/footer') %>

    <script>
        // Store posts data from backend
        const postsData = <%- JSON.stringify(posts || []) %>;
        let currentPostId = null;
        let selectedPosts = new Set();

        // ========== MODAL FUNCTIONS ==========
        
        // View Modal
        function openViewModal(postId) {
            currentPostId = postId;
            const post = postsData.find(p => p.id == postId);
            
            if (post) {
                const modalContent = document.getElementById('viewModalContent');
                modalContent.innerHTML = `
                    <div class="mb-4">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br ${post.is_official ? 'from-blue-600 to-amber-600' : 'from-gray-400 to-gray-500'} flex items-center justify-center text-white font-bold text-xl">
                                ${post.user_avatar}
                            </div>
                            <div>
                                <p class="font-semibold text-gray-800">${post.author_name}</p>
                                <p class="text-sm text-gray-500">${post.author_email || 'Resident'} • Posted ${post.time_ago}</p>
                            </div>
                            <span class="ml-auto urgency-${post.urgency} px-3 py-1 rounded-full text-xs font-medium">
                                ${post.urgency === 'emergency' ? '🚨 ' : ''}${post.urgency.charAt(0).toUpperCase() + post.urgency.slice(1)} Urgency
                            </span>
                        </div>
                        <h4 class="text-xl font-bold text-gray-800 mb-2">${post.title || 'Untitled Post'}</h4>
                        <p class="text-gray-700 leading-relaxed mb-4 whitespace-pre-wrap">
                            ${post.content || 'No content available'}
                        </p>
                        <div class="bg-gray-50 rounded-lg p-4 mb-4">
                            <p class="text-sm font-medium text-gray-700 mb-2">Additional Information:</p>
                            <ul class="text-sm text-gray-600 space-y-1">
                                <li><i class="fas fa-map-pin text-amber-600 w-5"></i> Barangay: ${post.barangay || 'Not specified'}</li>
                                <li><i class="fas fa-clock text-amber-600 w-5"></i> Posted: ${new Date(post.created_at).toLocaleString()}</li>
                                <li><i class="fas fa-thumbs-up text-amber-600 w-5"></i> Likes: ${post.likes || 0}</li>
                                <li><i class="fas fa-comment text-amber-600 w-5"></i> Comments: ${post.comments_count || 0}</li>
                                ${post.reports_count > 0 ? `<li><i class="fas fa-flag text-red-600 w-5"></i> Reports: ${post.reports_count}</li>` : ''}
                                ${post.is_official ? `<li><i class="fas fa-check-circle text-green-600 w-5"></i> Official Post</li>` : ''}
                            </ul>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
                        <button onclick="closeViewModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Close</button>
                        <button onclick="openApproveModal('${post.id}')" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">Approve Post</button>
                        <button onclick="openRejectModal('${post.id}')" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">Reject Post</button>
                    </div>
                `;
            }
            
            document.getElementById('viewModal').classList.remove('hidden');
        }
        
        function closeViewModal() {
            document.getElementById('viewModal').classList.add('hidden');
        }
        
        // Approve Modal
        function openApproveModal(postId) {
            currentPostId = postId;
            document.getElementById('approveModal').classList.remove('hidden');
        }
        
        function closeApproveModal() {
            document.getElementById('approveModal').classList.add('hidden');
        }
        
        // Reject Modal
        function openRejectModal(postId) {
            currentPostId = postId;
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            document.getElementById('rejectReason').value = '';
        }

        // ========== BULK ACTIONS ==========
        
        // Select All functionality
        document.getElementById('selectAll')?.addEventListener('change', function(e) {
            const checkboxes = document.querySelectorAll('.post-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
                if (e.target.checked) {
                    selectedPosts.add(cb.value);
                } else {
                    selectedPosts.delete(cb.value);
                }
            });
            updateBulkActionsBar();
        });

        // Individual checkbox selection
        document.querySelectorAll('.post-checkbox').forEach(cb => {
            cb.addEventListener('change', function(e) {
                if (e.target.checked) {
                    selectedPosts.add(e.target.value);
                } else {
                    selectedPosts.delete(e.target.value);
                }
                updateBulkActionsBar();
                
                // Update select all checkbox
                const allCheckboxes = document.querySelectorAll('.post-checkbox');
                const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
                if (document.getElementById('selectAll')) {
                    document.getElementById('selectAll').checked = allChecked;
                }
            });
        });

        // Clear selection
        document.getElementById('clearSelection')?.addEventListener('click', function() {
            document.querySelectorAll('.post-checkbox').forEach(cb => {
                cb.checked = false;
            });
            selectedPosts.clear();
            if (document.getElementById('selectAll')) {
                document.getElementById('selectAll').checked = false;
            }
            updateBulkActionsBar();
        });

        function updateBulkActionsBar() {
            const bar = document.getElementById('bulkActionsBar');
            const countSpan = document.getElementById('selectedCount');
            const count = selectedPosts.size;
            
            if (bar && countSpan) {
                if (count > 0) {
                    countSpan.textContent = count;
                    bar.classList.remove('hidden');
                } else {
                    bar.classList.add('hidden');
                }
            }
        }

        // ========== FILTERS ==========
        
        // Apply filters button
        document.getElementById('applyFilters')?.addEventListener('click', function() {
            const status = document.getElementById('statusFilter').value;
            const urgency = document.getElementById('urgencyFilter').value;
            const type = document.getElementById('typeFilter').value;
            const barangay = document.getElementById('barangayFilter').value;
            const sort = document.getElementById('sortFilter').value;
            const search = document.getElementById('searchInput').value;
            
            let url = '/moderator/posts?';
            const params = [];
            if (status !== 'all') params.push(`status=${encodeURIComponent(status)}`);
            if (urgency !== 'all') params.push(`urgency=${encodeURIComponent(urgency)}`);
            if (type !== 'all') params.push(`type=${encodeURIComponent(type)}`);
            if (barangay !== 'all') params.push(`barangay=${encodeURIComponent(barangay)}`);
            if (sort !== 'latest') params.push(`sort=${encodeURIComponent(sort)}`);
            if (search) params.push(`search=${encodeURIComponent(search)}`);
            
            window.location.href = url + params.join('&');
        });

        // ========== BULK ACTION BUTTONS ==========
        
        document.getElementById('bulkApprove')?.addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            
            const postIds = Array.from(selectedPosts);
            Promise.all(postIds.map(postId => 
                fetch(`/moderator/posts/${postId}/approve`, { method: 'POST' })
            )).then(() => {
                showToast('success', 'Bulk Approve', `${selectedPosts.size} posts approved successfully`);
                setTimeout(() => location.reload(), 1500);
            }).catch(() => {
                showToast('error', 'Error', 'Failed to approve posts');
            });
        });

        document.getElementById('bulkReject')?.addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            
            const reason = prompt('Enter reason for rejection:');
            const postIds = Array.from(selectedPosts);
            Promise.all(postIds.map(postId => 
                fetch(`/moderator/posts/${postId}/reject`, { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reason: reason })
                })
            )).then(() => {
                showToast('error', 'Bulk Reject', `${selectedPosts.size} posts rejected`);
                setTimeout(() => location.reload(), 1500);
            }).catch(() => {
                showToast('error', 'Error', 'Failed to reject posts');
            });
        });

        document.getElementById('bulkArchive')?.addEventListener('click', function() {
            if (selectedPosts.size === 0) return;
            // Archive functionality - can be implemented similar to reject
            showToast('info', 'Bulk Archive', `${selectedPosts.size} posts archived`);
        });

        // ========== CONFIRMATION BUTTONS ==========
        
        document.getElementById('confirmApproveBtn')?.addEventListener('click', function() {
            fetch(`/moderator/posts/${currentPostId}/approve`, { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('success', 'Post Approved', `Post ${currentPostId} has been approved`);
                        closeApproveModal();
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('error', 'Error', data.message || 'Failed to approve post');
                    }
                })
                .catch(() => {
                    showToast('error', 'Error', 'Failed to approve post');
                });
        });

        document.getElementById('confirmRejectBtn')?.addEventListener('click', function() {
            const reason = document.getElementById('rejectReason').value;
            fetch(`/moderator/posts/${currentPostId}/reject`, { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: reason })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('error', 'Post Rejected', `Post ${currentPostId} rejected${reason ? ': ' + reason : ''}`);
                        closeRejectModal();
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('error', 'Error', data.message || 'Failed to reject post');
                    }
                })
                .catch(() => {
                    showToast('error', 'Error', 'Failed to reject post');
                });
        });

        // ========== TOAST NOTIFICATION ==========
        
        function showToast(type, title, message) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastMessage = document.getElementById('toastMessage');
            
            if (!toast) return;
            
            // Set colors based on type
            if (type === 'success') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-green-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-check-circle text-green-500 text-xl';
            } else if (type === 'error') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-red-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-times-circle text-red-500 text-xl';
            } else if (type === 'info') {
                toast.className = 'toast hidden bg-white rounded-lg shadow-lg border-l-4 border-blue-500 p-4 min-w-[300px]';
                icon.className = 'fas fa-info-circle text-blue-500 text-xl';
            }
            
            toastTitle.textContent = title;
            toastMessage.textContent = message;
            
            toast.classList.remove('hidden');
            
            // Auto hide after 3 seconds
            setTimeout(hideToast, 3000);
        }
        
        function hideToast() {
            const toast = document.getElementById('toast');
            if (toast) toast.classList.add('hidden');
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList && event.target.classList.contains('modal-overlay')) {
                closeViewModal();
                closeApproveModal();
                closeRejectModal();
            }
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeViewModal();
                closeApproveModal();
                closeRejectModal();
            }
        });
    </script>
</body>
</html>