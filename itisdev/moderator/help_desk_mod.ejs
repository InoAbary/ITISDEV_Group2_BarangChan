    <!-- JavaScript for Help Desk Functionality -->
    <script>
        // Update current time
        function updateTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('en-US', { 
                hour: '2-digit', 
                minute: '2-digit',
                second: '2-digit',
                hour12: true 
            });
            document.getElementById('currentTime').textContent = timeString;
        }
        setInterval(updateTime, 1000);
        updateTime();

        // Ticket selection
        function selectTicket(ticketId) {
            // Remove highlight from all tickets
            document.querySelectorAll('.ticket-card').forEach(card => {
                card.classList.remove('bg-blue-100');
                card.classList.add('hover:bg-blue-50');
            });
            
            // Highlight selected ticket
            const selectedCard = event.currentTarget;
            selectedCard.classList.add('bg-blue-100');
            selectedCard.classList.remove('hover:bg-blue-50');
            
            // Update chat header based on selected ticket
            updateChatHeader(ticketId);
        }

        // Update chat header with ticket info
        function updateChatHeader(ticketId) {
            // This would normally fetch from server
            console.log('Selected ticket:', ticketId);
        }

        // Message sending
        document.getElementById('sendMessage')?.addEventListener('click', function() {
            sendMessage();
        });

        document.getElementById('messageInput')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            
            if (message) {
                // Add user message to chat
                const chatMessages = document.getElementById('chatMessages');
                const messageDiv = document.createElement('div');
                messageDiv.className = 'flex justify-start mb-4';
                messageDiv.innerHTML = `
                    <div class="message-bubble-moderator p-3 text-sm text-gray-700">
                        <p class="font-semibold text-xs text-purple-700 mb-1">You (Moderator)</p>
                        <p>${message.replace(/\n/g, '<br>')}</p>
                        <p class="text-xs text-gray-500 mt-1">${new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</p>
                    </div>
                `;
                chatMessages.appendChild(messageDiv);
                
                // Clear input
                input.value = '';
                
                // Scroll to bottom
                chatMessages.scrollTop = chatMessages.scrollHeight;
                
                // Show typing indicator (simulate user response)
                document.getElementById('typingIndicator').classList.remove('hidden');
                chatMessages.scrollTop = chatMessages.scrollHeight;
                
                // Hide typing indicator after delay
                setTimeout(() => {
                    document.getElementById('typingIndicator').classList.add('hidden');
                }, 2000);
            }
        }

        // Quick responses
        function insertQuickResponse(text) {
            document.getElementById('messageInput').value = text;
            document.getElementById('messageInput').focus();
        }

        // Canned responses
        document.getElementById('cannedResponses')?.addEventListener('change', function(e) {
            const value = e.target.value;
            let response = '';
            
            switch(value) {
                case 'greeting':
                    response = 'Good day! Thank you for contacting BarangChan Help Desk. How may I assist you today?';
                    break;
                case 'clearance':
                    response = 'For Barangay Clearance, you need to:\n1. Fill out the form (available in Government Forms section)\n2. Submit valid ID and proof of residency\n3. Pay PHP 50.00 fee\n4. Wait 1-2 working days for processing';
                    break;
                case 'business':
                    response = 'Business Permit requirements:\n• DTI Registration\n• Barangay Clearance\n• Community Tax Certificate\n• Proof of Business Address\n• Fire Safety Inspection Certificate';
                    break;
                case 'indigency':
                    response = 'Certificate of Indigency is free. Just visit the Barangay Hall with a valid ID and barangay certification.';
                    break;
                case 'tracking':
                    response = 'You can track your request status by logging into your account and visiting the "My Requests" section.';
                    break;
                case 'closing':
                    response = 'Is there anything else I can help you with? If not, I\'ll mark this ticket as resolved. Thank you!';
                    break;
                default:
                    return;
            }
            
            document.getElementById('messageInput').value = response;
        });

        // Search functionality
        document.getElementById('searchTickets')?.addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const tickets = document.querySelectorAll('.ticket-card');
            
            tickets.forEach(ticket => {
                const text = ticket.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    ticket.style.display = 'block';
                } else {
                    ticket.style.display = 'none';
                }
            });
        });

        // Filter functionality
        function filterTickets() {
            const statusFilter = document.getElementById('statusFilter').value;
            const priorityFilter = document.getElementById('priorityFilter').value;
            
            // This would filter tickets based on selected criteria
            console.log('Filtering by:', { status: statusFilter, priority: priorityFilter });
        }

        document.getElementById('statusFilter')?.addEventListener('change', filterTickets);
        document.getElementById('priorityFilter')?.addEventListener('change', filterTickets);
    </script>
</body>
</html>