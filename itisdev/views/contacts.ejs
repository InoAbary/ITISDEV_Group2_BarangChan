    <!-- JavaScript for Contacts Page -->
    <script>
        // Language switching functionality
        document.querySelectorAll('.lang-option').forEach(option => {
            option.addEventListener('click', function() {
                const lang = this.dataset.lang;
                const url = new URL(window.location.href);
                url.searchParams.set('lang', lang);
                window.location.href = url.toString();
            });
        });
        
        // Favorite button functionality
        document.querySelectorAll('.favorite-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const contactId = this.dataset.contactId;
                const isFavorited = this.classList.contains('favorite-active');
                
                try {
                    const response = await fetch(`/api/contacts/${contactId}/favorite`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        if (data.action === 'added') {
                            this.classList.add('favorite-active');
                            // Show success message
                            showToast('<%= language === "tl" ? "Idinagdag sa mga paborito" : "Added to favorites" %>', 'success');
                        } else {
                            this.classList.remove('favorite-active');
                            showToast('<%= language === "tl" ? "Tinanggal sa mga paborito" : "Removed from favorites" %>', 'info');
                        }
                    }
                } catch (error) {
                    console.error('Error toggling favorite:', error);
                    showToast('<%= language === "tl" ? "May error. Pakisubukang muli." : "An error occurred. Please try again." %>', 'error');
                }
            });
        });
        
        // Toast notification function
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white z-50 ${
                type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : 'bg-blue-500'
            }`;
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
        
        // Track contact clicks for analytics
        document.querySelectorAll('a[href^="tel:"]').forEach(link => {
            link.addEventListener('click', function(e) {
                const phoneNumber = this.getAttribute('href').replace('tel:', '');
                console.log('Calling:', phoneNumber);
                
                // Send tracking to server
                fetch('/api/contacts/track-click', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        phone_number: phoneNumber,
                        contact_name: this.closest('.contact-card')?.querySelector('h3')?.textContent || 'Unknown'
                    })
                }).catch(err => console.error('Tracking error:', err));
            });
        });
        
        // Search functionality
        const searchInput = document.querySelector('#searchContacts');
        if (searchInput) {
            let searchTimeout;
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                const query = this.value.trim();
                
                if (query.length >= 2) {
                    searchTimeout = setTimeout(async () => {
                        try {
                            const response = await fetch(`/api/contacts/search?q=${encodeURIComponent(query)}&lang=<%= language %>`);
                            const data = await response.json();
                            
                            if (data.success && data.contacts.length > 0) {
                                displaySearchResults(data.contacts);
                            }
                        } catch (error) {
                            console.error('Search error:', error);
                        }
                    }, 500);
                }
            });
        }
        
        // Display search results
        function displaySearchResults(contacts) {
            const resultsContainer = document.getElementById('searchResults');
            if (!resultsContainer) return;
            
            resultsContainer.innerHTML = contacts.map(contact => `
                <div class="p-4 border-b border-gray-200 hover:bg-gray-50 cursor-pointer" onclick="window.location.href='/contacts/${contact.contact_id}'">
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                            <i class="fas fa-phone text-blue-600"></i>
                        </div>
                        <div>
                            <p class="font-semibold">${contact.name}</p>
                            <p class="text-sm text-gray-600">${contact.title || ''}</p>
                            <p class="text-xs text-blue-600 mt-1">${contact.phone_landline || contact.phone_mobile || ''}</p>
                        </div>
                    </div>
                </div>
            `).join('');
            
            resultsContainer.classList.remove('hidden');
        }
        
        // Quick actions for chatbot (Baliuag specific)
        document.addEventListener('DOMContentLoaded', function() {
            const quickActionsContainer = document.getElementById('quickActionsContainer');
            if (quickActionsContainer) {
                const lang = '<%= language %>';
                if (lang === 'tl') {
                    quickActionsContainer.innerHTML = `
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Ano ang mga emergency numbers sa Baliuag?">
                            🚨 Emergency numbers
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Paano ko makontak ang Kapitan ng Barangay San Antonio?">
                            📞 Barangay Captain
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Saan matatagpuan ang Barangay Health Center sa San Antonio?">
                            🏥 Health Center
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Ano ang dapat kong gawin kapag may sunog sa Baliuag?">
                            🔥 Fire emergency
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Saan ang evacuation center sa Barangay San Antonio?">
                            🏫 Evacuation center
                        </button>
                    `;
                } else {
                    quickActionsContainer.innerHTML = `
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="What are the emergency numbers in Baliuag?">
                            🚨 Emergency numbers
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How do I contact the Barangay Captain of San Antonio?">
                            📞 Barangay Captain
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Where is the Barangay Health Center in San Antonio?">
                            🏥 Health Center
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="What should I do in case of fire in Baliuag?">
                            🔥 Fire emergency
                        </button>
                        <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Where is the evacuation center in Barangay San Antonio?">
                            🏫 Evacuation center
                        </button>
                    `;
                }
            }
        });
    </script>
</body>
</html>