<!DOCTYPE html>
<html lang="<%= language %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> · BarangChan</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        
        .contact-card {
            transition: all 0.2s ease;
        }
        .contact-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        .emergency-card {
            animation: softPulse 2s infinite;
        }
        @keyframes softPulse {
            0% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.3); }
            70% { box-shadow: 0 0 0 10px rgba(220, 38, 38, 0); }
            100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
        }
        
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }
        
        .category-header {
            background: linear-gradient(135deg, #1e3a8a, #b45309);
        }
        
        .quick-dial {
            transition: all 0.2s ease;
        }
        .quick-dial:hover {
            transform: scale(1.05);
        }
        
        .baliuag-badge {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
        }
        
        .favorite-btn {
            transition: all 0.2s ease;
        }
        .favorite-btn:hover {
            transform: scale(1.1);
        }
        .favorite-active {
            color: #f59e0b;
        }
        
        /* Language toggle */
        .lang-toggle {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(8px);
            border-radius: 9999px;
            padding: 0.25rem;
        }
        .lang-option {
            padding: 0.5rem 1rem;
            border-radius: 9999px;
            transition: all 0.2s;
            cursor: pointer;
        }
        .lang-option.active {
            background: white;
            color: #1e3a8a;
            font-weight: bold;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/contacts', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Baliuag Header with Language Toggle -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between flex-wrap gap-4">
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <i class="fas fa-map-marker-alt text-amber-300"></i>
                            <span class="text-amber-200 text-sm font-semibold">
                                <%= language === 'tl' ? 'Bayan ng Baliuag, Bulacan' : 'Municipality of Baliuag, Bulacan' %>
                            </span>
                        </div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-phone-alt"></i> 
                            <%= title %>
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm">
                            <i class="fas fa-address-book mr-1"></i> 
                            <%= language === 'tl' ? 
                                'Mahahalagang numero at impormasyon para sa Barangay ' + (barangayInfo?.barangay_name || 'San Antonio') : 
                                'Important numbers and information for Barangay ' + (barangayInfo?.barangay_name || 'San Antonio') %>
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <!-- Language Toggle -->
                        <div class="lang-toggle flex">
                            <div class="lang-option <%= language === 'en' ? 'active' : '' %>" data-lang="en">
                                EN
                            </div>
                            <div class="lang-option <%= language === 'tl' ? 'active' : '' %>" data-lang="tl">
                                FIL
                            </div>
                        </div>
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-clock mr-2"></i><%= language === 'tl' ? '24/7 Emergency Hotlines' : '24/7 Emergency Hotlines' %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Emergency Banner -->
        <div class="mb-6 bg-red-600 rounded-xl shadow-lg overflow-hidden emergency-card">
            <div class="px-6 py-4 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div class="flex items-center gap-4">
                    <div class="bg-white/20 p-3 rounded-full">
                        <i class="fas fa-exclamation-triangle text-2xl"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold">
                            <%= language === 'tl' ? '🚨 PARA SA EMERGENCY, TUMAWAG SA:' : '🚨 FOR EMERGENCIES, CALL:' %>
                        </h2>
                        <p class="text-red-100">
                            <%= language === 'tl' ? 'Tumawag agad kung may emergency' : 'Call immediately for emergencies' %>
                        </p>
                    </div>
                </div>
                <div class="mt-3 md:mt-0 flex gap-2">
                    <% emergencyHotlines.slice(0, 3).forEach(hotline => { %>
                        <a href="tel:<%= hotline.number %>" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition quick-dial">
                            <%= hotline.number %>
                        </a>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Quick Actions - Emergency Numbers -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <% emergencyHotlines.forEach(hotline => { %>
                <a href="tel:<%= hotline.number %>" class="bg-<%= hotline.color %>-50 hover:bg-<%= hotline.color %>-100 p-4 rounded-xl text-center transition border border-<%= hotline.color %>-200">
                    <i class="fas <%= hotline.icon %> text-<%= hotline.color %>-600 text-2xl mb-2"></i>
                    <p class="font-bold text-<%= hotline.color %>-700"><%= hotline.name %></p>
                    <p class="text-xs text-<%= hotline.color %>-600"><%= hotline.number %></p>
                </a>
            <% }) %>
        </div>

        <!-- Filipino Pattern Divider -->
        <div class="filipino-divider my-8"></div>

        <!-- Main Contacts Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- LEFT COLUMN - Emergency & Barangay Services -->
            <div class="lg:col-span-7 space-y-6">
                
                <!-- Barangay Hall Section -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="category-header px-6 py-4">
                        <h2 class="text-xl font-bold flex items-center gap-2">
                            <i class="fas fa-landmark"></i>
                            <%= language === 'tl' ? 'Bulwagang Barangay' : 'Barangay Hall' %>
                        </h2>
                        <p class="text-blue-100 text-sm mt-1">
                            <%= language === 'tl' ? 'Barangay ' + (barangayInfo?.barangay_name || 'San Antonio') : 'Barangay ' + (barangayInfo?.barangay_name || 'San Antonio') %>
                            , <%= barangayInfo?.city || 'Baliuag' %>, <%= barangayInfo?.province || 'Bulacan' %>
                        </p>
                    </div>
                    
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <% 
                                const barangayContacts = categories.find(c => c.category_id === 1)?.contacts || [];
                                barangayContacts.forEach(contact => { 
                            %>
                                <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200 relative">
                                    <button class="favorite-btn absolute top-2 right-2 text-gray-400 hover:text-amber-500 <%= contact.is_favorited ? 'favorite-active' : '' %>" 
                                            data-contact-id="<%= contact.contact_id %>">
                                        <i class="fas fa-star"></i>
                                    </button>
                                    <div class="flex items-start gap-3">
                                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xl">
                                            <i class="fas fa-user-tie"></i>
                                        </div>
                                        <div class="flex-1">
                                            <h3 class="font-bold text-gray-800"><%= contact.name %></h3>
                                            <p class="text-sm text-gray-600"><%= contact.title %></p>
                                            <div class="mt-2 space-y-1">
                                                <% if (contact.phone_landline) { %>
                                                    <p class="text-sm flex items-center gap-2">
                                                        <i class="fas fa-phone text-amber-600 w-4"></i>
                                                        <a href="tel:<%= contact.phone_landline.replace(/[^0-9]/g, '') %>" 
                                                           class="text-blue-600 hover:text-blue-700"><%= contact.phone_landline %></a>
                                                    </p>
                                                <% } %>
                                                <% if (contact.phone_mobile) { %>
                                                    <p class="text-sm flex items-center gap-2">
                                                        <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                        <a href="tel:<%= contact.phone_mobile %>" 
                                                           class="text-blue-600 hover:text-blue-700"><%= contact.phone_mobile %></a>
                                                    </p>
                                                <% } %>
                                                <% if (contact.email) { %>
                                                    <p class="text-sm flex items-center gap-2">
                                                        <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                        <a href="mailto:<%= contact.email %>" 
                                                           class="text-blue-600 hover:text-blue-700"><%= contact.email %></a>
                                                    </p>
                                                <% } %>
                                                <p class="text-xs text-gray-500 mt-1">
                                                    <%= language === 'tl' ? (contact.office_hours_tagalog || contact.office_hours) : contact.office_hours %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <!-- Emergency Services Section -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-red-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-exclamation-circle"></i>
                            <%= language === 'tl' ? 'Pang-emergency na Serbisyo' : 'Emergency Services' %>
                        </h2>
                    </div>
                    
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <% 
                                const emergencyContacts = categories.find(c => c.category_id === 2)?.contacts || [];
                                emergencyContacts.forEach(contact => { 
                            %>
                                <div class="contact-card bg-red-50 rounded-xl p-4 border border-red-200 relative">
                                    <button class="favorite-btn absolute top-2 right-2 text-gray-400 hover:text-amber-500 <%= contact.is_favorited ? 'favorite-active' : '' %>" 
                                            data-contact-id="<%= contact.contact_id %>">
                                        <i class="fas fa-star"></i>
                                    </button>
                                    <div class="flex items-start gap-3">
                                        <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center text-red-600 text-xl">
                                            <i class="fas fa-shield-alt"></i>
                                        </div>
                                        <div>
                                            <h3 class="font-bold text-gray-800"><%= contact.name %></h3>
                                            <p class="text-sm text-gray-600"><%= contact.title %></p>
                                            <div class="mt-2 space-y-1">
                                                <% if (contact.phone_landline) { %>
                                                    <p class="text-sm flex items-center gap-2">
                                                        <i class="fas fa-phone text-amber-600 w-4"></i>
                                                        <a href="tel:<%= contact.phone_landline.replace(/[^0-9]/g, '') %>" 
                                                           class="text-blue-600 hover:text-blue-700"><%= contact.phone_landline %></a>
                                                    </p>
                                                <% } %>
                                                <% if (contact.phone_mobile) { %>
                                                    <p class="text-lg font-bold text-red-600"><%= contact.phone_mobile %></p>
                                                <% } %>
                                                <% if (contact.email) { %>
                                                    <p class="text-sm flex items-center gap-2">
                                                        <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                        <a href="mailto:<%= contact.email %>" 
                                                           class="text-blue-600 hover:text-blue-700"><%= contact.email %></a>
                                                    </p>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN - Health, Utilities, Municipal Services -->
            <div class="lg:col-span-5 space-y-6">
                
                <!-- Health Services -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-green-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-hospital"></i>
                            <%= language === 'tl' ? 'Serbisyong Pangkalusugan' : 'Health Services' %>
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <% 
                            const healthContacts = categories.find(c => c.category_id === 3)?.contacts || [];
                            healthContacts.forEach(contact => { 
                        %>
                            <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200 relative">
                                <button class="favorite-btn absolute top-2 right-2 text-gray-400 hover:text-amber-500 <%= contact.is_favorited ? 'favorite-active' : '' %>" 
                                        data-contact-id="<%= contact.contact_id %>">
                                    <i class="fas fa-star"></i>
                                </button>
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xl">
                                        <i class="fas fa-clinic-medical"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="font-bold text-gray-800"><%= contact.name %></h3>
                                        <p class="text-sm text-gray-600"><%= contact.title %></p>
                                        <div class="mt-2 space-y-1">
                                            <% if (contact.phone_landline) { %>
                                                <p class="text-sm flex items-center gap-2">
                                                    <i class="fas fa-phone text-amber-600 w-4"></i>
                                                    <a href="tel:<%= contact.phone_landline.replace(/[^0-9]/g, '') %>" 
                                                       class="text-blue-600 hover:text-blue-700"><%= contact.phone_landline %></a>
                                                </p>
                                            <% } %>
                                            <% if (contact.phone_mobile) { %>
                                                <p class="text-sm flex items-center gap-2">
                                                    <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                    <a href="tel:<%= contact.phone_mobile %>" 
                                                       class="text-blue-600 hover:text-blue-700"><%= contact.phone_mobile %></a>
                                                </p>
                                            <% } %>
                                            <p class="text-xs text-gray-500 mt-1">
                                                <%= language === 'tl' ? (contact.office_hours_tagalog || contact.office_hours) : contact.office_hours %>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Utilities & Public Services -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-blue-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-tools"></i>
                            <%= language === 'tl' ? 'Mga Utility at Pampublikong Serbisyo' : 'Utilities & Public Services' %>
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-3">
                        <% 
                            const utilityContacts = categories.find(c => c.category_id === 4)?.contacts || [];
                            utilityContacts.forEach(contact => { 
                        %>
                            <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center text-yellow-600">
                                        <i class="fas fa-bolt"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium"><%= contact.name %></p>
                                        <p class="text-xs text-gray-500"><%= contact.title %></p>
                                    </div>
                                </div>
                                <a href="tel:<%= contact.phone_landline || contact.phone_mobile %>" 
                                   class="text-blue-600 font-bold">
                                    <%= contact.phone_landline || contact.phone_mobile %>
                                </a>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Social Welfare -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-amber-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-hand-holding-heart"></i>
                            <%= language === 'tl' ? 'Pangkapakanang Panlipunan' : 'Social Welfare' %>
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <% 
                            const welfareContacts = categories.find(c => c.category_id === 5)?.contacts || [];
                            welfareContacts.forEach(contact => { 
                        %>
                            <div class="contact-card bg-amber-50 rounded-xl p-4 border border-amber-200 relative">
                                <button class="favorite-btn absolute top-2 right-2 text-gray-400 hover:text-amber-500 <%= contact.is_favorited ? 'favorite-active' : '' %>" 
                                        data-contact-id="<%= contact.contact_id %>">
                                    <i class="fas fa-star"></i>
                                </button>
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 text-xl">
                                        <i class="fas fa-hands-helping"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800"><%= contact.name %></h3>
                                        <p class="text-sm text-gray-600"><%= contact.title %></p>
                                        <div class="mt-2">
                                            <% if (contact.phone_landline) { %>
                                                <p class="text-sm flex items-center gap-2">
                                                    <i class="fas fa-phone text-amber-600 w-4"></i>
                                                    <a href="tel:<%= contact.phone_landline.replace(/[^0-9]/g, '') %>" 
                                                       class="text-blue-600 hover:text-blue-700"><%= contact.phone_landline %></a>
                                                </p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Municipal Office -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-purple-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-city"></i>
                            <%= language === 'tl' ? 'Opisina ng Munisipyo ng Baliuag' : 'Baliuag Municipal Office' %>
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <% 
                            const municipalContacts = categories.find(c => c.category_id === 6)?.contacts || [];
                            municipalContacts.forEach(contact => { 
                        %>
                            <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200 relative">
                                <button class="favorite-btn absolute top-2 right-2 text-gray-400 hover:text-amber-500 <%= contact.is_favorited ? 'favorite-active' : '' %>" 
                                        data-contact-id="<%= contact.contact_id %>">
                                    <i class="fas fa-star"></i>
                                </button>
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center text-purple-600 text-xl">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800"><%= contact.name %></h3>
                                        <p class="text-sm text-gray-600"><%= contact.title %></p>
                                        <div class="mt-2 space-y-1">
                                            <% if (contact.phone_landline) { %>
                                                <p class="text-sm flex items-center gap-2">
                                                    <i class="fas fa-phone text-amber-600 w-4"></i>
                                                    <a href="tel:<%= contact.phone_landline.replace(/[^0-9]/g, '') %>" 
                                                       class="text-blue-600 hover:text-blue-700"><%= contact.phone_landline %></a>
                                                </p>
                                            <% } %>
                                            <% if (contact.email) { %>
                                                <p class="text-sm flex items-center gap-2">
                                                    <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                    <a href="mailto:<%= contact.email %>" 
                                                       class="text-blue-600 hover:text-blue-700"><%= contact.email %></a>
                                                </p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Important Addresses Section (Baliuag) -->
        <div class="mt-8 bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <div class="bg-gradient-to-r from-blue-800 to-amber-700 px-6 py-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-map-marked-alt"></i>
                    <%= language === 'tl' ? 'Mahahalagang Lokasyon sa Baliuag' : 'Important Locations in Baliuag' %>
                </h2>
            </div>
            
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <!-- Barangay Hall -->
                    <div class="flex items-start gap-3 p-3 hover:bg-gray-50 rounded-lg">
                        <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center text-amber-600">
                            <i class="fas fa-landmark"></i>
                        </div>
                        <div>
                            <p class="font-semibold"><%= language === 'tl' ? 'Bulwagang Barangay' : 'Barangay Hall' %></p>
                            <p class="text-sm text-gray-600"><%= barangayInfo?.hall_address || 'Purok 3, Barangay San Antonio, Baliuag, Bulacan' %></p>
                            <p class="text-xs text-gray-500"><%= language === 'tl' ? 'Oras: ' : 'Hours: ' %><%= language === 'tl' ? (barangayInfo?.office_hours_tagalog || barangayInfo?.office_hours) : barangayInfo?.office_hours %></p>
                        </div>
                    </div>

                    <!-- Health Center -->
                    <div class="flex items-start gap-3 p-3 hover:bg-gray-50 rounded-lg">
                        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center text-green-600">
                            <i class="fas fa-clinic-medical"></i>
                        </div>
                        <div>
                            <p class="font-semibold"><%= language === 'tl' ? 'Barangay Health Center' : 'Barangay Health Center' %></p>
