<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Emergency & Community Contacts</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        /* Contact card hover effects */
        .contact-card {
            transition: all 0.2s ease;
        }
        .contact-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        /* Emergency card pulse animation */
        .emergency-card {
            animation: softPulse 2s infinite;
        }
        @keyframes softPulse {
            0% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.3); }
            70% { box-shadow: 0 0 0 10px rgba(220, 38, 38, 0); }
            100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
        }

        /* Filipino pattern */
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }

        /* Category headers */
        .category-header {
            background: linear-gradient(135deg, #1e3a8a, #b45309);
            color: white;
        }

        /* Quick dial buttons */
        .quick-dial {
            transition: all 0.2s ease;
        }
        .quick-dial:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/contacts', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-phone-alt"></i> 
                            Emergency & Community Contacts
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm">
                            <i class="fas fa-address-book mr-1"></i> 
                            Mahahalagang numero at impormasyon para sa barangay (Important numbers and information for the barangay)
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-clock mr-2"></i>24/7 Emergency Hotlines
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Emergency Banner -->
        <div class="mb-6 bg-red-600 rounded-xl shadow-lg overflow-hidden emergency-card">
            <div class="px-6 py-4 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div class="flex items-center gap-4">
                    <div class="bg-white/20 p-3 rounded-full">
                        <i class="fas fa-exclamation-triangle text-2xl"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold">🚨 FOR EMERGENCIES, CALL:</h2>
                        <p class="text-red-100">Tumawag agad kung may emergency (Call immediately for emergencies)</p>
                    </div>
                </div>
                <div class="mt-3 md:mt-0 flex gap-2">
                    <a href="tel:911" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition quick-dial">
                        911
                    </a>
                    <a href="tel:161" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition quick-dial">
                        161
                    </a>
                    <a href="tel:117" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition quick-dial">
                        117
                    </a>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <a href="tel:911" class="bg-red-50 hover:bg-red-100 p-4 rounded-xl text-center transition border border-red-200">
                <i class="fas fa-phone-alt text-red-600 text-2xl mb-2"></i>
                <p class="font-bold text-red-700">911</p>
                <p class="text-xs text-red-600">Emergency</p>
            </a>
            <a href="tel:136" class="bg-blue-50 hover:bg-blue-100 p-4 rounded-xl text-center transition border border-blue-200">
                <i class="fas fa-shield-alt text-blue-600 text-2xl mb-2"></i>
                <p class="font-bold text-blue-700">136</p>
                <p class="text-xs text-blue-600">PNP</p>
            </a>
            <a href="tel:160" class="bg-orange-50 hover:bg-orange-100 p-4 rounded-xl text-center transition border border-orange-200">
                <i class="fas fa-fire-extinguisher text-orange-600 text-2xl mb-2"></i>
                <p class="font-bold text-orange-700">160</p>
                <p class="text-xs text-orange-600">BFP</p>
            </a>
            <a href="tel:143" class="bg-green-50 hover:bg-green-100 p-4 rounded-xl text-center transition border border-green-200">
                <i class="fas fa-ambulance text-green-600 text-2xl mb-2"></i>
                <p class="font-bold text-green-700">143</p>
                <p class="text-xs text-green-600">Red Cross</p>
            </a>
        </div>

        <!-- Filipino Pattern Divider -->
        <div class="filipino-divider my-8"></div>

        <!-- Main Contacts Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- LEFT COLUMN - Emergency Services -->
            <div class="lg:col-span-7 space-y-6">
                
                <!-- Barangay Hall Section -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="category-header px-6 py-4">
                        <h2 class="text-xl font-bold flex items-center gap-2">
                            <i class="fas fa-landmark"></i>
                            Barangay Hall
                        </h2>
                        <p class="text-blue-100 text-sm mt-1">Barangay <%= user.barangay || 'San Antonio' %>, <%= user.city || 'Quezon City' %></p>
                    </div>
                    
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <!-- Contact 1 - Barangay Captain -->
                            <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xl">
                                        <i class="fas fa-user-tie"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="font-bold text-gray-800">Barangay Captain</h3>
                                        <p class="text-sm text-gray-600">Hon. Maria Reyes</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234567" class="text-blue-600 hover:text-blue-700">(02) 8123-4567</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                <a href="tel:+639171234567" class="text-blue-600 hover:text-blue-700">0917 123 4567</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:captain@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">captain@barangay.gov.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact 2 - Barangay Secretary -->
                            <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xl">
                                        <i class="fas fa-file-signature"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">Barangay Secretary</h3>
                                        <p class="text-sm text-gray-600">Maria Santos</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234568" class="text-blue-600 hover:text-blue-700">(02) 8123-4568</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:secretary@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">secretary@barangay.gov.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact 3 - Barangay Treasurer -->
                            <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 text-xl">
                                        <i class="fas fa-coins"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">Barangay Treasurer</h3>
                                        <p class="text-sm text-gray-600">Jose Torres</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234569" class="text-blue-600 hover:text-blue-700">(02) 8123-4569</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:treasurer@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">treasurer@barangay.gov.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact 4 - Barangay Hall General -->
                            <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center text-purple-600 text-xl">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">Barangay Hall</h3>
                                        <p class="text-sm text-gray-600">Main Office</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234560" class="text-blue-600 hover:text-blue-700">(02) 8123-4560</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:barangay@example.gov.ph" class="text-blue-600 hover:text-blue-700">barangay@example.gov.ph</a>
                                            </p>
                                            <p class="text-xs text-gray-500 mt-1">8:00 AM - 5:00 PM (Mon-Fri)</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Emergency Services Section -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-red-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-exclamation-circle"></i>
                            Emergency Services
                        </h2>
                    </div>
                    
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <!-- PNP/Police -->
                            <div class="contact-card bg-red-50 rounded-xl p-4 border border-red-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center text-red-600 text-xl">
                                        <i class="fas fa-shield-alt"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">PNP / Police</h3>
                                        <p class="text-sm text-gray-600">Barangay Police Station</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-lg font-bold text-red-600">911</p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234570" class="text-blue-600 hover:text-blue-700">(02) 8123-4570</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                <a href="tel:+639171234570" class="text-blue-600 hover:text-blue-700">0917 123 4570</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:police@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">police@barangay.gov.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- BFP / Fire -->
                            <div class="contact-card bg-orange-50 rounded-xl p-4 border border-orange-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center text-orange-600 text-xl">
                                        <i class="fas fa-fire-extinguisher"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">BFP / Fire Dept</h3>
                                        <p class="text-sm text-gray-600">Bureau of Fire Protection</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-lg font-bold text-orange-600">160</p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234571" class="text-blue-600 hover:text-blue-700">(02) 8123-4571</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                <a href="tel:+639171234571" class="text-blue-600 hover:text-blue-700">0917 123 4571</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:fire@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">fire@barangay.gov.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Red Cross / Ambulance -->
                            <div class="contact-card bg-green-50 rounded-xl p-4 border border-green-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xl">
                                        <i class="fas fa-ambulance"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">Red Cross / Ambulance</h3>
                                        <p class="text-sm text-gray-600">Emergency Medical Services</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-lg font-bold text-green-600">143</p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234572" class="text-blue-600 hover:text-blue-700">(02) 8123-4572</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                <a href="tel:+639171234572" class="text-blue-600 hover:text-blue-700">0917 123 4572</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:ems@redcross.org.ph" class="text-blue-600 hover:text-blue-700">ems@redcross.org.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- CDRRMO / Disaster -->
                            <div class="contact-card bg-blue-50 rounded-xl p-4 border border-blue-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xl">
                                        <i class="fas fa-cloud-rain"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">CDRRMO</h3>
                                        <p class="text-sm text-gray-600">Disaster Risk Reduction</p>
                                        <div class="mt-2 space-y-1">
                                            <p class="text-lg font-bold text-blue-600">161</p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-phone text-amber-600 w-4"></i>
                                                <a href="tel:+63281234573" class="text-blue-600 hover:text-blue-700">(02) 8123-4573</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                                <a href="tel:+639171234573" class="text-blue-600 hover:text-blue-700">0917 123 4573</a>
                                            </p>
                                            <p class="text-sm flex items-center gap-2">
                                                <i class="fas fa-envelope text-amber-600 w-4"></i>
                                                <a href="mailto:drrmo@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">drrmo@barangay.gov.ph</a>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN - Community Services -->
            <div class="lg:col-span-5 space-y-6">
                
                <!-- Health Services -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-green-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-hospital"></i>
                            Health Services
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <!-- Barangay Health Center -->
                        <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200">
                            <div class="flex items-start gap-3">
                                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xl">
                                    <i class="fas fa-clinic-medical"></i>
                                </div>
                                <div class="flex-1">
                                    <h3 class="font-bold text-gray-800">Barangay Health Center</h3>
                                    <p class="text-sm text-gray-600">Dr. Maria Santos - Municipal Health Officer</p>
                                    <div class="mt-2 space-y-1">
                                        <p class="text-sm flex items-center gap-2">
                                            <i class="fas fa-phone text-amber-600 w-4"></i>
                                            <a href="tel:+63281234574" class="text-blue-600 hover:text-blue-700">(02) 8123-4574</a>
                                        </p>
                                        <p class="text-sm flex items-center gap-2">
                                            <i class="fas fa-mobile-alt text-amber-600 w-4"></i>
                                            <a href="tel:+639171234574" class="text-blue-600 hover:text-blue-700">0917 123 4574</a>
                                        </p>
                                        <p class="text-sm flex items-center gap-2">
                                            <i class="fas fa-envelope text-amber-600 w-4"></i>
                                            <a href="mailto:health@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">health@barangay.gov.ph</a>
                                        </p>
                                        <p class="text-xs text-gray-500 mt-1">8:00 AM - 5:00 PM (Mon-Fri) • 8:00 AM - 12:00 PM (Sat)</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Rural Health Unit -->
                        <div class="contact-card bg-gray-50 rounded-xl p-4 border border-gray-200">
                            <div class="flex items-start gap-3">
                                <div class="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center text-teal-600 text-xl">
                                    <i class="fas fa-syringe"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-800">Rural Health Unit (RHU)</h3>
                                    <p class="text-sm text-gray-600">Vaccination & Maternal Care</p>
                                    <div class="mt-2 space-y-1">
                                        <p class="text-sm flex items-center gap-2">
                                            <i class="fas fa-phone text-amber-600 w-4"></i>
                                            <a href="tel:+63281234575" class="text-blue-600 hover:text-blue-700">(02) 8123-4575</a>
                                        </p>
                                        <p class="text-sm flex items-center gap-2">
                                            <i class="fas fa-envelope text-amber-600 w-4"></i>
                                            <a href="mailto:rhu@barangay.gov.ph" class="text-blue-600 hover:text-blue-700">rhu@barangay.gov.ph</a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Utilities & Public Services -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-blue-600 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center gap-2">
                            <i class="fas fa-tools"></i>
                            Utilities & Public Services
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-3">
                        <!-- MERALCO -->
                        <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center text-yellow-600">
                                    <i class="fas fa-bolt"></i>
                                </div>
                                <div>
                                    <p class="font-medium">MERALCO</p>
                                    <p class="text-xs text-gray-500">Power Outages / Billing</p>
                                </div>
                            </div>
