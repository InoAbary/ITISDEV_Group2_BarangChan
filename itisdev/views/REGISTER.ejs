<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Register as Kabayan</title>
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome 6 for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Phone number input styling -->
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        /* Remove spinner from number input */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none; 
            margin: 0; 
        }
        input[type=number] {
            -moz-appearance: textfield;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased text-gray-700 min-h-screen flex items-center justify-center p-4">

    <div class="max-w-6xl w-full bg-white rounded-3xl shadow-2xl overflow-hidden flex flex-col lg:flex-row">
        <!-- ========== LEFT COLUMN: REGISTRATION FORM ========== -->
        <div class="w-full lg:w-3/5 px-8 py-8 md:px-12 lg:px-10 overflow-y-auto max-h-[90vh]">
            
            <!-- logo and back to login -->
            <div class="mb-6 flex items-center justify-between">
                <div class="flex items-center space-x-2 text-2xl font-bold text-blue-900">
                    <i class="fas fa-hand-holding-heart text-3xl text-amber-600"></i>
                    <span class="tracking-tight">Barang<span class="text-amber-600">Chan</span></span>
                </div>
                <a href="/login" class="flex items-center gap-2 text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-full transition duration-200">
                    <i class="fas fa-arrow-left"></i> Back to Login
                </a>
            </div>

            <!-- heading -->
            <div class="mb-6">
                <h2 class="text-3xl font-bold text-gray-800">Join BarangChan, <span class="text-amber-700">kabayan!</span> 🇵🇭</h2>
                <p class="text-gray-500 mt-1 text-sm">Create your account to connect with your barangay community.</p>
            </div>

            <!-- display error message if any -->
            <% if (locals.error) { %>
                <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3">
                    <i class="fas fa-exclamation-circle mt-0.5"></i>
                    <p class="text-sm"><%= error %></p>
                </div>
            <% } %>

            <!-- REGISTRATION FORM -->
            <form action="/register" method="POST" class="space-y-5">
                <!-- Full Name Row: First Name, Last Name -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="first_name" class="block text-sm font-semibold text-gray-700 mb-1">
                            <i class="fas fa-user text-amber-600 mr-1"></i>First Name <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="first_name" name="first_name" required
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                               placeholder="Juan">
                    </div>
                    <div>
                        <label for="last_name" class="block text-sm font-semibold text-gray-700 mb-1">
                            <i class="fas fa-user text-amber-600 mr-1"></i>Last Name <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="last_name" name="last_name" required
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                               placeholder="Dela Cruz">
                    </div>
                </div>

                <!-- Middle Name (Optional) and Age -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="middle_name" class="block text-sm font-semibold text-gray-700 mb-1">
                            <i class="fas fa-user-circle text-amber-600 mr-1"></i>Middle Name <span class="text-gray-400 text-xs">(optional)</span>
                        </label>
                        <input type="text" id="middle_name" name="middle_name"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                               placeholder="Mendoza">
                    </div>
                    <div>
                        <label for="age" class="block text-sm font-semibold text-gray-700 mb-1">
                            <i class="fas fa-calendar-alt text-amber-600 mr-1"></i>Age <span class="text-red-500">*</span>
                        </label>
                        <input type="number" id="age" name="age" required min="1" max="120"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                               placeholder="25">
                    </div>
                </div>

                <!-- Email and Phone -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">
                            <i class="far fa-envelope text-amber-600 mr-1"></i>Email Address <span class="text-red-500">*</span>
                        </label>
                        <input type="email" id="email" name="email" required
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                               placeholder="juandelacruz@email.com">
                    </div>
                    <div>
                        <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">
                            <i class="fas fa-phone-alt text-amber-600 mr-1"></i>Mobile Number <span class="text-red-500">*</span>
                        </label>
                        <div class="flex">
                            <span class="inline-flex items-center px-4 bg-gray-100 border border-r-0 border-gray-300 rounded-l-xl text-gray-600 text-sm">
                                +63
                            </span>
                            <input type="tel" id="phone" name="phone" required maxlength="10"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-r-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="9123456789" pattern="[0-9]{10}" title="Please enter 10 digits">
                        </div>
                        <p class="text-xs text-gray-400 mt-1">Enter 10 digits after +63 (e.g., 9123456789)</p>
                    </div>
                </div>

                <!-- Address Section: City, Barangay, Street, Zipcode -->
                <div class="space-y-4">
                    <h3 class="text-sm font-semibold text-gray-700 border-b pb-1"><i class="fas fa-map-marker-alt text-amber-600 mr-1"></i>Your Address</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="city" class="block text-sm font-semibold text-gray-700 mb-1">
                                City / Municipality <span class="text-red-500">*</span>
                            </label>
                            <input type="text" id="city" name="city" required
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="Quezon City">
                        </div>
                        <div>
                            <label for="barangay" class="block text-sm font-semibold text-gray-700 mb-1">
                                Barangay <span class="text-red-500">*</span>
                            </label>
                            <input type="text" id="barangay" name="barangay" required
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="Barangay San Antonio">
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-1">
                            <label for="street" class="block text-sm font-semibold text-gray-700 mb-1">
                                Street / Unit / House No. <span class="text-red-500">*</span>
                            </label>
                            <input type="text" id="street" name="street" required
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="123 Mabini St.">
                        </div>
                        <div>
                            <label for="zipcode" class="block text-sm font-semibold text-gray-700 mb-1">
                                <i class="fas fa-mail-bulk text-amber-600 mr-1"></i>Zip Code <span class="text-red-500">*</span>
                            </label>
                            <input type="text" id="zipcode" name="zipcode" required maxlength="4"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="1100" pattern="[0-9]{4}" title="Please enter 4-digit zip code">
                        </div>
                    </div>
                </div>

                <!-- Password Section -->
                <div class="space-y-4">
                    <h3 class="text-sm font-semibold text-gray-700 border-b pb-1"><i class="fas fa-lock text-amber-600 mr-1"></i>Security</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="password" class="block text-sm font-semibold text-gray-700 mb-1">
                                <i class="fas fa-key text-amber-600 mr-1"></i>Password <span class="text-red-500">*</span>
                            </label>
                            <input type="password" id="password" name="password" required minlength="6"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="••••••••">
                        </div>
                        <div>
                            <label for="confirm_password" class="block text-sm font-semibold text-gray-700 mb-1">
                                <i class="fas fa-check-circle text-amber-600 mr-1"></i>Confirm Password <span class="text-red-500">*</span>
                            </label>
                            <input type="password" id="confirm_password" name="confirm_password" required minlength="6"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                                   placeholder="••••••••">
                        </div>
                    </div>
                </div>

                <!-- Terms and Conditions -->
                <div class="flex items-start gap-3 mt-4">
                    <input type="checkbox" id="terms" name="terms" required class="mt-1 h-4 w-4 text-amber-600 border-gray-300 rounded focus:ring-amber-500">
                    <label for="terms" class="text-sm text-gray-600">
                        I agree to the <a href="#" class="text-amber-700 hover:underline font-medium">Terms and Conditions</a> and <a href="#" class="text-amber-700 hover:underline font-medium">Privacy Policy</a> of BarangChan. <span class="text-red-500">*</span>
                    </label>
                </div>

                <!-- Register Button -->
                <button type="submit"
                        class="w-full bg-gradient-to-r from-amber-700 to-amber-600 hover:from-amber-800 hover:to-amber-700 text-white font-bold py-3 px-4 rounded-xl shadow-lg transform transition hover:scale-[1.02] duration-200 flex items-center justify-center gap-2 text-lg mt-6">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>

                <!-- Login link for mobile -->
                <p class="text-center text-sm text-gray-500 mt-4 lg:hidden">
                    Already have an account?
                    <a href="/login" class="font-semibold text-blue-800 hover:text-blue-900">Log in here</a>
                </p>
            </form>

            <!-- Empty spacer - removed the bottom ads completely -->
            <div class="mt-4"></div>
        </div>

        <!-- ========== RIGHT COLUMN: BANNER / SUMMARY (simplified) ========== -->
        <div class="hidden lg:block lg:w-2/5 relative bg-gradient-to-br from-blue-900 via-blue-800 to-amber-800 text-white overflow-hidden">
            <!-- background pattern: subtle PH flag colors -->
            <div class="absolute inset-0 opacity-20 mix-blend-overlay">
                <div class="absolute top-0 left-0 w-64 h-64 bg-amber-500 rounded-full filter blur-3xl"></div>
                <div class="absolute bottom-0 right-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl"></div>
            </div>
            
            <!-- content - removed stats/numbers, kept only essential messaging -->
            <div class="relative z-10 flex flex-col items-start justify-center h-full px-10 py-20">
                <div class="flex items-center gap-3 mb-6 bg-white/20 backdrop-blur-sm px-5 py-2 rounded-full text-sm font-medium border border-white/30">
                    <i class="fas fa-bullhorn text-amber-300"></i>
                    <span>Barangay Digital Transformation</span>
                </div>
                
                <h1 class="text-4xl font-extrabold leading-tight mb-4 drop-shadow-lg">
                    Mag-sign up na, <span class="text-amber-300">kabayan!</span>
                </h1>
                
                <p class="text-lg mb-6 text-white/90">Join your community today and enjoy:</p>
                
                <ul class="space-y-3 text-base mb-8 text-white/90">
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Report concerns</strong> – quickly & easily</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Track requests</strong> – know your document status</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Community updates</strong> – stay informed</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Free for all residents</strong> – walang bayad!</span>
                    </li>
                </ul>
                
                <!-- Completely removed the stats section with numbers -->
                
                <div class="mt-6 flex items-center gap-2 bg-blue-950/40 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
                    <i class="fas fa-hashtag text-sm"></i>
                    <span class="text-xs font-mono">BarangChan: a local help board channel</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Simple JS for phone number formatting and password match validation -->
    <script>
        (function() {
            // Phone number: auto +63 prefix handling
            const phoneInput = document.getElementById('phone');
            if (phoneInput) {
                phoneInput.addEventListener('input', function(e) {
                    // Remove non-digits
                    this.value = this.value.replace(/\D/g, '');
                    // Limit to 10 digits
                    if (this.value.length > 10) {
                        this.value = this.value.slice(0, 10);
                    }
                });
            }

            // Zip code validation (4 digits only)
            const zipInput = document.getElementById('zipcode');
            if (zipInput) {
                zipInput.addEventListener('input', function(e) {
                    this.value = this.value.replace(/\D/g, '');
                    if (this.value.length > 4) {
                        this.value = this.value.slice(0, 4);
                    }
                });
            }

            // Password match validation on client side
            const password = document.getElementById('password');
            const confirm = document.getElementById('confirm_password');
            const form = document.querySelector('form');
            
            if (form) {
                form.addEventListener('submit', function(e) {
                    if (password.value !== confirm.value) {
                        e.preventDefault();
                        alert('Passwords do not match!');
                    }
                });
            }
        })();
    </script>
</body>
</html>