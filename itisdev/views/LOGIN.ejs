<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Log in to your account</title>
    <!-- Tailwind CSS via CDN + a touch of subtle custom background -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome 6 (free) for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* subtle philippine-inspired pattern overlay (optional) */
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased text-gray-700 min-h-screen flex items-center justify-center p-4">

    <!-- main card: left (form) / right (hero banner) -->
    <div class="max-w-6xl w-full bg-white rounded-3xl shadow-2xl overflow-hidden flex flex-col lg:flex-row">

        <!-- ========== LEFT COLUMN: LOGIN FORM ========== -->
        <div class="w-full lg:w-1/2 px-8 py-12 md:px-12 lg:px-14 flex flex-col justify-between">
            
            <!-- logo inside form area (left top) for consistency, but also brand -->
            <div class="mb-8 flex items-center justify-between">
                <div class="flex items-center space-x-2 text-2xl font-bold text-blue-900">
                    <i class="fas fa-hand-holding-heart text-3xl text-amber-600"></i>
                    <span class="tracking-tight">Barang<span class="text-amber-600">Chan</span></span>
                </div>
                <div class="text-xs text-gray-400 bg-gray-100 px-3 py-1 rounded-full">v. 2026</div>
            </div>

            <!-- heading -->
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-gray-800">Welcome back, <span class="text-amber-700">kabayan</span> 👋</h2>
                <p class="text-gray-500 mt-2 text-sm">Log in to your BarangChan account – report, request, and stay updated.</p>
            </div>

            <!-- LOGIN FORM (ready for backend) -->
            <form action="/login" method="POST" class="space-y-6">
                <!-- email field -->
                <div>
                    <label for="email" class="block text-sm font-semibold text-gray-700 mb-1"><i class="far fa-envelope mr-1 text-amber-600"></i>Email address</label>
                    <input type="email" id="email" name="email" required
                           class="w-full px-5 py-3 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                           placeholder="delacruz@example.com">
                </div>

                <!-- password field + forgot row -->
                <div>
                    <div class="flex items-center justify-between mb-1">
                        <label for="password" class="block text-sm font-semibold text-gray-700"><i class="fas fa-lock mr-1 text-amber-600"></i>Password</label>
                        <a href="#" class="text-sm text-amber-700 hover:text-amber-900 font-medium transition duration-150">Forgot password?</a>
                    </div>
                    <input type="password" id="password" name="password" required
                           class="w-full px-5 py-3 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition duration-200 bg-gray-50/50"
                           placeholder="••••••••">
                </div>

                <!-- login button (big & friendly) -->
                <button type="submit"
                        class="w-full bg-gradient-to-r from-amber-700 to-amber-600 hover:from-amber-800 hover:to-amber-700 text-white font-bold py-3 px-4 rounded-xl shadow-lg transform transition hover:scale-[1.02] duration-200 flex items-center justify-center gap-2 text-lg">
                    <i class="fas fa-sign-in-alt"></i> Log in
                </button>

                <!-- optional register hint -->
                <p class="text-center text-sm text-gray-500 mt-4">
                    New to BarangChan?
                    <a href="/register" class="font-semibold text-blue-800 hover:text-blue-900 underline-offset-2 hover:underline">Create an account</a>
                </p>
            </form>

            <!-- demo / role switcher (non functional, but design hint) -->
            <div class="mt-8 flex items-center justify-center gap-3 text-xs text-gray-400 border-t pt-6 border-gray-200">
                <span class="flex items-center gap-1"><i class="fas text-blue-600"></i></span>
               
                <span class="flex items-center gap-1"><i class="fas text-green-700"></i></span>
           
                <span class="flex items-center gap-1"><i class="fas text-amber-700"></i></span>
            </div>
        </div>

        <!-- ========== RIGHT COLUMN: BANNER / SUMMARY (government feel) ========== -->
        <div class="hidden lg:block lg:w-1/2 relative bg-gradient-to-br from-blue-900 via-blue-800 to-amber-800 text-white overflow-hidden">
            <!-- background pattern: subtle PH flag colors + abstract shape -->
            <div class="absolute inset-0 opacity-20 mix-blend-overlay">
                <div class="absolute top-0 left-0 w-64 h-64 bg-amber-500 rounded-full filter blur-3xl"></div>
                <div class="absolute bottom-0 right-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl"></div>
            </div>
            
            <!-- actual content / summary about BarangChan -->
            <div class="relative z-10 flex flex-col items-start justify-center h-full px-12 py-20">
                <!-- stylized "seal" or simple icon -->
                <div class="flex items-center gap-3 mb-6 bg-white/20 backdrop-blur-sm px-5 py-2 rounded-full text-sm font-medium border border-white/30">
                    <i class="fas fa-bullhorn text-amber-300"></i>
                    <span>Barangay Digital Transformation</span>
                </div>
                
                <!-- big summary heading -->
                <h1 class="text-4xl font-extrabold leading-tight mb-4 drop-shadow-lg">
                    Tulong <span class="text-amber-300">barangay</span>,<br>sa isang pindot lang.
                </h1>
                
                <!-- bullet points: BarangChan core features -->
                <ul class="space-y-3 text-base mb-8 text-white/90">
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Status updates</strong> – real‑time concerns & queries</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Urgency tracker</strong> – moderators prioritize requests</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">Document progress</strong> – follow your form requests</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <i class="fas fa-check-circle text-amber-300 mt-1"></i>
                        <span><strong class="font-semibold">AI help desk & chatbot</strong> – 24/7 assistance</span>
                    </li>
                </ul>
                
                <!-- a small testimonial / statistics (placeholder) -->
                <div class="grid grid-cols-2 gap-4 w-full max-w-xs border-t border-white/20 pt-6">
                    <div>
                        <p class="text-3xl font-bold text-amber-300"></p>
                        <p class="text-xs uppercase tracking-wider opacity-80"></p>
                    </div>
                    <div>
                        <p class="text-3xl font-bold text-amber-300"></p>
                        <p class="text-xs uppercase tracking-wider opacity-80"></p>
                    </div>
                </div>
                
                <!-- small note: "a help board channel" -->
                <div class="mt-6 flex items-center gap-2 bg-blue-950/40 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
                    <i class="fas fa-hashtag text-sm"></i>
                    <span class="text-xs font-mono">BarangChan: a local help board channel</span>
                </div>
            </div>

            <!-- decorative bottom right "philippines" pattern -->
            <div class="absolute bottom-4 right-4 text-white/10 text-7xl">
                <i class="fas fa-sun"></i>
            </div>
        </div>

        <!-- for mobile, we can show a condensed summary (visible only on small screens) -->
        <div class="block lg:hidden bg-gradient-to-r from-blue-900 to-amber-800 text-white p-6">
            <div class="flex items-center gap-3 mb-2">
                <i class="fas fa-hand-holding-heart text-amber-300 text-3xl"></i>
                <span class="text-2xl font-bold">BarangChan</span>
            </div>
            <p class="text-sm text-white/80">Tulong barangay, sa isang pindot lang. Status updates, document tracking, and AI help desk for every kabayan.</p>
        </div>
    </div>

    <!-- optional backend integration note (hidden) 
         this form posts to /login, expects email & password. 
         csrf can be added later, flash messages placeholder.
    -->
</body>
</html>