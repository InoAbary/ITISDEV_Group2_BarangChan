<!-- moderator/complaints_mod.ejs - Complaint Management for Moderators with Modal (COMPLETELY FIXED) -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Manage Complaints</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Chart.js for analytics -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .status-in-progress { background-color: #e3f2fd; color: #1565c0; }
        .status-resolved { background-color: #e8f5e8; color: #2e7d32; }
        .status-cancelled { background-color: #ffebee; color: #c62828; }
        
        .priority-high { background-color: #ffebee; color: #c62828; }
        .priority-medium { background-color: #fff3e0; color: #ef6c00; }
        .priority-low { background-color: #e8f5e8; color: #2e7d32; }
        
        .stat-card {
            transition: all 0.2s ease;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        .table-row-hover:hover {
            background-color: #f9fafb;
        }
        
        .modal {
            transition: opacity 0.3s ease;
        }
        .modal.hidden {
            display: none;
        }
        
        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: slideIn 0.3s ease;
        }
        
        .complaint-card {
            transition: all 0.2s ease;
        }
        .complaint-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        .tab-active {
            border-bottom: 2px solid #f59e0b;
            color: #f59e0b;
        }
        
        .evidence-img {
            max-width: 100%;
            max-height: 200px;
            object-fit: cover;
            border-radius: 8px;
            cursor: pointer;
        }
        
        .evidence-img:hover {
            opacity: 0.9;
        }
        
        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.75);
            z-index: 1000;
        }
        
        .modal-container {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            max-width: 900px;
            max-height: 90vh;
            background: white;
            border-radius: 1rem;
            z-index: 1001;
            overflow-y: auto;
        }
        
        .modal-content {
            padding: 1.5rem;
        }
        
        .modal-header {
            position: sticky;
            top: 0;
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .modal-close {
            cursor: pointer;
            font-size: 1.5rem;
            color: #9ca3af;
            transition: color 0.2s;
        }
        
        .modal-close:hover {
            color: #ef4444;
        }
        
        .update-bubble {
            background: #fef3c7;
            border-left: 3px solid #f59e0b;
        }
        
        .update-moderator {
            background: #e0e7ff;
            border-left: 3px solid #4f46e5;
        }
        
        .update-resident {
            background: #f1f5f9;
            border-left: 3px solid #64748b;
        }
        
        /* Loading spinner animation */
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .animate-spin {
            animation: spin 1s linear infinite;
        }
        
        /* Line clamp utility */
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/moderator/complaints', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header -->
        <div class="bg-gradient-to-r from-red-800 to-red-700 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between flex-wrap gap-4">
                    <div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-gavel"></i> 
                            Complaint Management
                        </h1>
                        <p class="text-red-100 mt-1 text-sm md:text-base">
                            <i class="fas fa-map-marker-alt mr-1"></i> 
                            <%- user.barangay || 'Barangay San Antonio' %>, <%- user.city || 'Baliuag' %>
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-clock mr-2"></i>Last updated: <%= new Date().toLocaleDateString() %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Stats Overview -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-red-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">Total Complaints</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.totalComplaints || 0 %></p>
                    </div>
                    <div class="bg-red-100 p-2 rounded-lg">
                        <i class="fas fa-gavel text-red-600 text-lg"></i>
                    </div>
                </div>
            </div>
            
            <div class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-blue-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">In Progress</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.inProgress || 0 %></p>
                        <p class="text-xs text-blue-600 mt-1">Under investigation</p>
                    </div>
                    <div class="bg-blue-100 p-2 rounded-lg">
                        <i class="fas fa-spinner text-blue-600 text-lg"></i>
                    </div>
                </div>
            </div>
            
            <div class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-green-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">Resolved</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.resolved || 0 %></p>
                        <p class="text-xs text-green-600 mt-1">Closed cases</p>
                    </div>
                    <div class="bg-green-100 p-2 rounded-lg">
                        <i class="fas fa-check-circle text-green-600 text-lg"></i>
                    </div>
                </div>
            </div>
            
            <div class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-purple-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">This Month</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.thisMonth || 0 %></p>
                        <p class="text-xs text-purple-600 mt-1"><%= stats?.monthlyChange > 0 ? '+' + stats.monthlyChange : stats.monthlyChange === 0 ? 'Same as last month' : stats.monthlyChange + ' vs last month' %></p>
                    </div>
                    <div class="bg-purple-100 p-2 rounded-lg">
                        <i class="fas fa-calendar-alt text-purple-600 text-lg"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter and Search Bar -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-wrap gap-4 items-center justify-between">
                <div class="flex flex-wrap gap-2">
                    <button onclick="filterComplaints('all')" id="filter-all" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium bg-amber-600 text-white transition">
                        All Complaints
                    </button>
                    <button onclick="filterComplaints('in-progress')" id="filter-in-progress" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition">
                        In Progress
                    </button>
                    <button onclick="filterComplaints('resolved')" id="filter-resolved" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition">
                        Resolved
                    </button>
                    <button onclick="filterComplaints('cancelled')" id="filter-cancelled" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition">
                        Cancelled
                    </button>
                </div>
                <div class="flex gap-2">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-sm"></i>
                        <input type="text" id="searchInput" placeholder="Search by complainant, allegations..." 
                               class="pl-9 pr-4 py-2 border border-gray-300 rounded-lg w-64 focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                    </div>
                    <select id="sortBy" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400">
                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                        <option value="status">By Status</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Complaints List - Card View -->
        <div class="space-y-4" id="complaintsList">
            <% if (complaints && complaints.length > 0) { %>
                <% complaints.forEach(function(complaint) { %>
                    <div class="complaint-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden" 
                         data-complaint-id="<%= complaint.id %>"
                         data-status="<%= complaint.status.toLowerCase() %>"
                         data-date="<%= complaint.complaint_date %>">
                        
                        <!-- Header -->
                        <div class="p-5 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
                            <div class="flex flex-wrap items-start justify-between gap-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center">
                                        <i class="fas fa-user text-red-600 text-xl"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800 text-lg">
                                            <%= complaint.complainant_name %>
                                        </h3>
                                        <div class="flex flex-wrap items-center gap-2 mt-1">
                                            <span class="text-xs text-gray-500">
                                                <i class="fas fa-envelope mr-1"></i><%= complaint.email || 'No email provided' %>
                                            </span>
                                            <span class="text-xs text-gray-500">
                                                <i class="fas fa-phone mr-1"></i><%= complaint.phone || 'No phone provided' %>
                                            </span>
                                            <span class="text-xs text-gray-500">
                                                <i class="fas fa-map-marker-alt mr-1"></i><%= complaint.address || 'No address provided' %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="status-<%= complaint.status === 'Under Review' ? 'in-progress' : complaint.status.toLowerCase() %> px-3 py-1 rounded-full text-xs font-medium">
                                        <i class="fas <%= complaint.status === 'Under Review' ? 'fa-spinner fa-pulse' : (complaint.status === 'Resolved' ? 'fa-check-circle' : 'fa-times-circle') %> mr-1"></i>
                                        <%= complaint.status === 'Under Review' ? 'In Progress' : complaint.status %>
                                    </span>
                                    <span class="text-xs text-gray-400">
                                        <i class="far fa-calendar-alt mr-1"></i>
                                        <%= new Date(complaint.complaint_date).toLocaleDateString() %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Body - Preview -->
                        <div class="p-5">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
                                <div>
                                    <div class="flex items-center gap-2 mb-2">
                                        <i class="fas fa-exclamation-triangle text-red-500"></i>
                                        <h4 class="font-semibold text-gray-700">Allegations</h4>
                                    </div>
                                    <p class="text-gray-600 text-sm leading-relaxed bg-gray-50 p-3 rounded-lg line-clamp-3">
                                        <%= (complaint.allegations || 'No allegations provided').substring(0, 200) %><%= (complaint.allegations || '').length > 200 ? '...' : '' %>
                                    </p>
                                </div>
                                
                                <div>
                                    <div class="flex items-center gap-2 mb-2">
                                        <i class="fas fa-file-alt text-amber-600"></i>
                                        <h4 class="font-semibold text-gray-700">Narration / Details</h4>
                                    </div>
                                    <p class="text-gray-600 text-sm leading-relaxed bg-gray-50 p-3 rounded-lg line-clamp-3">
                                        <%= (complaint.narration || 'No narration provided').substring(0, 200) %><%= (complaint.narration || '').length > 200 ? '...' : '' %>
                                    </p>
                                </div>
                            </div>
                            
                            <!-- Evidence Files Preview -->
                            <% if (complaint.files && complaint.files.length > 0) { %>
                                <div class="mt-3">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-paperclip text-gray-500 text-sm"></i>
                                        <span class="text-xs text-gray-500"><%= complaint.files.length %> file(s) attached</span>
                                    </div>
                                </div>
                            <% } %>
                            
                            <!-- Recent Update Preview -->
                            <% if (complaint.updates && complaint.updates.length > 0) { %>
                                <div class="mt-3 pt-3 border-t border-gray-100">
                                    <div class="flex items-center gap-2 text-xs text-gray-500">
                                        <i class="fas fa-comment-dots text-amber-500"></i>
                                        <span>Latest update: <%= new Date(complaint.updates[complaint.updates.length - 1].created_at).toLocaleString() %></span>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                        
                        <!-- Actions Footer -->
                        <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex flex-wrap items-center justify-between gap-3">
                            <div class="flex items-center gap-2">
                                <select id="status-select-<%= complaint.id %>" class="text-sm border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-2 focus:ring-amber-400">
                                    <option value="Under Review" <%= complaint.status === 'Under Review' ? 'selected' : '' %>>In Progress</option>
                                    <option value="Resolved" <%= complaint.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                                    <option value="Cancelled" <%= complaint.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                                <button onclick="updateComplaintStatus(<%= complaint.id %>)" 
                                        class="px-3 py-1.5 bg-amber-600 text-white rounded-lg text-sm hover:bg-amber-700 transition">
                                    <i class="fas fa-save mr-1"></i> Update Status
                                </button>
                            </div>
                            <div class="flex items-center gap-2">
                                <button onclick="addComplaintUpdate(<%= complaint.id %>)" 
                                        class="px-3 py-1.5 border border-amber-600 text-amber-600 rounded-lg text-sm hover:bg-amber-50 transition">
                                    <i class="fas fa-plus mr-1"></i> Add Note
                                </button>
                                <button onclick="viewComplaintDetails(<%= complaint.id %>)" 
                                        class="px-3 py-1.5 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700 transition">
                                    <i class="fas fa-eye mr-1"></i> Full Details
                                </button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="bg-white rounded-xl shadow-md p-12 text-center">
                    <i class="fas fa-inbox text-5xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">No complaints found</p>
                    <p class="text-gray-400 text-sm mt-1">Complaints submitted by residents will appear here</p>
                </div>
            <% } %>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="mt-6 flex justify-center">
                <div class="flex items-center gap-2">
                    <button onclick="changePage(<%= currentPage - 1 %>)" <%= currentPage === 1 ? 'disabled' : '' %> 
                            class="px-3 py-1 border border-gray-300 rounded-lg text-sm <%= currentPage === 1 ? 'text-gray-400 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100' %>">
                        <i class="fas fa-chevron-left"></i> Previous
                    </button>
                    <% for (var i = 1; i <= totalPages; i++) { %>
                        <button onclick="changePage(<%= i %>)" 
                                class="px-3 py-1 rounded-lg text-sm <%= i === currentPage ? 'bg-amber-600 text-white' : 'border border-gray-300 text-gray-600 hover:bg-gray-100' %>">
                            <%= i %>
                        </button>
                    <% } %>
                    <button onclick="changePage(<%= currentPage + 1 %>)" <%= currentPage === totalPages ? 'disabled' : '' %>
                            class="px-3 py-1 border border-gray-300 rounded-lg text-sm <%= currentPage === totalPages ? 'text-gray-400 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100' %>">
                        Next <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        <% } %>
    </main>

    <!-- Full Complaint Details Modal -->
    <div id="complaintModal" class="modal hidden">
        <div class="modal-overlay" onclick="closeComplaintModal()"></div>
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-gavel text-red-600"></i>
                    Complaint Details
                </h3>
                <i class="fas fa-times modal-close" onclick="closeComplaintModal()"></i>
            </div>
            <div class="modal-content" id="complaintModalContent">
                <!-- Dynamic content will be loaded here -->
                <div class="text-center py-8">
                    <i class="fas fa-spinner fa-pulse text-3xl text-amber-600"></i>
                    <p class="mt-2 text-gray-500">Loading complaint details...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Note Modal -->
    <div id="noteModal" class="modal fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
            <div class="bg-gradient-to-r from-amber-600 to-amber-700 p-4 text-white rounded-t-2xl">
                <h3 class="text-lg font-bold">Add Case Update</h3>
            </div>
            <div class="p-6">
                <input type="hidden" id="noteComplaintId">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Update Note</label>
                    <textarea id="noteContent" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400" 
                              placeholder="Add notes about this case (e.g., investigation findings, resolution steps, etc.)"></textarea>
                </div>
                <div class="flex items-center justify-end gap-3">
                    <button onclick="closeNoteModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                        Cancel
                    </button>
                    <button onclick="submitComplaintUpdate()" class="px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700">
                        Add Update
                    </button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/chatbot') %>
    <%- include('../partials/footer') %>

    <script>
        let currentFilter = 'all';
        let currentComplaintData = null;
        let currentModalComplaintId = null;
        let currentNoteComplaintId = null;
        
        // Define all functions in global scope
        function filterComplaints(filter) {
            currentFilter = filter;
            const complaints = document.querySelectorAll('.complaint-card');
            
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-amber-600', 'text-white');
                btn.classList.add('text-gray-600', 'hover:bg-gray-100');
            });
            const activeBtn = document.getElementById(`filter-${filter === 'all' ? 'all' : filter === 'in-progress' ? 'in-progress' : filter}`);
            if (activeBtn) {
                activeBtn.classList.add('bg-amber-600', 'text-white');
                activeBtn.classList.remove('text-gray-600', 'hover:bg-gray-100');
            }
            
            complaints.forEach(complaint => {
                let show = true;
                if (filter === 'in-progress') {
                    show = complaint.dataset.status === 'under review';
                } else if (filter === 'resolved') {
                    show = complaint.dataset.status === 'resolved';
                } else if (filter === 'cancelled') {
                    show = complaint.dataset.status === 'cancelled';
                }
                complaint.style.display = show ? '' : 'none';
            });
        }
        
        function updateComplaintStatus(complaintId) {
            const select = document.getElementById(`status-select-${complaintId}`);
            const status = select.value;
            
            fetch(`/moderator/complaints/${complaintId}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('Status updated successfully', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(data.message || 'Error updating status', 'error');
                }
            })
            .catch(() => showToast('Error updating status', 'error'));
        }
        
        async function viewComplaintDetails(complaintId) {
            const modal = document.getElementById('complaintModal');
            const modalContent = document.getElementById('complaintModalContent');
            
            currentModalComplaintId = complaintId;
            
            modal.classList.remove('hidden');
            modalContent.innerHTML = `
                <div class="text-center py-8">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-amber-600"></div>
                    <p class="mt-2 text-gray-500">Loading complaint details...</p>
                </div>
            `;
            
            await loadComplaintDetailsIntoModal(complaintId);
        }
        
        async function loadComplaintDetailsIntoModal(complaintId) {
            const modalContent = document.getElementById('complaintModalContent');
            
            try {
                const response = await fetch(`/api/complaints/${complaintId}/details`);
                const data = await response.json();
                
                if (data.success) {
                    const complaint = data.complaint;
                    
                    // Format date
                    const complaintDate = new Date(complaint.complaint_date).toLocaleString();
                    const daysPending = complaint.days_pending || Math.floor((new Date() - new Date(complaint.complaint_date)) / (1000 * 60 * 60 * 24));
                    
                    // Build files HTML
                    let filesHtml = '';
                    if (complaint.files && complaint.files.length > 0) {
                        filesHtml = complaint.files.map(file => `
                            <a href="${file.file_path}" target="_blank" 
                               class="inline-flex items-center gap-2 px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm text-gray-600 transition">
                                <i class="fas ${file.mime_type && file.mime_type.includes('image') ? 'fa-image' : (file.mime_type && file.mime_type.includes('pdf') ? 'fa-file-pdf' : 'fa-file')}"></i>
                                ${escapeHtml(file.original_name || 'Evidence file')}
                            </a>
                        `).join('');
                    } else {
                        filesHtml = '<p class="text-gray-500 text-sm">No evidence files attached</p>';
                    }
                    
                    // Build updates HTML
                    let updatesHtml = '';
                    if (complaint.updates && complaint.updates.length > 0) {
                        updatesHtml = complaint.updates.map(update => `
                            <div class="p-3 rounded-lg text-sm ${update.user_role === 'moderator' || update.user_role === 'administrator' ? 'bg-amber-50 border-l-4 border-amber-500' : 'bg-gray-50 border-l-4 border-gray-400'}">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-2">
                                        <i class="fas ${update.user_role === 'moderator' || update.user_role === 'administrator' ? 'fa-user-shield' : 'fa-user'} text-${update.user_role === 'moderator' || update.user_role === 'administrator' ? 'amber' : 'gray'}-500"></i>
                                        <span class="font-medium text-gray-800">${escapeHtml(update.user_name || (update.user_role === 'moderator' ? 'Moderator' : 'Resident'))}</span>
                                        ${update.user_role === 'moderator' || update.user_role === 'administrator' ? '<span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Staff</span>' : ''}
                                    </div>
                                    <span class="text-xs text-gray-400">${new Date(update.created_at).toLocaleString()}</span>
                                </div>
                                <p class="text-gray-700 whitespace-pre-wrap">${escapeHtml(update.content)}</p>
                            </div>
                        `).join('');
                    } else {
                        updatesHtml = '<p class="text-gray-500 text-sm text-center py-4">No updates yet. Click "Add Note" to add the first update to this case.</p>';
                    }
                    
                    modalContent.innerHTML = `
                        <div class="space-y-5">
                            <!-- Complainant Info -->
                            <div class="bg-gradient-to-r from-red-50 to-amber-50 p-4 rounded-lg">
                                <h4 class="font-bold text-gray-800 mb-3 flex items-center gap-2">
                                    <i class="fas fa-user-circle text-red-600"></i>
                                    Complainant Information
                                </h4>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                                    <div><span class="font-medium text-gray-600">Name:</span> ${escapeHtml(complaint.complainant_name || 'Not provided')}</div>
                                    <div><span class="font-medium text-gray-600">Email:</span> ${escapeHtml(complaint.email || 'Not provided')}</div>
                                    <div><span class="font-medium text-gray-600">Phone:</span> ${escapeHtml(complaint.phone || 'Not provided')}</div>
                                    <div><span class="font-medium text-gray-600">Address:</span> ${escapeHtml(complaint.address || 'Not provided')}</div>
                                    <div><span class="font-medium text-gray-600">Date Filed:</span> ${complaintDate}</div>
                                    <div><span class="font-medium text-gray-600">Days Pending:</span> ${daysPending} day(s)</div>
                                    <div><span class="font-medium text-gray-600">Status:</span> 
                                        <span class="status-${complaint.status === 'Under Review' ? 'in-progress' : complaint.status.toLowerCase()} px-2 py-0.5 rounded-full text-xs">
                                            ${complaint.status === 'Under Review' ? 'In Progress' : complaint.status}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Allegations -->
                            <div>
                                <h4 class="font-bold text-gray-800 mb-2 flex items-center gap-2">
                                    <i class="fas fa-exclamation-triangle text-red-500"></i>
                                    Allegations
                                </h4>
                                <div class="bg-gray-50 p-4 rounded-lg text-gray-700 whitespace-pre-wrap">
                                    ${escapeHtml(complaint.allegations || 'No allegations provided')}
                                </div>
                            </div>
                            
                            <!-- Narration -->
                            <div>
                                <h4 class="font-bold text-gray-800 mb-2 flex items-center gap-2">
                                    <i class="fas fa-file-alt text-amber-600"></i>
                                    Narration / Details
                                </h4>
                                <div class="bg-gray-50 p-4 rounded-lg text-gray-700 whitespace-pre-wrap">
                                    ${escapeHtml(complaint.narration || 'No narration provided')}
                                </div>
                            </div>
                            
                            <!-- Evidence Files -->
                            <div>
                                <h4 class="font-bold text-gray-800 mb-2 flex items-center gap-2">
                                    <i class="fas fa-paperclip text-gray-500"></i>
                                    Evidence Files (${complaint.files ? complaint.files.length : 0})
                                </h4>
                                <div class="flex flex-wrap gap-2">
                                    ${filesHtml}
                                </div>
                            </div>
                            
                            <!-- Case Updates -->
                            <div>
                                <h4 class="font-bold text-gray-800 mb-2 flex items-center gap-2">
                                    <i class="fas fa-history text-gray-500"></i>
                                    Case Updates (${complaint.updates ? complaint.updates.length : 0})
                                </h4>
                                <div class="space-y-3 max-h-64 overflow-y-auto">
                                    ${updatesHtml}
                                </div>
                            </div>
                            
                            <!-- Resolution Notes -->
                            ${complaint.resolution_notes ? `
                            <div>
                                <h4 class="font-bold text-gray-800 mb-2 flex items-center gap-2">
                                    <i class="fas fa-check-circle text-green-600"></i>
                                    Resolution Notes
                                </h4>
                                <div class="bg-green-50 p-4 rounded-lg text-gray-700 whitespace-pre-wrap border-l-4 border-green-500">
                                    ${escapeHtml(complaint.resolution_notes)}
                                </div>
                            </div>
                            ` : ''}
                            
                            <!-- Quick Actions -->
                            <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
                                <select id="modal-status-select" class="text-sm border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400">
                                    <option value="Under Review" ${complaint.status === 'Under Review' ? 'selected' : ''}>In Progress</option>
                                    <option value="Resolved" ${complaint.status === 'Resolved' ? 'selected' : ''}>Resolved</option>
                                    <option value="Cancelled" ${complaint.status === 'Cancelled' ? 'selected' : ''}>Cancelled</option>
                                </select>
                                <button onclick="updateComplaintStatusFromModal()" 
                                        class="px-4 py-2 bg-amber-600 text-white rounded-lg text-sm hover:bg-amber-700 transition">
                                    <i class="fas fa-save mr-1"></i> Update Status
                                </button>
                                <button onclick="closeComplaintModal(); addComplaintUpdate(${complaint.id})" 
                                        class="px-4 py-2 border border-amber-600 text-amber-600 rounded-lg text-sm hover:bg-amber-50 transition">
                                    <i class="fas fa-plus mr-1"></i> Add Note
                                </button>
                            </div>
                        </div>
                    `;
                } else {
                    modalContent.innerHTML = `
                        <div class="text-center py-8 text-red-600">
                            <i class="fas fa-exclamation-circle text-3xl mb-2"></i>
                            <p>Error loading complaint details</p>
                            <p class="text-sm text-gray-500 mt-1">${data.message || 'Please try again'}</p>
                            <button onclick="closeComplaintModal()" class="mt-4 px-4 py-2 bg-gray-500 text-white rounded-lg">Close</button>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error fetching complaint details:', error);
                modalContent.innerHTML = `
                    <div class="text-center py-8 text-red-600">
                        <i class="fas fa-exclamation-triangle text-3xl mb-2"></i>
                        <p>Failed to load complaint details</p>
                        <p class="text-sm text-gray-500 mt-1">${error.message}</p>
                        <button onclick="closeComplaintModal()" class="mt-4 px-4 py-2 bg-gray-500 text-white rounded-lg">Close</button>
                    </div>
                `;
            }
        }
        
        function closeComplaintModal() {
            document.getElementById('complaintModal').classList.add('hidden');
            currentModalComplaintId = null;
        }
        
        function updateComplaintStatusFromModal() {
            if (!currentModalComplaintId) return;
            
            const select = document.getElementById('modal-status-select');
            const status = select.value;
            
            fetch(`/moderator/complaints/${currentModalComplaintId}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('Status updated successfully', 'success');
                    loadComplaintDetailsIntoModal(currentModalComplaintId);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Error updating status', 'error');
                }
            })
            .catch(() => showToast('Error updating status', 'error'));
        }
        
        function addComplaintUpdate(complaintId) {
            currentNoteComplaintId = complaintId;
            document.getElementById('noteComplaintId').value = complaintId;
            document.getElementById('noteContent').value = '';
            document.getElementById('noteModal').classList.remove('hidden');
        }
        
        function closeNoteModal() {
            document.getElementById('noteModal').classList.add('hidden');
            document.getElementById('noteContent').value = '';
        }
        
        function submitComplaintUpdate() {
            const complaintId = document.getElementById('noteComplaintId').value;
            const content = document.getElementById('noteContent').value;
            
            if (!content.trim()) {
                showToast('Please enter a note', 'error');
                return;
            }
            
            fetch(`/moderator/complaints/${complaintId}/note`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ content: content })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('Note added successfully', 'success');
                    closeNoteModal();
                    
                    if (currentModalComplaintId == complaintId) {
                        loadComplaintDetailsIntoModal(complaintId);
                    }
                    
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Error adding note', 'error');
                }
            })
            .catch((error) => {
                console.error('Error adding note:', error);
                showToast('Error adding note: ' + error.message, 'error');
            });
        }
        
        function changePage(page) {
            if (page < 1 || page > <%= totalPages %>) return;
            const url = new URL(window.location.href);
            url.searchParams.set('page', page);
            window.location.href = url.toString();
        }
        
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `toast px-6 py-3 rounded-lg shadow-lg text-white ${type === 'success' ? 'bg-green-500' : 'bg-red-500'}`;
            toast.innerHTML = `<div class="flex items-center gap-2"><i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i><span>${message}</span></div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
        
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // Search functionality
        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const complaints = document.querySelectorAll('.complaint-card');
            
            complaints.forEach(complaint => {
                const text = complaint.innerText.toLowerCase();
                complaint.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
        
        // Sort functionality
        document.getElementById('sortBy')?.addEventListener('change', function(e) {
            const sortValue = e.target.value;
            const container = document.getElementById('complaintsList');
            const complaints = Array.from(document.querySelectorAll('.complaint-card'));
            
            complaints.sort((a, b) => {
                if (sortValue === 'newest') {
                    return new Date(b.dataset.date) - new Date(a.dataset.date);
                } else if (sortValue === 'oldest') {
                    return new Date(a.dataset.date) - new Date(b.dataset.date);
                } else if (sortValue === 'status') {
                    const statusOrder = { 'under review': 1, 'resolved': 2, 'cancelled': 3 };
                    return (statusOrder[a.dataset.status] || 99) - (statusOrder[b.dataset.status] || 99);
                }
                return 0;
            });
            
            complaints.forEach(complaint => container.appendChild(complaint));
        });
    </script>
</body>
</html>