<!-- moderator/Dashboard_mod.ejs - Updated with all requested changes -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Moderator Dashboard</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Chart.js for analytics -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .status-pending { background-color: #fff3e0; color: #ef6c00; }
        .status-accepted { background-color: #e3f2fd; color: #1565c0; }
        .status-in-progress { background-color: #e3f2fd; color: #1565c0; }
        .status-completed { background-color: #e8f5e8; color: #2e7d32; }
        .status-cancelled { background-color: #ffebee; color: #c62828; }
        .status-resolved { background-color: #e8f5e8; color: #2e7d32; }
        .status-closed { background-color: #e3f2fd; color: #1565c0; }

        .urgency-low { background-color: #e6f7e6; color: #2e7d32; }
        .urgency-medium { background-color: #fff3e0; color: #ef6c00; }
        .urgency-high { background-color: #ffebee; color: #c62828; }
        .urgency-emergency { background-color: #fce4ec; color: #880e4f; animation: pulse 2s infinite; }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }

        .stat-card {
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .table-row-hover:hover {
            background-color: #f9fafb;
        }
        
        .chart-container {
            position: relative;
            height: 250px;
            width: 100%;
        }
        
        .modal {
            transition: opacity 0.3s ease;
        }
        .modal.hidden {
            display: none;
        }
        
        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: slideIn 0.3s ease;
        }
        
        .post-card {
            transition: all 0.2s ease;
        }
        .post-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        .official-badge {
            background: linear-gradient(135deg, #2563eb, #1e40af);
        }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        .tab-active {
            border-bottom: 2px solid #f59e0b;
            color: #f59e0b;
        }
        
        .clickable-stat {
            cursor: pointer;
            transition: transform 0.2s;
        }
        .clickable-stat:hover {
            transform: scale(1.02);
        }
        
        .metric-card {
            transition: all 0.2s;
        }
        .metric-card:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/moderator/dashboard', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Welcome Banner -->
        <div class="bg-gradient-to-r from-amber-800 to-amber-700 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-shield-alt"></i> 
                        Moderator Command Center
                    </h1>
                    <p class="text-amber-100 mt-1 text-sm md:text-base">
                        <i class="fas fa-map-marker-alt mr-1"></i> 
                        <%- user.barangay || 'Barangay San Antonio' %>, <%- user.city || 'Baliuag' %>
                    </p>
                </div>
                <div class="mt-3 md:mt-0 flex items-center gap-3">
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-clock mr-2"></i>Last login: <%= user.last_login ? new Date(user.last_login).toLocaleDateString() : 'Today' %>
                    </span>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Quick Stats Cards - Updated with clickable links -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <!-- Active Requests Card - Clickable -->
            <div onclick="window.location.href='/moderator/requests'" class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-blue-500 clickable-stat">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">Active Requests</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.activeRequests || 0 %></p>
                        <p class="text-xs text-blue-600 mt-1"><i class="fas fa-hourglass-half"></i> Click to manage</p>
                    </div>
                    <div class="bg-blue-100 p-2 rounded-lg">
                        <i class="fas fa-file-alt text-blue-600 text-lg"></i>
                    </div>
                </div>
            </div>
            
            <!-- Active Complaints Card - Clickable -->
            <div onclick="window.location.href='/moderator/complaints'" class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-red-500 clickable-stat">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">Active Complaints</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.activeComplaints || 0 %></p>
                        <p class="text-xs text-red-600 mt-1"><i class="fas fa-exclamation-triangle"></i> Click to review</p>
                    </div>
                    <div class="bg-red-100 p-2 rounded-lg">
                        <i class="fas fa-gavel text-red-600 text-lg"></i>
                    </div>
                </div>
            </div>
            
            <!-- Forum Topics Card -->
            <div class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-green-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">Forum Topics</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.forumTopics || 0 %></p>
                        <p class="text-xs text-green-600 mt-1"><i class="fas fa-users"></i> Community discussions</p>
                    </div>
                    <div class="bg-green-100 p-2 rounded-lg">
                        <i class="fas fa-comments text-green-600 text-lg"></i>
                    </div>
                </div>
            </div>
            
            <!-- Resolved This Week Card -->
            <div class="stat-card bg-white rounded-xl shadow-md p-4 border-l-4 border-purple-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-gray-500 mb-1">This Week</p>
                        <p class="text-2xl font-bold text-gray-800"><%= stats?.resolvedThisWeek || 0 %></p>
                        <p class="text-xs text-purple-600 mt-1"><i class="fas fa-check-circle"></i> Resolved items</p>
                    </div>
                    <div class="bg-purple-100 p-2 rounded-lg">
                        <i class="fas fa-check-double text-purple-600 text-lg"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs for Content Navigation -->
        <div class="mb-6 border-b border-gray-200">
            <nav class="flex flex-wrap gap-4">
                <button onclick="switchTab('forum')" id="tab-forum" class="tab-btn px-4 py-2 text-sm font-medium text-gray-600 hover:text-amber-600 transition border-b-2 border-transparent hover:border-amber-600 focus:outline-none tab-active">
                    <i class="fas fa-newspaper mr-2"></i>Community Posts
                </button>
                <button onclick="switchTab('requests')" id="tab-requests" class="tab-btn px-4 py-2 text-sm font-medium text-gray-600 hover:text-amber-600 transition border-b-2 border-transparent hover:border-amber-600 focus:outline-none">
                    <i class="fas fa-file-alt mr-2"></i>Document Requests
                </button>
                <button onclick="switchTab('complaints')" id="tab-complaints" class="tab-btn px-4 py-2 text-sm font-medium text-gray-600 hover:text-amber-600 transition border-b-2 border-transparent hover:border-amber-600 focus:outline-none">
                    <i class="fas fa-gavel mr-2"></i>Complaints
                </button>
                <button onclick="switchTab('analytics')" id="tab-analytics" class="tab-btn px-4 py-2 text-sm font-medium text-gray-600 hover:text-amber-600 transition border-b-2 border-transparent hover:border-amber-600 focus:outline-none">
                    <i class="fas fa-chart-line mr-2"></i>Analytics
                </button>
            </nav>
        </div>

        <!-- TAB 1: FORUM POSTS -->
        <div id="forum-tab" class="tab-content">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                
                <!-- Main Feed Column -->
                <div class="lg:col-span-8 space-y-5">
                    
                    <!-- Create Announcement Card (Moderator Only) -->
                    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                        <div class="p-4 border-b border-gray-100 bg-gray-50">
                            <h3 class="font-semibold text-gray-700 flex items-center gap-2">
                                <i class="fas fa-bullhorn text-amber-600"></i> 
                                Make Official Announcement
                            </h3>
                        </div>
                        <div class="p-4">
                            <form action="/moderator/posts/create" method="POST">
                                <input type="text" name="title" placeholder="Announcement title" 
                                    class="w-full px-4 py-2 mb-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                                <textarea name="content" rows="3" 
                                    class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400 focus:border-transparent"
                                    placeholder="Share an official announcement or update..." required></textarea>
                                
                                <div class="flex flex-wrap items-center justify-between mt-3 gap-2">
                                    <div class="flex items-center gap-2">
                                        <select name="type" class="text-sm border border-gray-300 rounded-lg px-3 py-2">
                                            <option value="announcement">📢 Official Announcement</option>
                                            <option value="update">📝 Update</option>
                                            <option value="emergency">🚨 Emergency Alert</option>
                                        </select>
                                        <select name="urgency" class="text-sm border border-gray-300 rounded-lg px-3 py-2">
                                            <option value="low">🟢 Low</option>
                                            <option value="medium">🟡 Medium</option>
                                            <option value="high">🟠 High</option>
                                            <option value="emergency">🔴 Emergency</option>
                                        </select>
                                    </div>
                                    <input type="hidden" name="is_official" value="true">
                                    <button type="submit" 
                                            class="bg-amber-600 hover:bg-amber-700 text-white px-5 py-2 rounded-lg transition">
                                        <i class="fas fa-paper-plane"></i> Post Announcement
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Filter Tabs -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-1 flex flex-wrap gap-1">
                        <button onclick="filterPosts('all')" class="filter-btn flex-1 px-4 py-2 text-sm font-medium rounded-lg bg-amber-600 text-white" data-filter="all">All Posts</button>
                        <button onclick="filterPosts('pending')" class="filter-btn flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition" data-filter="pending">Pending Review</button>
                        <button onclick="filterPosts('urgent')" class="filter-btn flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition" data-filter="urgent">Urgent</button>
                        <button onclick="filterPosts('official')" class="filter-btn flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition" data-filter="official">Official</button>
                    </div>
                   
                    <!-- POSTS FEED -->
                    <div id="posts-feed" class="space-y-4">
                        <% if (posts && posts.length > 0) { %>
                            <% posts.forEach(function(post) { %>
                                <!-- Post Card -->
                                <div class="post-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden" data-post-id="<%= post.id %>" data-urgency="<%= post.urgency %>" data-status="<%= post.status %>" data-official="<%= post.is_official %>">
                                    <!-- Post Header -->
                                    <div class="p-4 pb-2">
                                        <div class="flex items-start justify-between">
                                            <div class="flex items-start gap-3">
                                                <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0 
                                                    <%= post.is_official ? 'bg-gradient-to-br from-blue-600 to-amber-600' : 'bg-gray-400' %>">
                                                    <%= post.user_avatar || (post.user_name ? post.user_name.charAt(0).toUpperCase() : 'U') %>
                                                </div>
                                                <div>
                                                    <div class="flex items-center flex-wrap gap-2">
                                                        <span class="font-semibold text-gray-800">
                                                            <%= post.user_name || 'Unknown User' %>
                                                        </span>
                                                        <% if (post.is_official) { %>
                                                            <span class="official-badge text-white text-xs px-2 py-0.5 rounded-full">
                                                                <i class="fas fa-check-circle"></i> Official
                                                            </span>
                                                        <% } %>
                                                        <% if (post.status === 'Pending') { %>
                                                            <span class="status-pending px-2 py-0.5 rounded-full text-xs">
                                                                <i class="fas fa-clock"></i> Pending Review
                                                            </span>
                                                        <% } %>
                                                        <span class="text-xs text-gray-500"><%= post.user_role || 'Resident' %></span>
                                                    </div>
                                                    <div class="flex items-center gap-2 text-xs text-gray-500 mt-1">
                                                        <span><i class="far fa-clock"></i> <%= post.time_ago || 'Just now' %></span>
                                                        <% if (post.urgency === 'low') { %>
                                                            <span class="urgency-low px-2 py-0.5 rounded-full">Low Priority</span>
                                                        <% } else if (post.urgency === 'medium') { %>
                                                            <span class="urgency-medium px-2 py-0.5 rounded-full">Medium Priority</span>
                                                        <% } else if (post.urgency === 'high') { %>
                                                            <span class="urgency-high px-2 py-0.5 rounded-full">High Priority</span>
                                                        <% } else if (post.urgency === 'emergency') { %>
                                                            <span class="urgency-emergency px-2 py-0.5 rounded-full">🚨 EMERGENCY</span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="text-gray-400">
                                                <% if (post.type === 'announcement') { %>
                                                    <i class="fas fa-bullhorn text-blue-500"></i>
                                                <% } else if (post.type === 'complaint') { %>
                                                    <i class="fas fa-exclamation-triangle text-amber-600"></i>
                                                <% } else if (post.type === 'suggestion') { %>
                                                    <i class="fas fa-lightbulb text-yellow-600"></i>
                                                <% } else if (post.type === 'emergency') { %>
                                                    <i class="fas fa-exclamation-circle text-red-600"></i>
                                                <% } else { %>
                                                    <i class="fas fa-comment text-gray-400"></i>
                                                <% } %>
                                            </div>
                                        </div>

                                        <% if (post.title) { %>
                                            <h3 class="font-bold text-gray-800 mt-3 text-lg">
                                                <a href="/client/dashboard/<%= post.id %>" class="hover:text-amber-600 hover:underline">
                                                    <%= post.title %>
                                                </a>
                                            </h3>
                                        <% } %>

                                        <p class="text-gray-700 mt-2 text-sm leading-relaxed"><%= post.content %></p>
                                    </div>

                                    <!-- Post Stats -->
                                    <div class="px-4 py-2 border-t border-b border-gray-100 flex items-center gap-4 text-xs text-gray-500">
                                        <span><i class="far fa-thumbs-up mr-1"></i> <%= post.likes || 0 %> likes</span>
                                        <span><i class="far fa-comment mr-1"></i> <%= post.comments_count || 0 %> comments</span>
                                        <% if (post.reports_count > 0) { %>
                                            <span class="text-red-500"><i class="fas fa-flag mr-1"></i> <%= post.reports_count %> reports</span>
                                        <% } %>
                                    </div>

                                    <!-- Moderator Actions - REMOVED VIEW BUTTON -->
                                    <div class="px-4 py-2 flex items-center justify-between text-sm border-b border-gray-100 bg-gray-50">
                                        <div class="flex items-center gap-2">
                                            <% if (post.status === 'Pending') { %>
                                                <button onclick="approvePost(<%= post.id %>)" 
                                                        class="flex items-center gap-1 px-3 py-1 bg-green-100 text-green-700 rounded-lg hover:bg-green-200 transition text-xs">
                                                    <i class="fas fa-check"></i> Approve
                                                </button>
                                                <button onclick="showRejectModal(<%= post.id %>)" 
                                                        class="flex items-center gap-1 px-3 py-1 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition text-xs">
                                                    <i class="fas fa-times"></i> Reject
                                                </button>
                                            <% } %>
                                        </div>
                                        <div class="text-xs text-gray-500">
                                            <% if (post.reports_count > 0) { %>
                                                <i class="fas fa-flag text-red-500"></i> Flagged by <%= post.reports_count %> users
                                            <% } %>
                                        </div>
                                    </div>

                                    <!-- Quick Comment Section -->
                                    <div class="px-4 py-3 bg-gray-50">
                                        <form action="/client/dashboard/<%= post.id %>/comment" method="POST" class="flex gap-2">
                                            <input type="text" name="content" placeholder="Write a comment..." 
                                                class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-green-400 focus:border-transparent">
                                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm transition">
                                                Post
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="bg-white rounded-xl shadow-md p-8 text-center">
                                <i class="fas fa-newspaper text-4xl text-gray-300 mb-3"></i>
                                <p class="text-gray-500">No posts yet. Create an announcement to get started!</p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Right Sidebar - Urgent Issues & Recent Activity -->
                <div class="lg:col-span-4 space-y-5">
                    
                    <!-- Urgent Issues Summary -->
                    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                        <div class="bg-gradient-to-r from-red-600 to-red-700 px-4 py-3">
                            <h3 class="font-semibold text-white flex items-center gap-2">
                                <i class="fas fa-exclamation-triangle"></i> Urgent Issues
                            </h3>
                        </div>
                        <div class="divide-y divide-gray-200 max-h-96 overflow-y-auto">
                            <% if (urgentIssues && urgentIssues.length > 0) { %>
                                <% urgentIssues.forEach(function(issue) { %>
                                <div class="p-3 hover:bg-gray-50 transition">
                                    <div class="flex items-start gap-2">
                                        <div class="w-2 h-2 bg-red-600 rounded-full mt-2"></div>
                                        <div class="flex-1">
                                            <p class="text-sm font-medium"><%= issue.title || 'Urgent Concern' %></p>
                                            <p class="text-xs text-gray-500 mt-1">
                                                <i class="far fa-clock"></i> <%= issue.time_ago %>
                                            </p>
                                            <div class="flex items-center gap-2 mt-2">
                                                <span class="text-xs <%= issue.urgency === 'emergency' ? 'bg-purple-100 text-purple-600' : 'bg-red-100 text-red-600' %> px-2 py-0.5 rounded-full">
                                                    <%= issue.urgency === 'emergency' ? 'Emergency' : 'High Priority' %>
                                                </span>
                                                <button onclick="viewPostDetails(<%= issue.id %>)" class="text-xs text-blue-600 hover:underline">Review →</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                            <% } else { %>
                                <div class="p-6 text-center text-gray-500">
                                    <i class="fas fa-check-circle text-3xl mb-2 text-green-500"></i>
                                    <p class="text-sm">No urgent issues at the moment</p>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Recent Moderator Activity -->
                    <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                        <h3 class="font-semibold text-gray-700 flex items-center gap-2 mb-3">
                            <i class="fas fa-history text-amber-600"></i>
                            Recent Activity
                        </h3>
                        <div class="space-y-3 max-h-64 overflow-y-auto">
                            <% if (recentActivity && recentActivity.length > 0) { %>
                                <% recentActivity.forEach(function(activity) { %>
                                <div class="flex items-start gap-2 text-sm border-b border-gray-100 pb-2">
                                    <i class="fas fa-check-circle text-green-500 mt-0.5 text-xs"></i>
                                    <div>
                                        <p class="text-gray-700 text-xs"><span class="font-medium"><%= activity.moderator %></span> <%= activity.details %></p>
                                        <p class="text-xs text-gray-400"><%= activity.time_ago %></p>
                                    </div>
                                </div>
                                <% }); %>
                            <% } else { %>
                                <div class="text-center text-gray-500 py-4">
                                    <i class="fas fa-clock text-2xl mb-2"></i>
                                    <p class="text-sm">No recent activity</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 2: DOCUMENT REQUESTS -->
        <div id="requests-tab" class="tab-content hidden">
            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
                        <i class="fas fa-file-signature text-blue-600"></i>
                        Document Requests Management
                    </h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Resident</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Document Type</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% if (recentRequests && recentRequests.length > 0) { %>
                                <% recentRequests.forEach(function(req) { %>
                                <tr class="table-row-hover">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">#<%= req.id %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= req.resident %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= req.type %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= req.date %></td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="status-<%= req.status %> px-3 py-1 rounded-full text-xs font-medium">
                                            <%= req.statusDisplay %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <button onclick="updateRequestStatus(<%= req.original_id %>)" 
                                                class="text-amber-600 hover:text-amber-700 mr-2" title="Update Status">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button onclick="viewRequestDetails(<%= req.original_id %>)" 
                                                class="text-blue-600 hover:text-blue-700" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                        <i class="fas fa-inbox text-3xl mb-2"></i>
                                        <p>No document requests found</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TAB 3: COMPLAINTS - Updated to show "In Progress" instead of "Under Review" -->
        <div id="complaints-tab" class="tab-content hidden">
            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
                        <i class="fas fa-gavel text-red-600"></i>
                        Complaint Management
                    </h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Complainant</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% if (recentComplaints && recentComplaints.length > 0) { %>
                                <% recentComplaints.forEach(function(comp) { %>
                                <tr class="table-row-hover">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">#<%= comp.id %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= comp.complainant %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= comp.type %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= comp.date %></td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="status-<%= comp.status === 'Under Review' ? 'in-progress' : comp.status.toLowerCase() %> px-3 py-1 rounded-full text-xs font-medium">
                                            <%= comp.status === 'Under Review' ? 'In Progress' : (comp.statusDisplay || comp.status) %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <button onclick="viewComplaintDetails(<%= comp.original_id %>)" 
                                                class="text-blue-600 hover:text-blue-700" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                        <i class="fas fa-inbox text-3xl mb-2"></i>
                                        <p>No complaints found</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TAB 4: ANALYTICS - Enhanced with more relevant metrics -->
        <div id="analytics-tab" class="tab-content hidden">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Activity Chart -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                    <h3 class="font-semibold text-gray-700 flex items-center gap-2 mb-4">
                        <i class="fas fa-chart-line text-amber-600"></i>
                        Weekly Activity Overview
                    </h3>
                    <div class="chart-container">
                        <canvas id="activityChart"></canvas>
                    </div>
                </div>
                
                <!-- Resolution Rate & Status Distribution -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                    <h3 class="font-semibold text-gray-700 flex items-center gap-2 mb-4">
                        <i class="fas fa-chart-pie text-amber-600"></i>
                        Issue Resolution Status
                    </h3>
                    <div class="chart-container">
                        <canvas id="resolutionChart"></canvas>
                    </div>
                    <div class="mt-4 grid grid-cols-3 gap-2 text-center text-xs">
                        <div>
                            <div class="w-3 h-3 bg-green-500 rounded-full inline-block mr-1"></div>
                            <span>Resolved (<%= stats?.resolvedCount || 0 %>)</span>
                        </div>
                        <div>
                            <div class="w-3 h-3 bg-amber-500 rounded-full inline-block mr-1"></div>
                            <span>In Progress (<%= stats?.inProgressCount || 0 %>)</span>
                        </div>
                        <div>
                            <div class="w-3 h-3 bg-red-500 rounded-full inline-block mr-1"></div>
                            <span>Pending (<%= stats?.pendingCount || 0 %>)</span>
                        </div>
                    </div>
                </div>
                
                <!-- Top Categories -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                    <h3 class="font-semibold text-gray-700 flex items-center gap-2 mb-4">
                        <i class="fas fa-tags text-amber-600"></i>
                        Most Common Concerns
                    </h3>
                    <div id="topCategories" class="space-y-3">
                        <% if (topCategories && topCategories.length > 0) { %>
                            <% topCategories.forEach(function(cat) { %>
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span><%= cat.name %></span>
                                    <span><%= cat.count %></span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-amber-600 h-2 rounded-full" style="width: <%= cat.percentage %>%"></div>
                                </div>
                            </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-gray-500 text-sm">No data available</p>
                        <% } %>
                    </div>
                </div>
                
                <!-- Response Time & Performance Metrics -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                    <h3 class="font-semibold text-gray-700 flex items-center gap-2 mb-4">
                        <i class="fas fa-stopwatch text-amber-600"></i>
                        Performance Metrics
                    </h3>
                    <div class="space-y-5">
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <p class="text-sm text-gray-600">Average Response Time</p>
                                <p class="text-xs text-gray-400">Time to first response</p>
                            </div>
                            <p class="text-2xl font-bold text-gray-800"><%= stats?.avgResponseTime || '2.4' %> <span class="text-sm">hours</span></p>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <p class="text-sm text-gray-600">Resolution Rate</p>
                                <p class="text-xs text-gray-400">Issues resolved vs total</p>
                            </div>
                            <p class="text-2xl font-bold text-green-600"><%= stats?.resolutionRate || '78' %>%</p>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <p class="text-sm text-gray-600">Active Users (Last 15min)</p>
                                <p class="text-xs text-gray-400">Currently online</p>
                            </div>
                            <p class="text-2xl font-bold text-blue-600"><%= stats?.activeUsers || '0' %></p>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <p class="text-sm text-gray-600">Resolved This Week</p>
                                <p class="text-xs text-gray-400"><%= stats?.resolvedIncrease > 0 ? '+' + stats.resolvedIncrease : stats.resolvedIncrease === 0 ? 'Same as last week' : stats.resolvedIncrease + ' vs last week' %></p>
                            </div>
                            <p class="text-2xl font-bold text-purple-600"><%= stats?.resolvedThisWeek || '0' %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Update Status Modal - Removed "Completed" option to match schema -->
    <div id="updateStatusModal" class="modal fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
            <div class="bg-gradient-to-r from-blue-600 to-blue-700 p-4 text-white rounded-t-2xl">
                <h3 class="text-lg font-bold">Update Request Status</h3>
            </div>
            <div class="p-6">
                <input type="hidden" id="currentRequestId">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                    <select id="requestStatus" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400">
                        <option value="Pending">Pending</option>
                        <option value="Accepted">In Progress</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Notes (Optional)</label>
                    <textarea id="statusNotes" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400" placeholder="Add notes about this update..."></textarea>
                </div>
                <div class="flex items-center justify-end gap-3">
                    <button onclick="closeStatusModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                        Cancel
                    </button>
                    <button onclick="submitStatusUpdate()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                        Update Status
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Reject Post Modal -->
    <div id="rejectPostModal" class="modal fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
            <div class="bg-gradient-to-r from-red-600 to-red-700 p-4 text-white rounded-t-2xl">
                <h3 class="text-lg font-bold">Reject Post</h3>
            </div>
            <div class="p-6">
                <input type="hidden" id="rejectPostId">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Reason for Rejection</label>
                    <textarea id="rejectReason" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400" placeholder="Please provide a reason for rejection..."></textarea>
                </div>
                <div class="flex items-center justify-end gap-3">
                    <button onclick="closeRejectModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                        Cancel
                    </button>
                    <button onclick="submitRejectPost()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
                        Reject Post
                    </button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/chatbot') %>
    <%- include('../partials/footer') %>

    <script>
        let activityChart = null;
        let resolutionChart = null;
        
        const chartData = {
            days: <%- JSON.stringify(chartData?.days || ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']) %>,
            posts: <%- JSON.stringify(chartData?.posts || [0, 0, 0, 0, 0, 0, 0]) %>,
            requests: <%- JSON.stringify(chartData?.requests || [0, 0, 0, 0, 0, 0, 0]) %>,
            complaints: <%- JSON.stringify(chartData?.complaints || [0, 0, 0, 0, 0, 0, 0]) %>,
            resolved: <%- JSON.stringify(chartData?.resolved || [0, 0, 0, 0, 0, 0, 0]) %>
        };
        
        // Tab switching
        function switchTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.add('hidden'));
            // Remove active class from all tab buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('tab-active');
                btn.classList.remove('border-amber-600', 'text-amber-600');
                btn.classList.add('text-gray-600');
            });
            
            // Show selected tab
            document.getElementById(`${tabName}-tab`).classList.remove('hidden');
            // Add active class to clicked button
            const activeBtn = document.getElementById(`tab-${tabName}`);
            activeBtn.classList.add('tab-active');
            activeBtn.classList.add('border-amber-600', 'text-amber-600');
            activeBtn.classList.remove('text-gray-600');
            
            // Re-render charts if switching to analytics tab
            if (tabName === 'analytics') {
                setTimeout(() => {
                    if (activityChart) activityChart.resize();
                    if (resolutionChart) resolutionChart.resize();
                }, 100);
            }
        }
        
        // Filter posts
        let currentFilter = 'all';
        function filterPosts(filter) {
            currentFilter = filter;
            const posts = document.querySelectorAll('.post-card');
            
            // Update active button style
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-amber-600', 'text-white');
                btn.classList.add('text-gray-600', 'hover:bg-gray-100');
                if (btn.dataset.filter === filter) {
                    btn.classList.add('bg-amber-600', 'text-white');
                    btn.classList.remove('text-gray-600', 'hover:bg-gray-100');
                }
            });
            
            posts.forEach(post => {
                let show = true;
                if (filter === 'pending') {
                    show = post.dataset.status === 'Pending';
                } else if (filter === 'urgent') {
                    show = post.dataset.urgency === 'high' || post.dataset.urgency === 'emergency';
                } else if (filter === 'official') {
                    show = post.dataset.official === 'true';
                }
                post.style.display = show ? '' : 'none';
            });
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Activity Chart
            const activityCtx = document.getElementById('activityChart')?.getContext('2d');
            if (activityCtx) {
                activityChart = new Chart(activityCtx, {
                    type: 'line',
                    data: {
                        labels: chartData.days,
                        datasets: [
                            { label: 'Posts', data: chartData.posts, borderColor: '#f59e0b', backgroundColor: 'rgba(245, 158, 11, 0.1)', tension: 0.4, fill: true },
                            { label: 'Requests', data: chartData.requests, borderColor: '#3b82f6', backgroundColor: 'rgba(59, 130, 246, 0.1)', tension: 0.4, fill: true },
                            { label: 'Complaints', data: chartData.complaints, borderColor: '#ef4444', backgroundColor: 'rgba(239, 68, 68, 0.1)', tension: 0.4, fill: true },
                            { label: 'Resolved', data: chartData.resolved, borderColor: '#10b981', backgroundColor: 'rgba(16, 185, 129, 0.1)', tension: 0.4, fill: true }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: true } } }
                });
            }
            
            // Initialize Resolution Chart
            const resolutionCtx = document.getElementById('resolutionChart')?.getContext('2d');
            if (resolutionCtx) {
                resolutionChart = new Chart(resolutionCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Resolved', 'In Progress', 'Pending'],
                        datasets: [{ data: [<%= stats?.resolvedCount || 0 %>, <%= stats?.inProgressCount || 0 %>, <%= stats?.pendingCount || 0 %>], backgroundColor: ['#10b981', '#f59e0b', '#ef4444'] }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
                });
            }
            
            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(function() { 
                    if (activityChart) activityChart.resize();
                    if (resolutionChart) resolutionChart.resize();
                }, 250);
            });
        });
        
        function approvePost(postId) {
            if (confirm('Approve this post? It will be visible to all residents.')) {
                fetch(`/moderator/posts/${postId}/approve`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
                    .then(r => r.json()).then(d => { if (d.success) { showToast('Post approved!', 'success'); setTimeout(() => location.reload(), 1500); } else showToast('Error', 'error'); })
                    .catch(() => showToast('Error', 'error'));
            }
        }
        
        function showRejectModal(postId) { 
            document.getElementById('rejectPostId').value = postId; 
            document.getElementById('rejectPostModal').classList.remove('hidden'); 
        }
        
        function closeRejectModal() { 
            document.getElementById('rejectPostModal').classList.add('hidden'); 
            document.getElementById('rejectReason').value = ''; 
        }
        
        function submitRejectPost() {
            const postId = document.getElementById('rejectPostId').value;
            const reason = document.getElementById('rejectReason').value;
            fetch(`/moderator/posts/${postId}/reject`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: reason }) })
                .then(r => r.json()).then(d => { if (d.success) { showToast('Post rejected', 'success'); closeRejectModal(); setTimeout(() => location.reload(), 1500); } else showToast('Error', 'error'); })
                .catch(() => showToast('Error', 'error'));
        }
        
        let currentRequestId = null;
        function updateRequestStatus(requestId) { 
            currentRequestId = requestId; 
            document.getElementById('currentRequestId').value = requestId; 
            document.getElementById('updateStatusModal').classList.remove('hidden'); 
        }
        
        function closeStatusModal() { 
            document.getElementById('updateStatusModal').classList.add('hidden'); 
            document.getElementById('requestStatus').value = 'Pending'; 
            document.getElementById('statusNotes').value = ''; 
        }
        
        function submitStatusUpdate() {
            const status = document.getElementById('requestStatus').value;
            const notes = document.getElementById('statusNotes').value;
            fetch(`/moderator/requests/${currentRequestId}/update`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: status, notes: notes }) })
                .then(r => r.json()).then(d => { if (d.success) { showToast('Status updated', 'success'); closeStatusModal(); setTimeout(() => location.reload(), 1500); } else showToast('Error', 'error'); })
                .catch(() => showToast('Error', 'error'));
        }
        
        function viewRequestDetails(id) { window.location.href = `/client/requests/${id}`; }
        function viewComplaintDetails(id) { window.location.href = `/client/complaints/${id}`; }
        function viewPostDetails(id) { window.location.href = `/client/dashboard/${id}`; }
        
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `toast px-6 py-3 rounded-lg shadow-lg text-white ${type === 'success' ? 'bg-green-500' : 'bg-red-500'}`;
            toast.innerHTML = `<div class="flex items-center gap-2"><i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i><span>${message}</span></div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
</body>
</html>