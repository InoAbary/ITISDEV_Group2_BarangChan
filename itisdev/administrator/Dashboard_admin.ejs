    <!-- JavaScript for Charts and Analytics -->
    <script>
        // Update date and time
        function updateDateTime() {
            const now = new Date();
            const dateOptions = { year: 'numeric', month: 'long', day: 'numeric' };
            const timeOptions = { hour: '2-digit', minute: '2-digit', second: '2-digit' };
            
            document.getElementById('currentDate').textContent = now.toLocaleDateString('en-US', dateOptions);
            document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-US', timeOptions);
        }
        setInterval(updateDateTime, 1000);
        updateDateTime();

        // User Growth Chart (Descriptive)
        const userGrowthCtx = document.getElementById('userGrowthChart').getContext('2d');
        new Chart(userGrowthCtx, {
            type: 'line',
            data: {
                labels: ['Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'],
                datasets: [
                    {
                        label: 'New Users',
                        data: [245, 320, 412, 389, 456, 512],
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Active Users',
                        data: [189, 245, 312, 356, 412, 478],
                        borderColor: '#f59e0b',
                        backgroundColor: 'rgba(245, 158, 11, 0.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // Activity Distribution Chart (Descriptive)
        const activityCtx = document.getElementById('activityDistributionChart').getContext('2d');
        new Chart(activityCtx, {
            type: 'doughnut',
            data: {
                labels: ['Posts', 'Document Requests', 'Complaints', 'Chatbot Inquiries', 'Profile Updates'],
                datasets: [{
                    data: [35, 28, 15, 12, 10],
                    backgroundColor: ['#3b82f6', '#f59e0b', '#ef4444', '#10b981', '#8b5cf6'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // Simulate real-time updates
        setInterval(() => {
            // Randomize some values to simulate live data
            const usersLoggedIn = document.getElementById('usersLoggedIn');
            const moderatorsOnline = document.getElementById('moderatorsOnline');
            
            if (usersLoggedIn) {
                const current = parseInt(usersLoggedIn.textContent);
                const change = Math.floor(Math.random() * 10) - 3;
                usersLoggedIn.textContent = Math.max(800, current + change);
            }
            
            if (moderatorsOnline) {
                const current = parseInt(moderatorsOnline.textContent);
                const change = Math.floor(Math.random() * 3) - 1;
                moderatorsOnline.textContent = Math.max(15, Math.min(22, current + change));
            }
        }, 30000); // Update every 30 seconds
    </script>
