<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan - Admin Analytics Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        .analytics-card { transition: all 0.2s ease; }
        .analytics-card:hover { transform: translateY(-2px); box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }
        .status-online { background-color: #dcfce7; color: #166534; }
        .status-offline { background-color: #fee2e2; color: #991b1b; }
        .status-away { background-color: #fff3e0; color: #9a3412; }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col" data-page-context="admin">
    <%- include('../partials/topnavigation', { currentPath: '/administrator/dashboard', currentUser: user }) %>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-chart-pie"></i>
                        Admin Analytics Dashboard
                    </h1>
                    <p class="text-blue-100 mt-1 text-sm">Database-driven overview of platform usage, service workload, and moderator operations.</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-calendar-alt mr-2"></i><span id="currentDate"></span>
                    </span>
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-clock mr-2"></i><span id="currentTime"></span>
                    </span>
                </div>
            </div>
        </div>

        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="analytics-card bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500">
                <p class="text-sm text-gray-500 mb-1"><i class="fas fa-users text-blue-500 mr-1"></i>Total Registered Users</p>
                <p class="text-3xl font-bold text-gray-800"><%= totalUsers || 0 %></p>
                <p class="text-xs text-green-600 mt-2">+<%= growthPercent || 0 %>% from last month</p>
                <p class="mt-3 text-xs text-gray-500">Active: <%= activeUsers || 0 %> | Inactive: <%= inactiveUsers || 0 %></p>
            </div>
            <div class="analytics-card bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
                <p class="text-sm text-gray-500 mb-1"><i class="fas fa-sign-in-alt text-green-500 mr-1"></i>Users Logged In Today</p>
                <p class="text-3xl font-bold text-gray-800" id="usersLoggedIn"><%= usersLoggedInToday || 0 %></p>
                <p class="text-xs text-green-600 mt-2">Derived from `last_login`</p>
            </div>
            <div class="analytics-card bg-white rounded-xl shadow-md p-6 border-l-4 border-amber-500">
                <p class="text-sm text-gray-500 mb-1"><i class="fas fa-user-shield text-amber-500 mr-1"></i>Moderators Online</p>
                <p class="text-3xl font-bold text-gray-800" id="moderatorsOnline"><%= moderatorsOnline || 0 %></p>
                <p class="text-xs text-amber-600 mt-2">of <%= totalModerators || 0 %> total moderators</p>
            </div>
            <div class="analytics-card bg-white rounded-xl shadow-md p-6 border-l-4 border-purple-500">
                <p class="text-sm text-gray-500 mb-1"><i class="fas fa-file-signature text-purple-500 mr-1"></i>Pending Requests</p>
                <p class="text-3xl font-bold text-gray-800"><%= pendingRequests || 0 %></p>
                <p class="text-xs text-purple-600 mt-2"><%= completedRequests || 0 %> completed overall</p>
                <p class="mt-3 text-xs text-gray-500">Total requests: <%= totalRequests || 0 %> | Recent posts: <%= recentPosts || 0 %></p>
            </div>
        </div>

        <div class="filipino-divider my-8"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-gray-700">User Growth (Last 6 Months)</h3>
                </div>
                <div class="h-64">
                    <canvas id="userGrowthChart"></canvas>
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-gray-700">Platform Activity Distribution</h3>
                    <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">Last 30 days</span>
                </div>
                <div class="h-64">
                    <canvas id="activityDistributionChart"></canvas>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-4">Service Completion Overview</h3>
                <div class="space-y-4">
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span>Registration Funnel</span>
                            <span class="font-medium"><%= dropOff?.registrationFunnel || 0 %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2.5">
                            <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= dropOff?.registrationFunnel || 0 %>%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span>Request Completion</span>
                            <span class="font-medium"><%= dropOff?.documentCompletion || 0 %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2.5">
                            <div class="bg-amber-600 h-2.5 rounded-full" style="width: <%= dropOff?.documentCompletion || 0 %>%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span>Complaint Resolution</span>
                            <span class="font-medium"><%= dropOff?.complaintResolution || 0 %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2.5">
                            <div class="bg-green-600 h-2.5 rounded-full" style="width: <%= dropOff?.complaintResolution || 0 %>%"></div>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Average resolution time: <%= resolutionTime || 0 %> days</p>
                    </div>
                </div>

                <div class="mt-6 p-4 bg-red-50 rounded-lg">
                    <h4 class="font-semibold text-red-700 text-sm mb-2">Database-Backed Issues</h4>
                    <ul class="space-y-2 text-xs text-red-600">
                        <% (issueSummary || []).forEach(function(issue) { %>
                            <li class="flex items-start gap-2">
                                <i class="fas fa-circle text-[6px] mt-1.5"></i>
                                <span><%= issue.text %></span>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-4">Operational Metrics</h3>
                <div class="space-y-4 mb-6">
                    <% (operationalMetrics || []).forEach(function(metric) { %>
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1">
                                <span><%= metric.label %></span>
                                <span class="font-medium text-<%= metric.color %>-600"><%= metric.value %>%</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2">
                                <div class="bg-<%= metric.color %>-500 h-2 rounded-full" style="width: <%= metric.value %>%"></div>
                            </div>
                            <p class="text-xs text-gray-500 mt-1"><%= metric.detail %></p>
                        </div>
                    <% }) %>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <p class="text-xs text-gray-500">Open Complaints</p>
                        <p class="text-xl font-bold text-red-600"><%= unresolvedComplaints || 0 %></p>
                        <p class="text-xs text-gray-400"><%= resolvedComplaints || 0 %> resolved</p>
                    </div>
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <p class="text-xs text-gray-500">Total Posts</p>
                        <p class="text-xl font-bold text-blue-600"><%= totalPosts || 0 %></p>
                        <p class="text-xs text-gray-400"><%= recentPosts || 0 %> in the last 30 days</p>
                    </div>
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <p class="text-xs text-gray-500">Chatbot Queries</p>
                        <p class="text-xl font-bold text-purple-600"><%= systemHealth?.totalQueries || 0 %></p>
                        <p class="text-xs text-gray-400">Last hour activity</p>
                    </div>
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <p class="text-xs text-gray-500">Avg Chatbot Response</p>
                        <p class="text-xl font-bold text-amber-600"><%= systemHealth?.avgResponseTime || 0 %>ms</p>
                        <p class="text-xs text-gray-400">Live from ChatbotLog</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-3">User Growth Forecast</h3>
                <div class="flex items-end gap-2 mb-4">
                    <p class="text-3xl font-bold text-blue-600"><%= predictedUsers || 0 %></p>
                    <p class="text-sm text-gray-500 mb-1">projected users</p>
                </div>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <span>Current users:</span>
                        <span class="font-medium"><%= totalUsers || 0 %></span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span>Projected growth:</span>
                        <span class="font-medium text-green-600">+<%= growthPercent || 0 %>%</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span>Recent sign-ins:</span>
                        <span class="font-medium"><%= usersLoggedInToday || 0 %> today</span>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-3">Peak Usage Prediction</h3>
                <p class="text-sm text-gray-500">Next peak expected:</p>
                <p class="text-xl font-bold text-amber-600 mb-4"><%= predictedPeakDay || 'N/A' %>, <%= predictedPeakHour || 'N/A' %></p>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <span>Predicted concurrent users:</span>
                        <span class="font-medium"><%= predictedConcurrent || 0 %></span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span>Moderators available now:</span>
                        <span class="font-medium text-amber-600"><%= moderatorsOnline || 0 %> / <%= totalModerators || 0 %></span>
                    </div>
                </div>
                <div class="mt-4 p-3 bg-amber-50 rounded-lg text-xs text-amber-700">
                    <i class="fas fa-lightbulb mr-1"></i>Peak hours are derived from actual login records.
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-3">Document Request Forecast</h3>
                <div class="flex items-end gap-2 mb-4">
                    <p class="text-3xl font-bold text-green-600"><%= predictedRequests || 0 %></p>
                    <p class="text-sm text-gray-500 mb-1">requests next week</p>
                </div>
                <div class="space-y-2 text-sm">
                    <% if (documentBreakdown && documentBreakdown.length > 0) { %>
                        <% documentBreakdown.slice(0, 3).forEach(function(doc) { %>
                            <div class="flex items-center justify-between">
                                <span><%= doc.doc_type %>:</span>
                                <span class="font-medium text-green-600"><%= doc.count || 0 %> requests</span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-gray-500">No recent document request breakdown available.</p>
                    <% } %>
                </div>
                <div class="mt-4 flex items-center gap-2">
                    <div class="flex-1 bg-gray-200 rounded-full h-2">
                        <div class="bg-green-500 h-2 rounded-full" style="width: <%= Math.min(100, Math.max(5, Number(requestForecastGrowth || 0) + 50)) %>%"></div>
                    </div>
                    <span class="text-xs text-gray-500"><%= requestForecastGrowth || 0 %>% growth</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-4">Recommendations</h3>
                <div class="space-y-4">
                    <% if (recommendations && recommendations.length > 0) { %>
                        <% recommendations.forEach(function(rec) { %>
                            <div class="p-3 bg-<%= rec.category === 'database' ? 'blue' : (rec.category === 'chatbot' ? 'amber' : 'green') %>-50 rounded-lg border-l-4 border-<%= rec.category === 'database' ? 'blue' : (rec.category === 'chatbot' ? 'amber' : 'green') %>-500">
                                <p class="font-medium text-sm text-<%= rec.category === 'database' ? 'blue' : (rec.category === 'chatbot' ? 'amber' : 'green') %>-800"><%= rec.action %></p>
                                <p class="text-xs text-<%= rec.category === 'database' ? 'blue' : (rec.category === 'chatbot' ? 'amber' : 'green') %>-600 mt-1"><%= rec.recommendation %></p>
                                <p class="text-xs text-<%= rec.category === 'database' ? 'blue' : (rec.category === 'chatbot' ? 'amber' : 'green') %>-500 mt-2">Priority: <%= rec.priority %> | ROI: +<%= rec.roi %>%</p>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-sm text-gray-500">No recommendations available.</p>
                    <% } %>
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                <h3 class="font-semibold text-gray-700 mb-4">Immediate Priorities</h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50">
                        <div class="flex items-center gap-3">
                            <i class="fas fa-folder-open text-amber-600"></i>
                            <span class="text-sm">Review <%= pendingRequests || 0 %> pending document requests.</span>
                        </div>
                        <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Queue</span>
                    </div>
                    <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50">
                        <div class="flex items-center gap-3">
                            <i class="fas fa-exclamation-triangle text-red-600"></i>
                            <span class="text-sm">Resolve <%= unresolvedComplaints || 0 %> open complaints.</span>
                        </div>
                        <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">Urgent</span>
                    </div>
                    <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50">
                        <div class="flex items-center gap-3">
                            <i class="fas fa-user-clock text-blue-600"></i>
                            <span class="text-sm">Monitor staffing around <%= predictedPeakDay || 'peak day' %> <%= predictedPeakHour || '' %>.</span>
                        </div>
                        <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">Staffing</span>
                    </div>
                    <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50">
                        <div class="flex items-center gap-3">
                            <i class="fas fa-robot text-purple-600"></i>
                            <span class="text-sm">Track chatbot throughput: <%= systemHealth?.totalQueries || 0 %> queries in the last hour.</span>
                        </div>
                        <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full">Support</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden mb-8">
            <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-6 py-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-user-shield"></i>
                    Moderator Status Dashboard
                </h2>
            </div>
            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Moderator</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Active</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tickets Assigned</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Resolution Rate</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Avg Response</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% if (moderatorStatus && moderatorStatus.length > 0) { %>
                                <% moderatorStatus.forEach(function(mod) { %>
                                    <tr class="hover:bg-gray-50">
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center">
                                                <div class="w-8 h-8 bg-<%= mod.role === 'administrator' ? 'amber' : (mod.online_status === 'Online' ? 'green' : 'blue') %>-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                                                    <%= mod.name ? mod.name.charAt(0).toUpperCase() : 'M' %>
                                                </div>
                                                <div class="ml-3">
                                                    <p class="text-sm font-medium text-gray-900"><%= mod.name %></p>
                                                    <p class="text-xs text-gray-500"><%= mod.role === 'administrator' ? 'Administrator' : 'Moderator' %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="status-<%= mod.online_status === 'Online' ? 'online' : (mod.online_status === 'Away' ? 'away' : 'offline') %> px-3 py-1 rounded-full text-xs font-medium"><%= mod.online_status %></span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= mod.online_status === 'Online' ? 'Now' : (mod.last_login ? moment(mod.last_login).fromNow() : 'Never') %></td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= mod.tickets_assigned || 0 %></td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-medium"><%= mod.resolution_rate || 0 %>%</span>
                                                <div class="w-16 bg-gray-200 rounded-full h-2">
                                                    <div class="bg-green-500 h-2 rounded-full" style="width: <%= mod.resolution_rate || 0 %>%"></div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= mod.avg_response_time || '-' %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">No moderator data available</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="mt-4 flex items-center justify-between">
                    <div class="flex items-center gap-4 text-xs text-gray-600">
                        <span><span class="inline-block w-3 h-3 bg-green-500 rounded-full mr-1"></span><%= moderatorsOnline || 0 %> Online</span>
                        <span><span class="inline-block w-3 h-3 bg-gray-400 rounded-full mr-1"></span><%= Math.max(0, (totalModerators || 0) - (moderatorsOnline || 0)) %> Offline/Away</span>
                    </div>
                    <a href="/administrator/moderators" class="text-sm text-amber-600 hover:text-amber-700">Manage Moderators <i class="fas fa-arrow-right ml-1"></i></a>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                    <h3 class="font-semibold text-gray-700">Generate Analytics Report</h3>
                    <p class="text-xs text-gray-500">Download a summary of the current dashboard analytics</p>
                </div>
                <div class="flex gap-2">
                    <button onclick="generateReport('pdf')" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 transition flex items-center gap-2">
                        <i class="fas fa-file-pdf text-red-500"></i>PDF
                    </button>
                    <button onclick="generateReport('excel')" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 transition flex items-center gap-2">
                        <i class="fas fa-file-excel text-green-600"></i>Excel
                    </button>
                    <button onclick="generateReport('csv')" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 transition flex items-center gap-2">
                        <i class="fas fa-file-csv text-blue-600"></i>CSV
                    </button>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/chatbot') %>
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
    <script>
        function updateDateTime() {
            const now = new Date();
            document.getElementById('currentDate').textContent = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
            document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        setInterval(updateDateTime, 1000);
        updateDateTime();

        const userGrowthMonths = <%- JSON.stringify(userGrowthMonths || []) %>;
        const userGrowthNew = <%- JSON.stringify(userGrowthNew || []) %>;
        const userGrowthActive = <%- JSON.stringify(userGrowthActive || []) %>;
        new Chart(document.getElementById('userGrowthChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: userGrowthMonths,
                datasets: [
                    { label: 'New Users', data: userGrowthNew, borderColor: '#2563eb', backgroundColor: 'rgba(37, 99, 235, 0.08)', tension: 0.35, fill: true },
                    { label: 'Cumulative Users', data: userGrowthActive, borderColor: '#f59e0b', backgroundColor: 'rgba(245, 158, 11, 0.08)', tension: 0.35, fill: true }
                ]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: true } } }
        });

        const activityTypes = <%- JSON.stringify(activityTypes || []) %>;
        const activityCounts = <%- JSON.stringify(activityCounts || []) %>;
        new Chart(document.getElementById('activityDistributionChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: activityTypes,
                datasets: [{ data: activityCounts, backgroundColor: ['#2563eb', '#f59e0b', '#ef4444', '#10b981', '#8b5cf6'], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        function generateReport(format) {
            window.location.href = `/administrator/reports/generate?format=${format}&type=full`;
        }

        setInterval(() => {
            fetch('/administrator/analytics/realtime')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const usersLoggedIn = document.getElementById('usersLoggedIn');
                        const moderatorsOnline = document.getElementById('moderatorsOnline');
                        if (usersLoggedIn) usersLoggedIn.textContent = data.usersLoggedIn;
                        if (moderatorsOnline) moderatorsOnline.textContent = data.moderatorsOnline;
                    }
                })
                .catch(err => console.error('Error fetching real-time data:', err));
        }, 30000);
    </script>
</body>
</html>
