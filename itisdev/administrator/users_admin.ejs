    <!-- JavaScript for Manage Users Page -->
    <script>
        let currentUserId = null;

        // Open user details modal
        function openUserModal(userId) {
            currentUserId = userId;
            document.getElementById('userModal').classList.remove('hidden');
        }

        function closeUserModal() {
            document.getElementById('userModal').classList.add('hidden');
        }

        // Open suspend modal
        function openSuspendModal(userId) {
            currentUserId = userId;
            document.getElementById('suspendModal').classList.remove('hidden');
        }

        function closeSuspendModal() {
            document.getElementById('suspendModal').classList.add('hidden');
        }

        function confirmSuspend() {
            const reason = document.getElementById('suspendReason').value;
            const duration = document.getElementById('suspendDuration').value;
            
            // Here you would make an API call to suspend the user
            console.log('Suspending user:', currentUserId, 'Reason:', reason, 'Duration:', duration);
            
            // Show success message
            showSuccess('User has been suspended successfully');
            
            closeSuspendModal();
        }

        // Send warning
        function showWarning(userId) {
            currentUserId = userId;
            
            // Here you would make an API call to send warning
            console.log('Sending warning to user:', userId);
            
            // Show toast
            const toast = document.getElementById('warningToast');
            document.getElementById('warningMessage').textContent = 'Warning has been sent to the user.';
            toast.classList.remove('hidden');
            
            // Auto hide after 3 seconds
            setTimeout(() => {
                toast.classList.add('hidden');
            }, 3000);
        }

        // Show success message
        function showSuccess(message) {
            // You can implement a success toast here
            alert(message); // Temporary
        }

        // Close toast
        function closeToast() {
            document.getElementById('warningToast').classList.add('hidden');
        }

        // Search functionality
        document.getElementById('searchUsers')?.addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Filter functionality
        function applyFilters() {
            const statusFilter = document.getElementById('statusFilter').value;
            const reportFilter = document.getElementById('reportFilter').value;
            const roleFilter = document.getElementById('roleFilter').value;
            
            console.log('Applying filters:', { status: statusFilter, report: reportFilter, role: roleFilter });
            // Implement actual filtering logic here
        }

        document.getElementById('statusFilter')?.addEventListener('change', applyFilters);
        document.getElementById('reportFilter')?.addEventListener('change', applyFilters);
        document.getElementById('roleFilter')?.addEventListener('change', applyFilters);

        // Close modals when clicking outside
        window.addEventListener('click', function(event) {
            const userModal = document.getElementById('userModal');
            const suspendModal = document.getElementById('suspendModal');
            
            if (event.target === userModal) {
                closeUserModal();
            }
            if (event.target === suspendModal) {
                closeSuspendModal();
            }
        });

        // Add quick actions for chatbot
        document.addEventListener('DOMContentLoaded', function() {
            const quickActionsContainer = document.getElementById('quickActionsContainer');
            if (quickActionsContainer) {
                quickActionsContainer.innerHTML = `
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How do I suspend a user?">
                        ⚠️ Suspend user
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="What is considered unusual activity?">
                        📊 Unusual activity
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How to send a warning?">
                        ⚡ Send warning
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Show users with high reports">
                        🔥 High report users
                    </button>
                `;
            }
        });
    </script>
