<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan - Manage Users</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern { background-color: #f8fafc; }
        .status-active { background-color: #dcfce7; color: #166534; }
        .status-inactive { background-color: #fee2e2; color: #991b1b; }
        .status-suspended { background-color: #fef3c7; color: #92400e; }
        .status-pending { background-color: #e0f2fe; color: #075985; }
        .report-low { background-color: #e6f7e6; color: #2e7d32; }
        .report-medium { background-color: #fff3e0; color: #ef6c00; }
        .report-high { background-color: #ffebee; color: #c62828; }
        .report-critical { background-color: #fecaca; color: #991b1b; }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">
    <%
        const stats = userStats || { total: 0, active: 0, flagged: 0, suspended: 0, pending: 0, newToday: 0 };
        const userList = users || [];
        const flaggedList = flaggedUsers || [];
        function reportClass(level) {
            if (level === 'critical') return 'report-critical';
            if (level === 'high') return 'report-high';
            if (level === 'medium') return 'report-medium';
            return 'report-low';
        }
    %>
    <%- include('../partials/topnavigation', { currentPath: '/administrator/users', currentUser: user }) %>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-users-cog"></i>
                        Manage Users
                    </h1>
                    <p class="text-blue-100 mt-1 text-sm">Live user list with warning, suspension, and reactivation actions.</p>
                </div>
                <div class="flex items-center gap-3 flex-wrap">
                    <span class="bg-white/20 px-4 py-2 rounded-lg text-sm">Total Users: <%= stats.total %></span>
                    <span class="bg-white/20 px-4 py-2 rounded-lg text-sm">Flagged: <%= stats.flagged %></span>
                </div>
            </div>
        </div>

        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg">
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg">
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
                <p class="text-sm text-gray-500 mb-1">Active Users</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.active %></p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-red-500">
                <p class="text-sm text-gray-500 mb-1">Flagged Users</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.flagged %></p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-amber-500">
                <p class="text-sm text-gray-500 mb-1">Suspended Accounts</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.suspended %></p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500">
                <p class="text-sm text-gray-500 mb-1">New Today</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.newToday %></p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4">
                <input type="text" id="searchUsers" placeholder="Search by name, email, or username..." class="flex-1 px-4 py-3 border border-gray-300 rounded-lg">
                <select id="statusFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm">
                    <option value="all">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                    <option value="suspended">Suspended</option>
                    <option value="pending">Pending</option>
                </select>
                <select id="reportFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm">
                    <option value="all">All Report Levels</option>
                    <option value="low">Low</option>
                    <option value="medium">Medium</option>
                    <option value="high">High</option>
                    <option value="critical">Critical</option>
                </select>
                <select id="roleFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm">
                    <option value="all">All Roles</option>
                    <option value="resident">Resident</option>
                    <option value="moderator">Moderator</option>
                    <option value="administrator">Admin</option>
                </select>
            </div>
        </div>

        <% if (flaggedList.length) { %>
            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-800 mb-4">Flagged Users</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% flaggedList.forEach(function(account) { %>
                        <div class="bg-white rounded-xl shadow-md border-l-4 border-red-500 p-5 user-record"
                             data-search="<%= `${account.name} ${account.email} ${account.username || ''}`.toLowerCase() %>"
                             data-status="<%= account.statusKey %>"
                             data-role="<%= account.role %>"
                             data-report="<%= account.reportLevel %>">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="font-semibold text-gray-800"><%= account.name %></h3>
                                    <p class="text-xs text-gray-500"><%= account.email %></p>
                                </div>
                                <span class="<%= reportClass(account.reportLevel) %> px-3 py-1 rounded-full text-xs font-bold"><%= account.reportLevel.toUpperCase() %></span>
                            </div>
                            <div class="mt-4 grid grid-cols-3 gap-2 text-center text-sm">
                                <div><p class="font-bold text-red-600"><%= account.reportCount %></p><p class="text-xs text-gray-500">Reports</p></div>
                                <div><p class="font-bold text-gray-700"><%= account.postCount %></p><p class="text-xs text-gray-500">Posts</p></div>
                                <div><p class="font-bold text-gray-700"><%= account.warningCount %></p><p class="text-xs text-gray-500">Warnings</p></div>
                            </div>
                            <div class="mt-4 flex gap-2">
                                <button type="button" onclick="openUserModal('<%= account.user_id %>')" class="flex-1 bg-amber-600 hover:bg-amber-700 text-white px-3 py-2 rounded-lg text-sm">Review</button>
                                <button type="button" onclick="openActionModal('warn', '<%= account.user_id %>')" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white px-3 py-2 rounded-lg text-sm">Warn</button>
                                <button type="button" onclick="openActionModal('suspend', '<%= account.user_id %>')" class="flex-1 bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded-lg text-sm">Suspend</button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-6 py-4">
                <h2 class="text-xl font-bold text-white">All Users</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Reports</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Warnings</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Active</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Joined</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% if (userList.length) { %>
                            <% userList.forEach(function(account) { %>
                                <tr class="hover:bg-gray-50 user-record"
                                    data-search="<%= `${account.name} ${account.email} ${account.username || ''}`.toLowerCase() %>"
                                    data-status="<%= account.statusKey %>"
                                    data-role="<%= account.role %>"
                                    data-report="<%= account.reportLevel %>">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div>
                                            <p class="text-sm font-medium text-gray-900"><%= account.name %></p>
                                            <p class="text-xs text-gray-500"><%= account.email %></p>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap"><span class="bg-gray-100 text-gray-800 px-3 py-1 rounded-full text-xs"><%= account.roleLabel %></span></td>
                                    <td class="px-6 py-4 whitespace-nowrap"><span class="status-<%= account.statusKey %> px-3 py-1 rounded-full text-xs font-medium"><%= account.statusLabel %></span></td>
                                    <td class="px-6 py-4 whitespace-nowrap"><span class="<%= reportClass(account.reportLevel) %> px-3 py-1 rounded-full text-xs font-bold"><%= account.reportCount %></span></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= account.warningCount %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= account.lastActiveLabel %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= account.joinedLabel %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <button type="button" class="text-amber-600 hover:text-amber-700 mr-2" onclick="openUserModal('<%= account.user_id %>')"><i class="fas fa-eye"></i></button>
                                        <button type="button" class="text-yellow-600 hover:text-yellow-700 mr-2" onclick="openActionModal('warn', '<%= account.user_id %>')" <%= account.isCurrentUser ? 'disabled' : '' %>><i class="fas fa-exclamation-triangle"></i></button>
                                        <% if (account.statusKey === 'suspended') { %>
                                            <button type="button" class="text-green-600 hover:text-green-700" onclick="openActionModal('activate', '<%= account.user_id %>')" <%= account.isCurrentUser ? 'disabled' : '' %>><i class="fas fa-user-check"></i></button>
                                        <% } else { %>
                                            <button type="button" class="text-red-600 hover:text-red-700" onclick="openActionModal('suspend', '<%= account.user_id %>')" <%= account.isCurrentUser ? 'disabled' : '' %>><i class="fas fa-ban"></i></button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="8" class="px-6 py-8 text-center text-gray-500">No users found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 text-sm text-gray-500">Showing <%= userList.length %> user account<%= userList.length === 1 ? '' : 's' %></div>
        </div>
    </main>

    <div id="userModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl max-w-xl w-full mx-4">
            <div class="bg-gradient-to-r from-blue-900 to-amber-800 p-6 text-white rounded-t-2xl flex items-center justify-between">
                <h3 class="text-xl font-bold">User Details</h3>
                <button type="button" onclick="closeUserModal()"><i class="fas fa-times"></i></button>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div><p class="text-gray-500">Name</p><p id="detailName" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Role</p><p id="detailRole" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Email</p><p id="detailEmail" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Phone</p><p id="detailPhone" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Status</p><p id="detailStatus" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Last Active</p><p id="detailLastActive" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Joined</p><p id="detailJoined" class="font-medium"></p></div>
                    <div><p class="text-gray-500">Reports / Warnings</p><p id="detailCounts" class="font-medium"></p></div>
                </div>
            </div>
        </div>
    </div>

    <div id="actionModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
            <form id="actionForm" method="POST">
                <div class="bg-amber-600 p-6 text-white rounded-t-2xl">
                    <h3 id="actionTitle" class="text-xl font-bold"></h3>
                </div>
                <div class="p-6">
                    <p class="text-gray-700 mb-4">Apply this action to <span class="font-bold" id="actionUserName"></span>.</p>
                    <input type="hidden" name="action" id="actionInput">
                    <div id="reasonField" class="mb-4 hidden">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Reason</label>
                        <select name="reason" class="w-full px-4 py-2 border border-gray-300 rounded-lg">
                            <option value="harassment">Harassment / Bullying</option>
                            <option value="spam">Spam / Advertisement</option>
                            <option value="misinformation">Spreading Misinformation</option>
                            <option value="inappropriate">Inappropriate Content</option>
                            <option value="multiple">Multiple Violations</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div id="durationField" class="mb-4 hidden">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Duration</label>
                        <select name="duration" class="w-full px-4 py-2 border border-gray-300 rounded-lg">
                            <option value="1 day">1 day</option>
                            <option value="3 days">3 days</option>
                            <option value="7 days">7 days</option>
                            <option value="14 days">14 days</option>
                            <option value="30 days">30 days</option>
                            <option value="permanent">Permanent</option>
                        </select>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Notes</label>
                        <textarea name="note" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg" placeholder="Optional details for the audit log"></textarea>
                    </div>
                    <div class="flex items-center gap-3">
                        <button type="button" onclick="closeActionModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700">Cancel</button>
                        <button type="submit" class="flex-1 px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-lg">Confirm</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/chatbot') %>
    <%- include('../partials/footer') %>

    <script>
        const users = <%- JSON.stringify(userList) %>;
        function getUser(userId) { return users.find(user => String(user.user_id) === String(userId)); }
        function openUserModal(userId) {
            const account = getUser(userId);
            if (!account) return;
            document.getElementById('detailName').textContent = account.name;
            document.getElementById('detailRole').textContent = account.roleLabel;
            document.getElementById('detailEmail').textContent = account.email || 'N/A';
            document.getElementById('detailPhone').textContent = account.phone || 'N/A';
            document.getElementById('detailStatus').textContent = account.statusLabel;
            document.getElementById('detailLastActive').textContent = account.lastActiveLabel;
            document.getElementById('detailJoined').textContent = account.joinedLabel;
            document.getElementById('detailCounts').textContent = `${account.reportCount} reports / ${account.warningCount} warnings`;
            const modal = document.getElementById('userModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
        function closeUserModal() {
            const modal = document.getElementById('userModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        function openActionModal(action, userId) {
            const account = getUser(userId);
            if (!account) return;
            const modal = document.getElementById('actionModal');
            const form = document.getElementById('actionForm');
            document.getElementById('actionInput').value = action;
            document.getElementById('actionUserName').textContent = account.name;
            document.getElementById('actionTitle').textContent = action === 'warn' ? 'Send Warning' : (action === 'suspend' ? 'Suspend Account' : 'Reactivate Account');
            document.getElementById('reasonField').classList.toggle('hidden', action === 'activate');
            document.getElementById('durationField').classList.toggle('hidden', action !== 'suspend');
            form.action = `/administrator/users/${userId}/action`;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
        function closeActionModal() {
            const modal = document.getElementById('actionModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        function applyFilters() {
            const search = (document.getElementById('searchUsers').value || '').toLowerCase().trim();
            const status = document.getElementById('statusFilter').value;
            const report = document.getElementById('reportFilter').value;
            const role = document.getElementById('roleFilter').value;
            document.querySelectorAll('.user-record').forEach(record => {
                const matchesSearch = !search || record.dataset.search.includes(search);
                const matchesStatus = status === 'all' || record.dataset.status === status;
                const matchesReport = report === 'all' || record.dataset.report === report;
                const matchesRole = role === 'all' || record.dataset.role === role;
                record.style.display = matchesSearch && matchesStatus && matchesReport && matchesRole ? '' : 'none';
            });
        }
        document.getElementById('searchUsers')?.addEventListener('input', applyFilters);
        document.getElementById('statusFilter')?.addEventListener('change', applyFilters);
        document.getElementById('reportFilter')?.addEventListener('change', applyFilters);
        document.getElementById('roleFilter')?.addEventListener('change', applyFilters);
        window.addEventListener('click', function(event) {
            if (event.target.id === 'userModal') closeUserModal();
            if (event.target.id === 'actionModal') closeActionModal();
        });
    </script>
</body>
</html>
