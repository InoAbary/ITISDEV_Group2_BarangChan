                </h2>
                <a href="#" class="text-sm text-amber-600 hover:text-amber-700">View all reported users</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- User Card 1 - Critical Reports -->
                <div class="user-card bg-white rounded-xl shadow-md border-l-4 border-red-600 overflow-hidden">
                    <div class="p-5">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center text-red-600 font-bold text-lg">
                                    JD
                                </div>
                                <div>
                                    <div class="flex items-center gap-2">
                                        <h3 class="font-semibold text-gray-800">Juan Dela Cruz</h3>
                                        <span class="status-active text-xs px-2 py-0.5 rounded-full">Active</span>
                                    </div>
                                    <p class="text-xs text-gray-500">@juandelacruz • Registered Jan 2026</p>
                                    <p class="text-xs text-gray-600 mt-1">juan.dela.cruz@email.com • 0917 123 4567</p>
                                </div>
                            </div>
                            <span class="report-critical px-3 py-1 rounded-full text-xs font-bold">CRITICAL</span>
                        </div>

                        <div class="mt-4 grid grid-cols-3 gap-2 text-center">
                            <div>
                                <p class="text-lg font-bold text-red-600">18</p>
                                <p class="text-xs text-gray-500">Reports</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold text-gray-700">12</p>
                                <p class="text-xs text-gray-500">Posts</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold text-gray-700">5</p>
                                <p class="text-xs text-gray-500">Warnings</p>
                            </div>
                        </div>

                        <!-- Recent Reports -->
                        <div class="mt-4 p-3 bg-red-50 rounded-lg">
                            <p class="text-xs font-semibold text-red-700 mb-2">Recent Reports (last 24h):</p>
                            <ul class="space-y-2">
                                <li class="text-xs flex items-start gap-2">
                                    <i class="fas fa-circle text-red-500 text-[6px] mt-1.5"></i>
                                    <span class="text-gray-700"><span class="font-medium">Harassment:</span> Inappropriate comments on multiple posts</span>
                                </li>
                                <li class="text-xs flex items-start gap-2">
                                    <i class="fas fa-circle text-red-500 text-[6px] mt-1.5"></i>
                                    <span class="text-gray-700"><span class="font-medium">Spam:</span> Repeated posting of advertisements</span>
                                </li>
                                <li class="text-xs flex items-start gap-2">
                                    <i class="fas fa-circle text-red-500 text-[6px] mt-1.5"></i>
                                    <span class="text-gray-700"><span class="font-medium">Misinformation:</span> Spreading false information</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-4 flex items-center gap-2">
                            <button onclick="openUserModal(1001)" class="flex-1 bg-amber-600 hover:bg-amber-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition">
                                <i class="fas fa-eye mr-1"></i> Review
                            </button>
                            <button onclick="showWarning(1001)" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition">
                                <i class="fas fa-exclamation-triangle mr-1"></i> Warn
                            </button>
                            <button onclick="openSuspendModal(1001)" class="flex-1 bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition">
                                <i class="fas fa-ban mr-1"></i> Suspend
                            </button>
                        </div>
                    </div>
                </div>

                <!-- User Card 2 - High Reports -->
                <div class="user-card bg-white rounded-xl shadow-md border-l-4 border-orange-500 overflow-hidden">
                    <div class="p-5">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center text-orange-600 font-bold text-lg">
                                    MS
                                </div>
                                <div>
                                    <div class="flex items-center gap-2">
                                        <h3 class="font-semibold text-gray-800">Maria Santos</h3>
                                        <span class="status-active text-xs px-2 py-0.5 rounded-full">Active</span>
                                    </div>
                                    <p class="text-xs text-gray-500">@maria.santos • Registered Feb 2026</p>
                                    <p class="text-xs text-gray-600 mt-1">maria.santos@email.com • 0918 765 4321</p>
                                </div>
                            </div>
                            <span class="report-high px-3 py-1 rounded-full text-xs font-bold">HIGH</span>
                        </div>

                        <div class="mt-4 grid grid-cols-3 gap-2 text-center">
                            <div>
                                <p class="text-lg font-bold text-orange-600">12</p>
                                <p class="text-xs text-gray-500">Reports</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold text-gray-700">8</p>
                                <p class="text-xs text-gray-500">Posts</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold text-gray-700">2</p>
                                <p class="text-xs text-gray-500">Warnings</p>
                            </div>
                        </div>

                        <!-- Recent Reports -->
                        <div class="mt-4 p-3 bg-orange-50 rounded-lg">
                            <p class="text-xs font-semibold text-orange-700 mb-2">Recent Reports:</p>
                            <ul class="space-y-2">
                                <li class="text-xs flex items-start gap-2">
                                    <i class="fas fa-circle text-orange-500 text-[6px] mt-1.5"></i>
                                    <span class="text-gray-700"><span class="font-medium">Inappropriate content:</span> Offensive language</span>
                                </li>
                                <li class="text-xs flex items-start gap-2">
                                    <i class="fas fa-circle text-orange-500 text-[6px] mt-1.5"></i>
                                    <span class="text-gray-700"><span class="font-medium">Harassment:</span> Targeting specific user</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-4 flex items-center gap-2">
                            <button onclick="openUserModal(1002)" class="flex-1 bg-amber-600 hover:bg-amber-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition">
                                <i class="fas fa-eye mr-1"></i> Review
                            </button>
                            <button onclick="showWarning(1002)" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition">
                                <i class="fas fa-exclamation-triangle mr-1"></i> Warn
                            </button>
                            <button onclick="openSuspendModal(1002)" class="flex-1 bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition">
                                <i class="fas fa-ban mr-1"></i> Suspend
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filipino Pattern Divider -->
        <div class="filipino-divider my-8"></div>

        <!-- All Users Table -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-6 py-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-list"></i>
                    All Users (2,547)
                </h2>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reports</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Active</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <tr class="table-row-hover">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center text-red-600 font-bold text-sm">JD</div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-gray-900">Juan Dela Cruz</p>
                                        <p class="text-xs text-gray-500">juan@email.com</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="bg-gray-100 text-gray-800 px-3 py-1 rounded-full text-xs">Resident</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="status-active px-3 py-1 rounded-full text-xs font-medium">Active</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="report-critical px-3 py-1 rounded-full text-xs font-bold">18</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">2 mins ago</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jan 15, 2026</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <button class="text-amber-600 hover:text-amber-700 mr-2" title="View Details" onclick="openUserModal(1001)">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="text-yellow-600 hover:text-yellow-700 mr-2" title="Send Warning" onclick="showWarning(1001)">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </button>
                                <button class="text-red-600 hover:text-red-700" title="Suspend Account" onclick="openSuspendModal(1001)">
                                    <i class="fas fa-ban"></i>
                                </button>
                            </td>
                        </tr>
                        <tr class="table-row-hover">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="w-8 h-8 bg-orange-100 rounded-full flex items-center justify-center text-orange-600 font-bold text-sm">MS</div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-gray-900">Maria Santos</p>
                                        <p class="text-xs text-gray-500">maria@email.com</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="bg-gray-100 text-gray-800 px-3 py-1 rounded-full text-xs">Resident</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="status-active px-3 py-1 rounded-full text-xs font-medium">Active</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="report-high px-3 py-1 rounded-full text-xs font-bold">12</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">15 mins ago</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Feb 3, 2026</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <button class="text-amber-600 hover:text-amber-700 mr-2"><i class="fas fa-eye"></i></button>
                                <button class="text-yellow-600 hover:text-yellow-700 mr-2"><i class="fas fa-exclamation-triangle"></i></button>
                                <button class="text-red-600 hover:text-red-700"><i class="fas fa-ban"></i></button>
                            </td>
                        </tr>
                        <tr class="table-row-hover">
