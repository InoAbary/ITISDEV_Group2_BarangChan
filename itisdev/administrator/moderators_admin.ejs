    <!-- JavaScript for Manage Moderators Page -->
    <script>
        let currentModId = null;
        let currentAction = null;

        // Promote functions
        function openPromoteModal(modId) {
            currentModId = modId;
            currentAction = 'promote';
            document.getElementById('promoteModal').classList.remove('hidden');
        }

        function closePromoteModal() {
            document.getElementById('promoteModal').classList.add('hidden');
        }

        function confirmPromote() {
            // Here you would make an API call to promote the moderator
            console.log('Promoting moderator:', currentModId);
            showSuccess('Moderator promoted successfully', 'The moderator has been promoted to the new level.');
            closePromoteModal();
        }

        // Demote functions
        function openDemoteModal(modId) {
            currentModId = modId;
            currentAction = 'demote';
            document.getElementById('demoteModal').classList.remove('hidden');
        }

        function closeDemoteModal() {
            document.getElementById('demoteModal').classList.add('hidden');
        }

        function confirmDemote() {
            // Here you would make an API call to demote the moderator
            console.log('Demoting moderator:', currentModId);
            showSuccess('Moderator demoted successfully', 'The moderator has been demoted to the selected level.');
            closeDemoteModal();
        }

        // Deactivate functions
        function openDeactivateModal(modId) {
            currentModId = modId;
            currentAction = 'deactivate';
            document.getElementById('deactivateModal').classList.remove('hidden');
        }

        function closeDeactivateModal() {
            document.getElementById('deactivateModal').classList.add('hidden');
        }

        function confirmDeactivate() {
            // Here you would make an API call to deactivate the moderator
            console.log('Deactivating moderator:', currentModId);
            showSuccess('Moderator deactivated', 'The moderator account has been deactivated successfully.');
            closeDeactivateModal();
        }

        // Add moderator functions
        function openPromoteModal() {
            document.getElementById('addModeratorModal').classList.remove('hidden');
        }

        function closeAddModeratorModal() {
            document.getElementById('addModeratorModal').classList.add('hidden');
        }

        function confirmAddModerator() {
            // Here you would make an API call to add a new moderator
            console.log('Adding new moderator');
            showSuccess('Moderator added', 'New moderator has been added successfully.');
            closeAddModeratorModal();
        }

        // Success toast
        function showSuccess(title, message) {
            document.getElementById('successTitle').textContent = title;
            document.getElementById('successMessage').textContent = message;
            document.getElementById('successToast').classList.remove('hidden');
            
            setTimeout(() => {
                document.getElementById('successToast').classList.add('hidden');
            }, 3000);
        }

        function closeSuccessToast() {
            document.getElementById('successToast').classList.add('hidden');
        }

        // Search functionality
        document.getElementById('searchModerators')?.addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.mod-card');
            const rows = document.querySelectorAll('tbody tr');
            
            cards.forEach(card => {
                const text = card.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Filter functionality
        function applyFilters() {
            const statusFilter = document.getElementById('statusFilter').value;
            const levelFilter = document.getElementById('levelFilter').value;
            
            console.log('Applying filters:', { status: statusFilter, level: levelFilter });
            // Implement actual filtering logic here
        }

        document.getElementById('statusFilter')?.addEventListener('change', applyFilters);
        document.getElementById('levelFilter')?.addEventListener('change', applyFilters);

        // Close modals when clicking outside
        window.addEventListener('click', function(event) {
            const promoteModal = document.getElementById('promoteModal');
            const demoteModal = document.getElementById('demoteModal');
            const deactivateModal = document.getElementById('deactivateModal');
            const addModal = document.getElementById('addModeratorModal');
            
            if (event.target === promoteModal) closePromoteModal();
            if (event.target === demoteModal) closeDemoteModal();
            if (event.target === deactivateModal) closeDeactivateModal();
            if (event.target === addModal) closeAddModeratorModal();
        });

        // Add quick actions for chatbot
        document.addEventListener('DOMContentLoaded', function() {
            const quickActionsContainer = document.getElementById('quickActionsContainer');
            if (quickActionsContainer) {
                quickActionsContainer.innerHTML = `
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How do I promote a moderator?">
                        ⬆️ Promote moderator
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How do I demote a moderator?">
                        ⬇️ Demote moderator
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How to add a new moderator?">
                        ➕ Add moderator
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Show moderator performance">
                        📊 Performance
                    </button>
                `;
            }
        });
