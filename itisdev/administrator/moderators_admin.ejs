<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan - Manage Moderators</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        .mod-card { transition: all 0.2s ease; }
        .mod-card:hover { transform: translateY(-2px); box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
        .status-active { background-color: #dcfce7; color: #166534; }
        .status-inactive { background-color: #fee2e2; color: #991b1b; }
        .position-admin { background-color: #8b5cf6; color: white; }
        .position-moderator { background-color: #2563eb; color: white; }
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">
    <%
        const stats = moderatorStats || { total: 0, active: 0, admins: 0, moderators: 0, inactive: 0 };
        const modList = moderators || [];
        const candidates = candidateUsers || [];
        const adminList = modList.filter(mod => mod.position === 'admin');
    %>

    <%- include('../partials/topnavigation', { currentPath: '/administrator/moderators', currentUser: user }) %>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between gap-4 flex-wrap">
                    <div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-user-shield"></i>
                            Manage Moderators
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm">Administrator and moderator account management.</p>
                    </div>
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-users mr-2"></i>Total: <%= stats.total %>
                        </span>
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-user-check mr-2 text-green-300"></i>Active: <%= stats.active %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
                <p class="text-sm text-gray-500 mb-1">Active Accounts</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.active %></p>
                <p class="text-xs text-green-600 mt-2">Currently available moderation staff</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-purple-500">
                <p class="text-sm text-gray-500 mb-1">Admin Accounts</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.admins %></p>
                <p class="text-xs text-purple-600 mt-2">Full access accounts</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500">
                <p class="text-sm text-gray-500 mb-1">Moderator Accounts</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.moderators %></p>
                <p class="text-xs text-blue-600 mt-2">Standard moderation accounts</p>
            </div>
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-red-500">
                <p class="text-sm text-gray-500 mb-1">Inactive Accounts</p>
                <p class="text-3xl font-bold text-gray-800"><%= stats.inactive %></p>
                <p class="text-xs text-red-600 mt-2">Temporarily unavailable accounts</p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1 relative">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" id="searchModerators" placeholder="Search by name or email..."
                        class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                </div>
                <div class="flex flex-wrap gap-2">
                    <select id="statusFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                    <select id="positionFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all">All Positions</option>
                        <option value="admin">Admin</option>
                        <option value="moderator">Moderator</option>
                    </select>
                    <button type="button" onclick="openAddModeratorModal()" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                        <i class="fas fa-user-plus mr-2"></i>Add Account
                    </button>
                </div>
            </div>
        </div>

        <div class="mb-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-crown text-amber-500"></i>
                    Administrators
                </h2>
                <span class="text-sm text-gray-500"><%= adminList.length %> records</span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <% if (adminList.length) { %>
                    <% adminList.forEach(function(mod) { %>
                        <div class="mod-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden moderator-record"
                             data-search="<%= `${mod.name} ${mod.email}`.toLowerCase() %>"
                             data-status="<%= mod.statusKey %>"
                             data-position="<%= mod.position %>">
                            <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-4 py-3 text-white flex items-center justify-between">
                                <span class="font-semibold">Administrator</span>
                                <i class="fas fa-crown"></i>
                            </div>
                            <div class="p-4">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 font-bold text-lg">
                                        <%= mod.initials %>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-gray-800"><%= mod.name %></h3>
                                        <p class="text-xs text-gray-500"><%= mod.email %></p>
                                    </div>
                                </div>
                                <div class="space-y-2 mb-3 text-sm">
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-600">Handled:</span>
                                        <span class="font-bold text-gray-800"><%= mod.totalHandled %></span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-600">Satisfaction:</span>
                                        <span class="font-bold text-green-600"><%= mod.satisfaction %>%</span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-600">Response Time:</span>
                                        <span class="font-bold text-blue-600"><%= mod.avgResponseTime %></span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2 mb-3 flex-wrap">
                                    <span class="status-<%= mod.statusKey %> text-xs px-2 py-1 rounded-full"><%= mod.statusLabel %></span>
                                    <span class="position-<%= mod.position %> text-xs px-2 py-1 rounded-full"><%= mod.positionLabel %></span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-600">Since <%= mod.createdYear %></span>
                                </div>
                                <div class="flex gap-2">
                                    <button type="button" onclick="openActionModal('demote', <%= mod.user_id %>, '<%- mod.name.replace(/'/g, "\\'") %>')"
                                        class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white px-3 py-2 rounded-lg text-xs font-medium transition">
                                        <i class="fas fa-arrow-down mr-1"></i>Demote
                                    </button>
                                    <button type="button" onclick="openActionModal('deactivate', <%= mod.user_id %>, '<%- mod.name.replace(/'/g, "\\'") %>')"
                                        class="flex-1 bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded-lg text-xs font-medium transition">
                                        <i class="fas fa-ban mr-1"></i>Deactivate
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full bg-white rounded-xl border border-dashed border-gray-300 p-8 text-center text-gray-500">
                        No administrator accounts available.
                    </div>
                <% } %>
            </div>
        </div>

        <div class="filipino-divider my-8"></div>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-6 py-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-list"></i>
                    All Accounts
                </h2>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Position</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Handled</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Satisfaction</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Response Time</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Active</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% if (modList.length) { %>
                            <% modList.forEach(function(mod) { %>
                                <tr class="moderator-record hover:bg-gray-50"
                                    data-search="<%= `${mod.name} ${mod.email}`.toLowerCase() %>"
                                    data-status="<%= mod.statusKey %>"
                                    data-position="<%= mod.position %>">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 font-bold text-sm"><%= mod.initials %></div>
                                            <div class="ml-3">
                                                <p class="text-sm font-medium text-gray-900"><%= mod.name %></p>
                                                <p class="text-xs text-gray-500"><%= mod.email %></p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="position-<%= mod.position %> px-3 py-1 rounded-full text-xs font-medium"><%= mod.positionLabel %></span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="status-<%= mod.statusKey %> px-3 py-1 rounded-full text-xs font-medium"><%= mod.statusLabel %></span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= mod.totalHandled %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-medium"><%= mod.satisfaction %>%</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= mod.avgResponseTime %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= mod.lastActiveLabel %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <% if (!mod.isAdmin) { %>
                                            <button type="button" class="text-green-600 hover:text-green-700 mr-3" title="Promote to Admin"
                                                onclick="openActionModal('promote', <%= mod.user_id %>, '<%- mod.name.replace(/'/g, "\\'") %>')">
                                                <i class="fas fa-arrow-up"></i>
                                            </button>
                                        <% } %>
                                        <button type="button" class="text-yellow-600 hover:text-yellow-700 mr-3" title="Demote"
                                            onclick="openActionModal('demote', <%= mod.user_id %>, '<%- mod.name.replace(/'/g, "\\'") %>')">
                                            <i class="fas fa-arrow-down"></i>
                                        </button>
                                        <button type="button" class="text-red-600 hover:text-red-700" title="Deactivate"
                                            onclick="openActionModal('deactivate', <%= mod.user_id %>, '<%- mod.name.replace(/'/g, "\\'") %>')">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="px-6 py-8 text-center text-gray-500">No moderator or admin accounts found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 text-sm text-gray-500">
                Showing <%= modList.length %> account<%= modList.length === 1 ? '' : 's' %>
            </div>
        </div>
    </main>

    <div id="actionModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
            <form id="actionForm" method="POST">
                <div id="actionModalHeader" class="p-6 text-white rounded-t-2xl bg-amber-600">
                    <h3 id="actionModalTitle" class="text-xl font-bold flex items-center gap-2"></h3>
                </div>
                <div class="p-6">
                    <p class="text-gray-700 mb-4">Update account for <span class="font-bold" id="actionUserName"></span>.</p>
                    <input type="hidden" name="action" id="actionTypeInput">

                    <div id="roleField" class="mb-4 hidden">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Target Position</label>
                        <select id="roleInput" name="role" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent"></select>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Notes</label>
                        <textarea name="note" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent" placeholder="Optional context for the action log"></textarea>
                    </div>

                    <div class="flex items-center gap-3">
                        <button type="button" onclick="closeActionModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                        <button id="actionSubmitButton" type="submit" class="flex-1 px-4 py-2 text-white rounded-lg transition bg-amber-600 hover:bg-amber-700">Confirm</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div id="addModeratorModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4">
            <form action="/administrator/moderators/add" method="POST">
                <div class="bg-gradient-to-r from-blue-900 to-amber-800 p-6 text-white rounded-t-2xl">
                    <h3 class="text-xl font-bold flex items-center gap-2">
                        <i class="fas fa-user-plus"></i>
                        Add Account
                    </h3>
                </div>
                <div class="p-6">
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Select Resident</label>
                        <select name="user_id" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400">
                            <option value="">Choose a resident...</option>
                            <% candidates.forEach(function(candidate) { %>
                                <option value="<%= candidate.user_id %>"><%= candidate.name %> (<%= candidate.email %>)</option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Position</label>
                        <select name="role" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400">
                            <option value="moderator" selected>Moderator</option>
                            <option value="administrator">Admin</option>
                        </select>
                    </div>

                    <div class="flex items-center gap-3">
                        <button type="button" onclick="closeAddModeratorModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Cancel</button>
                        <button type="submit" class="flex-1 px-4 py-2 bg-gradient-to-r from-amber-600 to-amber-700 text-white rounded-lg hover:from-amber-700 hover:to-amber-800 transition">
                            <i class="fas fa-user-plus mr-2"></i>Add Account
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/chatbot') %>
    <%- include('../partials/footer') %>

    <script>
        const actionConfig = {
            promote: {
                title: 'Promote to Admin',
                icon: 'fa-arrow-up',
                headerClass: 'bg-green-600',
                buttonClass: 'bg-green-600 hover:bg-green-700',
                submitText: 'Confirm Promote',
                options: [{ value: 'administrator', label: 'Admin' }],
                showRole: true
            },
            demote: {
                title: 'Demote Account',
                icon: 'fa-arrow-down',
                headerClass: 'bg-yellow-600',
                buttonClass: 'bg-yellow-600 hover:bg-yellow-700',
                submitText: 'Confirm Demote',
                options: [
                    { value: 'moderator', label: 'Moderator' },
                    { value: 'resident', label: 'Resident User' }
                ],
                showRole: true
            },
            deactivate: {
                title: 'Deactivate Account',
                icon: 'fa-ban',
                headerClass: 'bg-red-600',
                buttonClass: 'bg-red-600 hover:bg-red-700',
                submitText: 'Confirm Deactivate',
                options: [],
                showRole: false
            }
        };

        function openAddModeratorModal() {
            const modal = document.getElementById('addModeratorModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeAddModeratorModal() {
            const modal = document.getElementById('addModeratorModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openActionModal(action, userId, userName) {
            const config = actionConfig[action];
            if (!config) return;

            const modal = document.getElementById('actionModal');
            const form = document.getElementById('actionForm');
            const header = document.getElementById('actionModalHeader');
            const title = document.getElementById('actionModalTitle');
            const submitButton = document.getElementById('actionSubmitButton');
            const roleField = document.getElementById('roleField');
            const roleInput = document.getElementById('roleInput');

            form.action = `/administrator/moderators/${userId}/update`;
            document.getElementById('actionTypeInput').value = action;
            document.getElementById('actionUserName').textContent = userName;

            header.className = `p-6 text-white rounded-t-2xl ${config.headerClass}`;
            submitButton.className = `flex-1 px-4 py-2 text-white rounded-lg transition ${config.buttonClass}`;
            submitButton.textContent = config.submitText;
            title.innerHTML = `<i class="fas ${config.icon}"></i>${config.title}`;

            roleInput.innerHTML = '';
            if (config.showRole) {
                roleField.classList.remove('hidden');
                config.options.forEach(option => {
                    const element = document.createElement('option');
                    element.value = option.value;
                    element.textContent = option.label;
                    roleInput.appendChild(element);
                });
            } else {
                roleField.classList.add('hidden');
            }

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeActionModal() {
            const modal = document.getElementById('actionModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function applyFilters() {
            const searchValue = (document.getElementById('searchModerators').value || '').toLowerCase().trim();
            const statusValue = document.getElementById('statusFilter').value;
            const positionValue = document.getElementById('positionFilter').value;

            document.querySelectorAll('.moderator-record').forEach(record => {
                const matchesSearch = !searchValue || record.dataset.search.includes(searchValue);
                const matchesStatus = statusValue === 'all' || record.dataset.status === statusValue;
                const matchesPosition = positionValue === 'all' || record.dataset.position === positionValue;
                record.style.display = matchesSearch && matchesStatus && matchesPosition ? '' : 'none';
            });
        }

        document.getElementById('searchModerators')?.addEventListener('input', applyFilters);
        document.getElementById('statusFilter')?.addEventListener('change', applyFilters);
        document.getElementById('positionFilter')?.addEventListener('change', applyFilters);

        window.addEventListener('click', function(event) {
            if (event.target.id === 'actionModal') closeActionModal();
            if (event.target.id === 'addModeratorModal') closeAddModeratorModal();
        });
    </script>
</body>
</html>
