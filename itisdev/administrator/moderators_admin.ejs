<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Manage Moderators</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        /* Moderator card hover effects */
        .mod-card {
            transition: all 0.2s ease;
        }
        .mod-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        /* Status badges */
        .status-active { background-color: #dcfce7; color: #166534; border-left: 3px solid #16a34a; }
        .status-inactive { background-color: #fee2e2; color: #991b1b; border-left: 3px solid #dc2626; }
        .status-on-leave { background-color: #fff3e0; color: #9a3412; border-left: 3px solid #ea580c; }
        .status-training { background-color: #e0f2fe; color: #075985; border-left: 3px solid #0284c7; }

        /* Level badges */
        .level-senior { background-color: #8b5cf6; color: white; }
        .level-junior { background-color: #3b82f6; color: white; }
        .level-trainee { background-color: #9ca3af; color: white; }

        /* Performance indicators */
        .perf-excellent { color: #16a34a; }
        .perf-good { color: #ca8a04; }
        .perf-needs-improvement { color: #dc2626; }

        /* Filipino pattern */
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }

        /* Table row hover */
        .table-row-hover:hover {
            background-color: #f9fafb;
        }

        /* Action buttons */
        .action-btn {
            transition: all 0.2s ease;
        }
        .action-btn:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

