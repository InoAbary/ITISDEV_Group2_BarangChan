<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="bg-gray-50">
    <%- include('../partials/topnavigation', { currentPath: '/client/requests', currentUser: user }) %>

    <main class="max-w-7xl mx-auto px-4 py-6">
        <!-- Back button -->
        <div class="mb-4">
            <a href="/client/requests" class="text-amber-600 hover:text-amber-700">
                <i class="fas fa-arrow-left mr-2"></i>Back to Requests
            </a>
        </div>

        <!-- Request Details -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <!-- Header -->
            <div class="bg-gradient-to-r from-blue-900 to-amber-800 px-6 py-4">
                <div class="flex justify-between items-start">
                    <div>
                        <h1 class="text-2xl font-bold text-white">Request Details</h1>
                        <p class="text-amber-100">Reference: REQ-<%= request.request_id %>-2026</p>
                    </div>
                    <span class="px-3 py-1 rounded-full text-sm font-semibold
                        <%= request.status === 'Pending' ? 'bg-yellow-200 text-yellow-800' : 
                           request.status === 'Accepted' ? 'bg-blue-200 text-blue-800' :
                           request.status === 'Cancelled' ? 'bg-red-200 text-red-800' : 
                           'bg-green-200 text-green-800' %>">
                        <%= request.status %>
                    </span>
                </div>
            </div>

            <!-- Content -->
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Main Details -->
                    <div class="md:col-span-2 space-y-6">
                        <!-- Document Request -->
                        <div>
                            <h3 class="font-semibold text-gray-700 mb-2">Document Request</h3>
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <p class="text-gray-700 whitespace-pre-line"><%= request.document_request %></p>
                            </div>
                        </div>

                        <!-- Files -->
                        <% if (files && files.length > 0) { %>
                        <div>
                            <h3 class="font-semibold text-gray-700 mb-2">Uploaded Files</h3>
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                                <% files.forEach(file => { %>
                                <a href="<%= file.file_path %>" target="_blank" 
                                   class="bg-gray-50 p-3 rounded-lg hover:bg-gray-100">
                                    <i class="fas fa-file text-amber-600 mr-2"></i>
                                    <%= file.original_name %>
                                </a>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>

                        <!-- Status Timeline -->
                        <div>
                            <h3 class="font-semibold text-gray-700 mb-2">Status Timeline</h3>
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <div class="space-y-3">
                                    <div class="flex items-start gap-3">
                                        <div class="w-6 h-6 bg-green-200 rounded-full flex items-center justify-center text-green-700 text-xs">✓</div>
                                        <div>
                                            <p class="text-sm font-medium">Request Submitted</p>
                                            <p class="text-xs text-gray-500"><%= formatDate(request.request_date) %></p>
                                        </div>
                                    </div>
                                    <% if (request.status !== 'Pending') { %>
                                    <div class="flex items-start gap-3">
                                        <div class="w-6 h-6 bg-blue-200 rounded-full flex items-center justify-center text-blue-700 text-xs">⚡</div>
                                        <div>
                                            <p class="text-sm font-medium">Status Updated to <%= request.status %></p>
                                            <p class="text-xs text-gray-500">Recent</p>
                                        </div>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <div class="space-y-4">
                        <div class="bg-gray-50 p-4 rounded-lg">
                            <h4 class="font-semibold text-gray-700 mb-3">Request Info</h4>
                            <div class="space-y-2 text-sm">
                                <p><span class="text-gray-500">Requested:</span> <%= formatDate(request.request_date) %></p>
                                <p><span class="text-gray-500">Estimated Release:</span> <%= calculateEstimatedRelease(request.request_date, request.document_request) %></p>
                                <p><span class="text-gray-500">Requestor:</span> <%= request.name %></p>
                                <p><span class="text-gray-500">Contact:</span> <%= request.email %></p>
                                <p><span class="text-gray-500">Phone:</span> <%= request.phone %></p>
                            </div>
                        </div>

                        <div class="bg-gray-50 p-4 rounded-lg">
                            <h4 class="font-semibold text-gray-700 mb-3">Delivery Address</h4>
                            <p class="text-sm"><%= request.address %></p>
                        </div>

                        <% if (request.status === 'Pending') { %>
                        <button onclick="cancelRequest(<%= request.request_id %>)" 
                                class="w-full bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition">
                            <i class="fas fa-times mr-2"></i>Cancel Request
                        </button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        
        function cancelRequest(requestId) {
            if (confirm('Are you sure you want to cancel this request?')) {
                fetch(`/client/requests/${requestId}/cancel`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('Request cancelled successfully');
                        window.location.reload();
                    } else {
                        alert('Failed to cancel request');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Error cancelling request');
                });
            }
        }
    </script>
</body>
</html>