<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Government Forms</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }
        /* Form card hover effect */
        .form-card {
            transition: all 0.2s ease;
        }
        .form-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: #fbbf24;
        }
        /* Category tabs */
        .category-tab {
            transition: all 0.2s ease;
        }
        .category-tab.active {
            background-color: #d97706;
            color: white;
        }
        /* Filipino pattern divider */
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }
        /* Download button animation */
        .download-btn {
            transition: all 0.2s ease;
        }
        .download-btn:hover {
            transform: scale(1.05);
        }
        /* Form type badges */
        .badge-pdf { background-color: #fee2e2; color: #b91c1c; }
        .badge-doc { background-color: #e0f2fe; color: #0369a1; }
        .badge-xls { background-color: #dcfce7; color: #166534; }
        .badge-other { background-color: #f3e8ff; color: #6b21a8; }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col" data-page-context="govforms">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/client/govforms', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header with Philippine Flag Colors -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-file-alt"></i> 
                            Government Forms
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm">
                            <i class="fas fa-download mr-1"></i> 
                            Libreng pag-download ng mga form ng gobyerno (Free download of government forms)
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-file-pdf mr-2"></i>24 forms available
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search and Filter Bar -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1 relative">
                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    <input type="text" id="searchForms" placeholder="Search for forms (e.g., clearance, birth certificate, permit)..." 
                           class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                </div>
                <div class="flex gap-2">
                    <select id="categoryFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all">All Categories</option>
                        <option value="barangay">Barangay Forms</option>
                        <option value="national">National Government</option>
                        <option value="psa">PSA/Statistics</option>
                        <option value="bpls">Business Permits</option>
                        <option value="social">Social Services</option>
                    </select>
                    <select id="formatFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all">All Formats</option>
                        <option value="pdf">PDF</option>
                        <option value="doc">Word Document</option>
                        <option value="xls">Excel Spreadsheet</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Quick Access Categories -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3 mb-8">
            <button onclick="filterCategory('barangay')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-home text-amber-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Barangay</span>
            </button>
            <button onclick="filterCategory('national')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-landmark text-blue-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">National</span>
            </button>
            <button onclick="filterCategory('psa')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-id-card text-green-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">PSA</span>
            </button>
            <button onclick="filterCategory('bpls')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-store text-purple-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Business</span>
            </button>
            <button onclick="filterCategory('social')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-hand-holding-heart text-red-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Social</span>
            </button>
            <button onclick="filterCategory('education')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-graduation-cap text-indigo-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Education</span>
            </button>
            <button onclick="filterCategory('health')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-hospital text-pink-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Health</span>
            </button>
            <button onclick="filterCategory('others')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-ellipsis-h text-gray-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Others</span>
            </button>
        </div>

        <!-- Featured/Recent Forms -->
        <div class="mb-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-star text-amber-500"></i>
                    Featured Forms
                </h2>
                <a href="#" class="text-sm text-amber-600 hover:text-amber-700">View All <i class="fas fa-arrow-right ml-1"></i></a>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Featured Form 1 - Barangay Clearance -->
                <div class="form-card bg-white rounded-xl shadow-md border-2 border-amber-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-4 py-2 text-white flex items-center justify-between">
                        <span class="font-semibold text-sm">⭐ MOST POPULAR</span>
                        <i class="fas fa-crown"></i>
                    </div>
                    <div class="p-5">
                        <div class="flex items-start gap-3 mb-3">
                            <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-id-card text-amber-600 text-2xl"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800">Barangay Clearance Form</h3>
                                <p class="text-xs text-gray-500">Form ID: BC-FRM-001</p>
                            </div>
                        </div>
                        <p class="text-sm text-gray-600 mb-3">Standard application form for Barangay Clearance certificate.</p>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                                <span class="text-xs text-gray-500">250KB</span>
                            </div>
                            <a href="/downloads/barangay-clearance-form.pdf" class="download-btn bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2">
                                <i class="fas fa-download"></i> Download
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Featured Form 2 - PSA Birth Certificate -->
                <div class="form-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="p-5">
                        <div class="flex items-start gap-3 mb-3">
                            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-baby text-blue-600 text-2xl"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800">PSA Birth Certificate Application</h3>
                                <p class="text-xs text-gray-500">Form ID: PSA-BC-001</p>
                            </div>
                        </div>
                        <p class="text-sm text-gray-600 mb-3">Application form for PSA Birth Certificate request.</p>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                                <span class="text-xs text-gray-500">180KB</span>
                            </div>
                            <a href="/downloads/psa-birth-certificate.pdf" class="download-btn bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2">
                                <i class="fas fa-download"></i> Download
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Featured Form 3 - Business Permit -->
                <div class="form-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="p-5">
                        <div class="flex items-start gap-3 mb-3">
                            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-store text-green-600 text-2xl"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800">Business Permit Application</h3>
                                <p class="text-xs text-gray-500">Form ID: BP-FRM-002</p>
                            </div>
                        </div>
                        <p class="text-sm text-gray-600 mb-3">Complete application form for Business Permit / Mayor's Permit.</p>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="badge-doc text-xs px-2 py-1 rounded-full">DOC</span>
                                <span class="text-xs text-gray-500">350KB</span>
                            </div>
                            <a href="/downloads/business-permit-form.doc" class="download-btn bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2">
                                <i class="fas fa-download"></i> Download
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filipino Pattern Divider -->
        <div class="filipino-divider my-8"></div>

        <!-- All Forms Grid by Category -->
        <div class="space-y-8">
            <!-- Barangay Forms Section -->
            <div id="section-barangay">
                <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <i class="fas fa-home text-amber-600"></i>
                    Barangay Forms
                    <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded-full">8 forms</span>
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <!-- Barangay Clearance -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-id-card text-amber-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">Barangay Clearance</h3>
                                    <p class="text-xs text-gray-500">BC-FRM-001 • Updated Mar 2026</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-amber-600 mr-1"></i>250KB</span>
                            <a href="#" class="text-amber-600 hover:text-amber-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- Certificate of Indigency -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-file-contract text-blue-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">Certificate of Indigency</h3>
                                    <p class="text-xs text-gray-500">CI-FRM-002 • Updated Mar 2026</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-blue-600 mr-1"></i>180KB</span>
                            <a href="#" class="text-blue-600 hover:text-blue-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- Barangay ID Application -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-id-badge text-purple-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">Barangay ID Application</h3>
                                    <p class="text-xs text-gray-500">BID-FRM-003 • Updated Feb 2026</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-purple-600 mr-1"></i>220KB</span>
                            <a href="#" class="text-purple-600 hover:text-purple-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- Barangay Clearance (Tagalog Version) -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-language text-amber-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">Barangay Clearance (Tagalog)</h3>
                                    <p class="text-xs text-gray-500">BC-FRM-001-TG • Updated Mar 2026</p>
                                </div>
                            </div>
                            <span class="badge-doc text-xs px-2 py-1 rounded-full">DOC</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-amber-600 mr-1"></i>195KB</span>
                            <a href="#" class="text-amber-600 hover:text-amber-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- Cedula Application -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-receipt text-yellow-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">Community Tax Certificate (Cedula)</h3>
                                    <p class="text-xs text-gray-500">CTC-FRM-004 • Updated Jan 2026</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-yellow-600 mr-1"></i>150KB</span>
                            <a href="#" class="text-yellow-600 hover:text-yellow-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- Residency Certificate -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-map-pin text-green-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">Certificate of Residency</h3>
                                    <p class="text-xs text-gray-500">CR-FRM-005 • Updated Mar 2026</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-green-600 mr-1"></i>165KB</span>
                            <a href="#" class="text-green-600 hover:text-green-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- National Government Forms -->
            <div id="section-national">
                <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <i class="fas fa-landmark text-blue-600"></i>
                    National Government Forms
                    <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded-full">6 forms</span>
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <!-- PSA Birth Certificate -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-baby text-blue-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">PSA Birth Certificate Form</h3>
                                    <p class="text-xs text-gray-500">PSA-BC-001 • Updated Dec 2025</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-blue-600 mr-1"></i>180KB</span>
                            <a href="#" class="text-blue-600 hover:text-blue-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- PSA Marriage Certificate -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-heart text-pink-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">PSA Marriage Certificate Form</h3>
                                    <p class="text-xs text-gray-500">PSA-MC-001 • Updated Dec 2025</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-pink-600 mr-1"></i>190KB</span>
                            <a href="#" class="text-pink-600 hover:text-pink-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
                            </a>
                        </div>
                    </div>

                    <!-- PSA Death Certificate -->
                    <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-cross text-gray-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-800">PSA Death Certificate Form</h3>
                                    <p class="text-xs text-gray-500">PSA-DC-001 • Updated Dec 2025</p>
                                </div>
                            </div>
                            <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-gray-500"><i class="fas fa-file text-gray-600 mr-1"></i>175KB</span>
                            <a href="#" class="text-gray-600 hover:text-gray-700 text-sm font-medium">
                                <i class="fas fa-download mr-1"></i> Download
