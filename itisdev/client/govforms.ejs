<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Government Forms</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }
        /* Form card hover effect */
        .form-card {
            transition: all 0.2s ease;
        }
        .form-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: #fbbf24;
        }
        /* Category tabs */
        .category-tab {
            transition: all 0.2s ease;
        }
        .category-tab.active {
            background-color: #d97706;
            color: white;
        }
        /* Filipino pattern divider */
        .filipino-divider {
            background: linear-gradient(90deg, transparent, #fbbf24, #2563eb, #fbbf24, transparent);
            height: 2px;
            width: 100%;
        }
        /* Download button animation */
        .download-btn {
            transition: all 0.2s ease;
        }
        .download-btn:hover {
            transform: scale(1.05);
        }
        /* Form type badges */
        .badge-pdf { background-color: #fee2e2; color: #b91c1c; }
        .badge-doc { background-color: #e0f2fe; color: #0369a1; }
        .badge-xls { background-color: #dcfce7; color: #166534; }
        .badge-other { background-color: #f3e8ff; color: #6b21a8; }
        /* Loading spinner */
        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #fbbf24;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col" data-page-context="govforms">

    <%
        // Helper function for form icons
        function getFormIcon(category) {
            const icons = {
                'barangay': 'home',
                'national': 'landmark',
                'psa': 'id-card',
                'bpls': 'store',
                'social': 'hand-holding-heart',
                'education': 'graduation-cap',
                'health': 'hospital',
                'others': 'file-alt'
            };
            return icons[category] || 'file-alt';
        }

        // Helper function for badge colors
        function getBadgeClass(fileType) {
            const type = fileType ? fileType.toLowerCase() : 'other';
            const badges = {
                'pdf': 'badge-pdf',
                'doc': 'badge-doc',
                'docx': 'badge-doc',
                'xls': 'badge-xls',
                'xlsx': 'badge-xls',
                'other': 'badge-other'
            };
            return badges[type] || badges['other'];
        }
    %>

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/client/govforms', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header with Philippine Flag Colors -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-file-alt"></i> 
                            Government Forms
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm">
                            <i class="fas fa-download mr-1"></i> 
                            Libreng pag-download ng mga form ng gobyerno (Free download of government forms)
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-file-pdf mr-2"></i><%= categoryCounts.total || 24 %> forms available
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>

        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Search and Filter Bar -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1 relative">
                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    <input type="text" id="searchForms" placeholder="Search for forms (e.g., clearance, birth certificate, permit)..." 
                           class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                </div>
                <div class="flex gap-2">
                    <select id="categoryFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all">All Categories</option>
                        <option value="barangay">Barangay Forms (<%= categoryCounts.barangay || 0 %>)</option>
                        <option value="national">National Government (<%= categoryCounts.national || 0 %>)</option>
                        <option value="psa">PSA/Statistics (<%= categoryCounts.psa || 0 %>)</option>
                        <option value="bpls">Business Permits (<%= categoryCounts.bpls || 0 %>)</option>
                        <option value="social">Social Services (<%= categoryCounts.social || 0 %>)</option>
                        <option value="education">Education (<%= categoryCounts.education || 0 %>)</option>
                        <option value="health">Health (<%= categoryCounts.health || 0 %>)</option>
                        <option value="others">Others (<%= categoryCounts.others || 0 %>)</option>
                    </select>
                    <select id="formatFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-amber-400">
                        <option value="all">All Formats</option>
                        <option value="pdf">PDF</option>
                        <option value="doc">Word Document</option>
                        <option value="xls">Excel Spreadsheet</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Quick Access Categories -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3 mb-8">
            <button onclick="filterCategory('barangay')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-home text-amber-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Barangay</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.barangay || 0 %></span>
            </button>
            <button onclick="filterCategory('national')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-landmark text-blue-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">National</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.national || 0 %></span>
            </button>
            <button onclick="filterCategory('psa')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-id-card text-green-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">PSA</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.psa || 0 %></span>
            </button>
            <button onclick="filterCategory('bpls')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-store text-purple-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Business</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.bpls || 0 %></span>
            </button>
            <button onclick="filterCategory('social')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-hand-holding-heart text-red-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Social</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.social || 0 %></span>
            </button>
            <button onclick="filterCategory('education')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-graduation-cap text-indigo-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Education</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.education || 0 %></span>
            </button>
            <button onclick="filterCategory('health')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-hospital text-pink-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Health</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.health || 0 %></span>
            </button>
            <button onclick="filterCategory('others')" class="category-tab bg-white hover:bg-amber-50 p-3 rounded-xl shadow-sm border border-gray-200 text-center">
                <i class="fas fa-ellipsis-h text-gray-600 text-xl mb-1"></i>
                <span class="text-xs font-medium block">Others</span>
                <span class="text-xs text-gray-500"><%= categoryCounts.others || 0 %></span>
            </button>
        </div>

        <!-- Loading Indicator for AJAX searches -->
        <div id="searchLoading" class="hidden text-center py-4">
            <div class="spinner mx-auto"></div>
            <p class="text-sm text-gray-500 mt-2">Searching forms...</p>
        </div>

        <!-- Featured/Recent Forms -->
        <div class="mb-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-star text-amber-500"></i>
                    Featured Forms
                </h2>
                <a href="#" class="text-sm text-amber-600 hover:text-amber-700">View All <i class="fas fa-arrow-right ml-1"></i></a>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4" id="featuredFormsContainer">
                <% if (featuredForms && featuredForms.length > 0) { %>
                    <% featuredForms.slice(0, 3).forEach(form => { %>
                        <div class="form-card bg-white rounded-xl shadow-md border-2 <%= form.is_featured ? 'border-amber-200' : 'border-gray-200' %> overflow-hidden" data-form-id="<%= form.form_id %>">
                            <% if (form.is_featured) { %>
                            <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-4 py-2 text-white flex items-center justify-between">
                                <span class="font-semibold text-sm">⭐ MOST POPULAR</span>
                                <i class="fas fa-crown"></i>
                            </div>
                            <% } %>
                            <div class="p-5">
                                <div class="flex items-start gap-3 mb-3">
                                    <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center">
                                        <i class="fas fa-<%= getFormIcon(form.category) %> text-amber-600 text-2xl"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800"><%= form.title %></h3>
                                        <p class="text-xs text-gray-500">Form ID: <%= form.form_code || 'FRM-'+form.form_id %></p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-3"><%= form.description %></p>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="<%= getBadgeClass(form.file_type) %> text-xs px-2 py-1 rounded-full">
                                            <%= form.file_type %>
                                        </span>
                                        <span class="text-xs text-gray-500"><%= form.file_size %>KB</span>
                                    </div>
                                    <a href="/client/govforms/download/<%= form.form_id %>" 
                                       class="download-btn bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2"
                                       onclick="trackDownload('<%= form.title %>')">
                                        <i class="fas fa-download"></i> Download
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <!-- Fallback to hardcoded featured forms if no data -->
                    <div class="form-card bg-white rounded-xl shadow-md border-2 border-amber-200 overflow-hidden">
                        <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-4 py-2 text-white flex items-center justify-between">
                            <span class="font-semibold text-sm">⭐ MOST POPULAR</span>
                            <i class="fas fa-crown"></i>
                        </div>
                        <div class="p-5">
                            <div class="flex items-start gap-3 mb-3">
                                <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center">
                                    <i class="fas fa-id-card text-amber-600 text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-800">Barangay Clearance Form</h3>
                                    <p class="text-xs text-gray-500">Form ID: BC-FRM-001</p>
                                </div>
                            </div>
                            <p class="text-sm text-gray-600 mb-3">Standard application form for Barangay Clearance certificate.</p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                                    <span class="text-xs text-gray-500">250KB</span>
                                </div>
                                <a href="/client/govforms/download/1" class="download-btn bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2">
                                    <i class="fas fa-download"></i> Download
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="form-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                        <div class="p-5">
                            <div class="flex items-start gap-3 mb-3">
                                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                                    <i class="fas fa-baby text-blue-600 text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-800">PSA Birth Certificate Application</h3>
                                    <p class="text-xs text-gray-500">Form ID: PSA-BC-001</p>
                                </div>
                            </div>
                            <p class="text-sm text-gray-600 mb-3">Application form for PSA Birth Certificate request.</p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <span class="badge-pdf text-xs px-2 py-1 rounded-full">PDF</span>
                                    <span class="text-xs text-gray-500">180KB</span>
                                </div>
                                <a href="/client/govforms/download/2" class="download-btn bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2">
                                    <i class="fas fa-download"></i> Download
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="form-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                        <div class="p-5">
                            <div class="flex items-start gap-3 mb-3">
                                <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                                    <i class="fas fa-store text-green-600 text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-800">Business Permit Application</h3>
                                    <p class="text-xs text-gray-500">Form ID: BP-FRM-002</p>
                                </div>
                            </div>
                            <p class="text-sm text-gray-600 mb-3">Complete application form for Business Permit / Mayor's Permit.</p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <span class="badge-doc text-xs px-2 py-1 rounded-full">DOC</span>
                                    <span class="text-xs text-gray-500">350KB</span>
                                </div>
                                <a href="/client/govforms/download/3" class="download-btn bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center gap-2">
                                    <i class="fas fa-download"></i> Download
                                </a>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Filipino Pattern Divider -->
        <div class="filipino-divider my-8"></div>

        <!-- Search Results Message (for AJAX search) -->
        <div id="searchResultsMessage" class="hidden mb-4 p-4 bg-blue-50 rounded-lg text-blue-700"></div>

        <!-- All Forms Grid by Category -->
        <div id="allFormsContainer">
            <% if (formsByCategory && Object.keys(formsByCategory).length > 0) { %>
                <!-- Barangay Forms Section -->
                <% if (formsByCategory.barangay && formsByCategory.barangay.length > 0) { %>
                <div id="section-barangay" class="mb-8">
                    <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
                        <i class="fas fa-home text-amber-600"></i>
                        Barangay Forms
                        <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded-full"><%= formsByCategory.barangay.length %> forms</span>
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <% formsByCategory.barangay.forEach(form => { %>
                            <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4" data-form-id="<%= form.form_id %>">
                                <div class="flex items-start justify-between">
                                    <div class="flex items-start gap-3">
                                        <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-<%= getFormIcon(form.category) %> text-amber-600"></i>
                                        </div>
                                        <div>
                                            <h3 class="font-semibold text-gray-800"><%= form.title %></h3>
                                            <p class="text-xs text-gray-500"><%= form.form_code || 'FRM-'+form.form_id %> • Updated <%= new Date(form.last_updated).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></p>
                                        </div>
                                    </div>
                                    <span class="<%= getBadgeClass(form.file_type) %> text-xs px-2 py-1 rounded-full"><%= form.file_type %></span>
                                </div>
                                <div class="mt-3 flex items-center justify-between">
                                    <span class="text-xs text-gray-500"><i class="fas fa-file text-amber-600 mr-1"></i><%= form.file_size %>KB</span>
                                    <a href="/client/govforms/download/<%= form.form_id %>" class="text-amber-600 hover:text-amber-700 text-sm font-medium" onclick="trackDownload('<%= form.title %>')">
                                        <i class="fas fa-download mr-1"></i> Download
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <!-- National Government Forms Section -->
                <% if (formsByCategory.national && formsByCategory.national.length > 0) { %>
                <div id="section-national" class="mb-8">
                    <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
                        <i class="fas fa-landmark text-blue-600"></i>
                        National Government Forms
                        <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded-full"><%= formsByCategory.national.length %> forms</span>
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <% formsByCategory.national.forEach(form => { %>
                            <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4" data-form-id="<%= form.form_id %>">
                                <div class="flex items-start justify-between">
                                    <div class="flex items-start gap-3">
                                        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-<%= getFormIcon(form.category) %> text-blue-600"></i>
                                        </div>
                                        <div>
                                            <h3 class="font-semibold text-gray-800"><%= form.title %></h3>
                                            <p class="text-xs text-gray-500"><%= form.form_code || 'FRM-'+form.form_id %> • Updated <%= new Date(form.last_updated).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></p>
                                        </div>
                                    </div>
                                    <span class="<%= getBadgeClass(form.file_type) %> text-xs px-2 py-1 rounded-full"><%= form.file_type %></span>
                                </div>
                                <div class="mt-3 flex items-center justify-between">
                                    <span class="text-xs text-gray-500"><i class="fas fa-file text-blue-600 mr-1"></i><%= form.file_size %>KB</span>
                                    <a href="/client/govforms/download/<%= form.form_id %>" class="text-blue-600 hover:text-blue-700 text-sm font-medium" onclick="trackDownload('<%= form.title %>')">
                                        <i class="fas fa-download mr-1"></i> Download
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <!-- PSA Forms Section -->
                <% if (formsByCategory.psa && formsByCategory.psa.length > 0) { %>
                <div id="section-psa" class="mb-8">
                    <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
                        <i class="fas fa-id-card text-green-600"></i>
                        PSA/Statistics Forms
                        <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded-full"><%= formsByCategory.psa.length %> forms</span>
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <% formsByCategory.psa.forEach(form => { %>
                            <div class="form-card bg-white rounded-xl shadow-sm border border-gray-200 p-4" data-form-id="<%= form.form_id %>">
                                <div class="flex items-start justify-between">
                                    <div class="flex items-start gap-3">
                                        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-<%= getFormIcon(form.category) %> text-green-600"></i>
                                        </div>
                                        <div>
                                            <h3 class="font-semibold text-gray-800"><%= form.title %></h3>
