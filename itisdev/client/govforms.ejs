    <!-- JavaScript for Forms Page -->
    <script>
        // Track downloads
        function trackDownload(formName) {
            console.log(`Download started: ${formName}`);
            // You can add Google Analytics or other tracking here
            if (typeof gtag !== 'undefined') {
                gtag('event', 'download', {
                    'event_category': 'forms',
                    'event_label': formName
                });
            }
        }

        // Search functionality with AJAX
        let searchTimeout;
        document.getElementById('searchForms')?.addEventListener('keyup', function(e) {
            clearTimeout(searchTimeout);
            const searchTerm = e.target.value.toLowerCase();
            
            // Show loading indicator
            document.getElementById('searchLoading').classList.remove('hidden');
            
            searchTimeout = setTimeout(() => {
                if (searchTerm.length > 2) {
                    // Use AJAX search
                    fetch(`/client/govforms/api/search?q=${encodeURIComponent(searchTerm)}`)
                        .then(response => response.json())
                        .then(data => {
                            document.getElementById('searchLoading').classList.add('hidden');
                            if (data.success) {
                                updateSearchResults(data.forms, searchTerm);
                            }
                        })
                        .catch(error => {
                            console.error('Search error:', error);
                            document.getElementById('searchLoading').classList.add('hidden');
                            // Fallback to client-side search
                            performClientSideSearch(searchTerm);
                        });
                } else if (searchTerm.length === 0) {
                    // Reset all forms
                    document.querySelectorAll('.form-card').forEach(card => {
                        card.style.display = 'block';
                    });
                    document.getElementById('searchLoading').classList.add('hidden');
                    document.getElementById('searchResultsMessage').classList.add('hidden');
                } else {
                    performClientSideSearch(searchTerm);
                }
            }, 500);
        });

        // Client-side search fallback
        function performClientSideSearch(searchTerm) {
            const formCards = document.querySelectorAll('.form-card');
            let visibleCount = 0;
            
            formCards.forEach(card => {
                const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
                const description = card.querySelector('p.text-sm')?.textContent.toLowerCase() || '';
                const formId = card.querySelector('.text-xs.text-gray-500')?.textContent.toLowerCase() || '';
                
                if (title.includes(searchTerm) || description.includes(searchTerm) || formId.includes(searchTerm)) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            document.getElementById('searchLoading').classList.add('hidden');
            
            // Show results message
            const messageDiv = document.getElementById('searchResultsMessage');
            if (visibleCount === 0) {
                messageDiv.innerHTML = `<i class="fas fa-info-circle mr-2"></i>No forms found matching "${searchTerm}"`;
                messageDiv.classList.remove('hidden');
            } else {
                messageDiv.innerHTML = `<i class="fas fa-check-circle mr-2"></i>Found ${visibleCount} form(s) matching "${searchTerm}"`;
                messageDiv.classList.remove('hidden');
                
                // Hide message after 3 seconds
                setTimeout(() => {
                    messageDiv.classList.add('hidden');
                }, 3000);
            }
        }

        // Update search results from AJAX
        function updateSearchResults(forms, searchTerm) {
            // Hide all sections first
            document.querySelectorAll('[id^="section-"]').forEach(section => {
                section.style.display = 'none';
            });
            
            if (forms.length === 0) {
                document.getElementById('searchResultsMessage').innerHTML = 
                    `<i class="fas fa-info-circle mr-2"></i>No forms found matching "${searchTerm}"`;
                document.getElementById('searchResultsMessage').classList.remove('hidden');
                return;
            }
            
            // Show only sections that have matching forms
            const formIds = forms.map(f => f.form_id);
            document.querySelectorAll('.form-card').forEach(card => {
                const formId = card.dataset.formId;
                if (formIds.includes(parseInt(formId))) {
                    card.style.display = 'block';
                    // Show the parent section
                    const section = card.closest('[id^="section-"]');
                    if (section) section.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
            
            document.getElementById('searchResultsMessage').innerHTML = 
                `<i class="fas fa-check-circle mr-2"></i>Found ${forms.length} form(s) matching "${searchTerm}"`;
            document.getElementById('searchResultsMessage').classList.remove('hidden');
            
            setTimeout(() => {
                document.getElementById('searchResultsMessage').classList.add('hidden');
            }, 3000);
        }

        // Filter by category
        function filterCategory(category) {
            // Update active tab styling
            document.querySelectorAll('.category-tab').forEach(tab => {
                tab.classList.remove('active', 'bg-amber-600', 'text-white');
                tab.classList.add('bg-white');
            });
            
            // Scroll to section
            const section = document.getElementById(`section-${category}`);
            if (section) {
                section.scrollIntoView({ behavior: 'smooth' });
                
                // Highlight section
                section.style.backgroundColor = '#fffbeb';
                setTimeout(() => {
                    section.style.backgroundColor = 'transparent';
                }, 1000);
            } else {
                // If section doesn't exist, show message
                alert(`No forms available in the ${category} category`);
            }
        }

        // Category filter dropdown
        document.getElementById('categoryFilter')?.addEventListener('change', function(e) {
            const category = e.target.value;
            if (category !== 'all') {
                filterCategory(category);
            } else {
                // Show all sections
                document.querySelectorAll('[id^="section-"]').forEach(section => {
                    section.style.display = 'block';
                });
                document.querySelectorAll('.form-card').forEach(card => {
                    card.style.display = 'block';
                });
            }
        });

        // Format filter
        document.getElementById('formatFilter')?.addEventListener('change', function(e) {
            const format = e.target.value;
            const formCards = document.querySelectorAll('.form-card');
            let visibleCount = 0;
            
            formCards.forEach(card => {
                const formatBadge = card.querySelector('[class*="badge-"]');
                if (format === 'all') {
                    card.style.display = 'block';
                    visibleCount++;
                } else if (formatBadge && formatBadge.textContent.toLowerCase().includes(format)) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            // Show message if no results
            const messageDiv = document.getElementById('searchResultsMessage');
            if (format !== 'all' && visibleCount === 0) {
                messageDiv.innerHTML = `<i class="fas fa-info-circle mr-2"></i>No forms found in ${format.toUpperCase()} format`;
                messageDiv.classList.remove('hidden');
            } else {
                messageDiv.classList.add('hidden');
            }
        });

        // Download tracking for all download links
        document.querySelectorAll('.download-btn, a[href*="download"]').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const formName = this.closest('.form-card')?.querySelector('h3')?.textContent || 
                                this.closest('[class*="form-card"]')?.querySelector('h3')?.textContent || 
                                'Unknown form';
                trackDownload(formName);
            });
        });

        // Add quick actions for chatbot
        document.addEventListener('DOMContentLoaded', function() {
            const quickActionsContainer = document.getElementById('quickActionsContainer');
            if (quickActionsContainer) {
                quickActionsContainer.innerHTML = `
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="What forms are available?">
                        📋 Available forms
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="How do I download forms?">
                        ⬇️ How to download
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Are these forms free?">
                        💰 Fees
                    </button>
                    <button class="quick-action text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-2 rounded-full border border-amber-200 transition" data-message="Where do I submit forms?">
                        📍 Submission
                    </button>
                `;
            }

            // Initialize category counts in the header
            updateCategoryCounts();
        });

        // Update category counts in the UI
        function updateCategoryCounts() {
            const categories = ['barangay', 'national', 'psa', 'bpls', 'social', 'education', 'health', 'others'];
            categories.forEach(category => {
                const section = document.getElementById(`section-${category}`);
                if (section) {
                    const formCount = section.querySelectorAll('.form-card').length;
                    const countBadge = section.querySelector('.bg-gray-200');
                    if (countBadge) {
                        countBadge.textContent = `${formCount} forms`;
                    }
                }
            });
        }
    </script>
</body>
</html>