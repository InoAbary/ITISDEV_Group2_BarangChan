<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Community Forum</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }
        /* Forum card hover effects */
        .forum-card {
            transition: all 0.2s ease;
        }
        .forum-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        /* Category badges */
        .category-general { background-color: #e6f7e6; color: #2e7d32; }
        .category-announcement { background-color: #e3f2fd; color: #0d47a1; }
        .category-concern { background-color: #fff3e0; color: #ef6c00; }
        .category-suggestion { background-color: #f3e5f5; color: #6a1b9a; }
        .category-emergency { background-color: #ffebee; color: #c62828; animation: pulse 2s infinite; }
        .category-event { background-color: #e0f7fa; color: #006064; }
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }
        /* Topic row hover */
        .topic-row {
            transition: background-color 0.2s ease;
        }
        .topic-row:hover {
            background-color: #f9fafb;
        }
        /* Chatbot Styles */
        .chatbot-container {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .message-bubble {
            animation: fadeInUp 0.3s ease-out;
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .typing-indicator span {
            animation: blink 1.4s infinite;
            animation-fill-mode: both;
        }
        .typing-indicator span:nth-child(2) {
            animation-delay: 0.2s;
        }
        .typing-indicator span:nth-child(3) {
            animation-delay: 0.4s;
        }
        @keyframes blink {
            0% { opacity: 0.1; }
            20% { opacity: 1; }
            100% { opacity: 0.1; }
        }
        /* Filipino ornament divider */
        .filipino-divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: #9ca3af;
        }
        .filipino-divider::before,
        .filipino-divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e5e7eb;
        }
        .filipino-divider::before {
            margin-right: 0.75rem;
        }
        .filipino-divider::after {
            margin-left: 0.75rem;
        }
        .filipino-divider span {
            font-size: 0.75rem;
            color: #d97706;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/client/forum', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header with Forum Title -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-comments"></i> 
                            Barangay Forum
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm">
                            <i class="fas fa-users mr-1"></i> 
                            Makisali, makibahagi, at makipag-usap sa iyong komunidad
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-users mr-2"></i>1,234 members
                        </span>
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-message mr-2"></i>456 topics
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Success/Alert Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>

        <!-- Forum Navigation & Create Topic -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
            <!-- Breadcrumb -->
            <div class="text-sm breadcrumbs">
                <ul class="flex items-center gap-2 text-gray-600">
                    <li><a href="/client/dashboard" class="hover:text-amber-600">Dashboard</a></li>
                    <li><i class="fas fa-chevron-right text-xs"></i></li>
                    <li class="font-semibold text-amber-700">Community Forum</li>
                </ul>
            </div>
            
            <!-- Create Topic Button -->
            <button onclick="document.getElementById('createTopicModal').classList.remove('hidden')" 
                    class="bg-gradient-to-r from-amber-600 to-amber-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:from-amber-700 hover:to-amber-800 transition flex items-center gap-2 shadow-md">
                <i class="fas fa-plus-circle"></i>
                <span>Create New Topic</span>
            </button>
        </div>

        <!-- Main Grid: Forum Categories + Topic List -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- LEFT SIDEBAR - Forum Categories & Info -->
            <div class="lg:col-span-3 space-y-5">
                <!-- Categories Card -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-4 py-3">
                        <h3 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-tags"></i> Categories
                        </h3>
                    </div>
                    <div class="p-3 space-y-1">
                        <a href="#" class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 transition">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                                <span class="text-sm font-medium">General Discussion</span>
                            </div>
                            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">156</span>
                        </a>
                        <a href="#" class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 transition">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                                <span class="text-sm font-medium">Announcements</span>
                            </div>
                            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">89</span>
                        </a>
                        <a href="#" class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 transition">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
                                <span class="text-sm font-medium">Community Concerns</span>
                            </div>
                            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">67</span>
                        </a>
                        <a href="#" class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 transition">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
                                <span class="text-sm font-medium">Suggestions</span>
                            </div>
                            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">42</span>
                        </a>
                        <a href="#" class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 transition">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-red-500 rounded-full"></span>
                                <span class="text-sm font-medium">Emergency Alerts</span>
                            </div>
                            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">23</span>
                        </a>
                        <a href="#" class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 transition">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-teal-500 rounded-full"></span>
                                <span class="text-sm font-medium">Events & Activities</span>
                            </div>
                            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">78</span>
                        </a>
                    </div>
                </div>

                <!-- Forum Stats Card -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-4 py-3">
                        <h3 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-chart-simple"></i> Forum Stats
                        </h3>
                    </div>
                    <div class="p-4 space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600">Total Topics</span>
                            <span class="font-bold text-gray-800">456</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600">Total Posts</span>
                            <span class="font-bold text-gray-800">2,847</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600">Total Members</span>
                            <span class="font-bold text-gray-800">1,234</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600">Newest Member</span>
                            <span class="text-sm font-medium text-amber-600">Maria Santos</span>
                        </div>
                        <div class="filipino-divider mt-2">
                            <span>⚙️ ACTIVE NOW</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm text-gray-600">
                            <div class="flex -space-x-2">
                                <div class="w-6 h-6 bg-blue-600 rounded-full border-2 border-white flex items-center justify-center text-white text-xs">J</div>
                                <div class="w-6 h-6 bg-amber-600 rounded-full border-2 border-white flex items-center justify-center text-white text-xs">M</div>
                                <div class="w-6 h-6 bg-green-600 rounded-full border-2 border-white flex items-center justify-center text-white text-xs">R</div>
                                <div class="w-6 h-6 bg-purple-600 rounded-full border-2 border-white flex items-center justify-center text-white text-xs">+8</div>
                            </div>
                            <span>11 members online</span>
                        </div>
                    </div>
                </div>

                <!-- Popular Tags -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="px-4 py-3 border-b border-gray-100">
                        <h3 class="font-semibold text-gray-700 flex items-center gap-2">
                            <i class="fas fa-hashtag text-amber-600"></i> Popular Tags
                        </h3>
                    </div>
                    <div class="p-3 flex flex-wrap gap-2">
                        <span class="bg-blue-100 text-blue-700 text-xs px-3 py-1.5 rounded-full">#barangay</span>
                        <span class="bg-amber-100 text-amber-700 text-xs px-3 py-1.5 rounded-full">#clearance</span>
                        <span class="bg-green-100 text-green-700 text-xs px-3 py-1.5 rounded-full">#events</span>
                        <span class="bg-red-100 text-red-700 text-xs px-3 py-1.5 rounded-full">#emergency</span>
                        <span class="bg-purple-100 text-purple-700 text-xs px-3 py-1.5 rounded-full">#suggestion</span>
                        <span class="bg-teal-100 text-teal-700 text-xs px-3 py-1.5 rounded-full">#medical</span>
                        <span class="bg-indigo-100 text-indigo-700 text-xs px-3 py-1.5 rounded-full">#safety</span>
                        <span class="bg-pink-100 text-pink-700 text-xs px-3 py-1.5 rounded-full">#zumba</span>
                    </div>
                </div>
            </div>

            <!-- MAIN CONTENT - Forum Topics List -->
            <div class="lg:col-span-9 space-y-5">
                
                <!-- Search and Filter Bar -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 p-4">
                    <div class="flex flex-col md:flex-row gap-3">
                        <div class="flex-1 relative">
                            <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                            <input type="text" placeholder="Search topics..." 
                                   class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                        </div>
                        <div class="flex gap-2">
                            <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-amber-400">
                                <option>All Categories</option>
                                <option>General Discussion</option>
                                <option>Announcements</option>
                                <option>Concerns</option>
                                <option>Suggestions</option>
                                <option>Events</option>
                            </select>
                            <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-amber-400">
                                <option>Latest</option>
                                <option>Most Viewed</option>
                                <option>Most Replies</option>
                                <option>Trending</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Topics List Header -->
                <div class="bg-gray-50 rounded-t-xl border border-gray-200 p-3 hidden md:block">
                    <div class="grid grid-cols-12 gap-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">
                        <div class="col-span-6">Topic</div>
                        <div class="col-span-2 text-center">Replies</div>
                        <div class="col-span-2 text-center">Views</div>
                        <div class="col-span-2 text-center">Last Activity</div>
                    </div>
                </div>

                <!-- Topics List -->
                <div class="space-y-3">
                    <!-- Pinned Topic -->
                    <div class="forum-card bg-white rounded-xl shadow-md border-l-4 border-amber-500 border border-gray-200 overflow-hidden">
                        <div class="p-4">
                            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                                <div class="md:col-span-6">
                                    <div class="flex items-start gap-3">
                                        <div class="bg-amber-100 p-2 rounded-lg flex-shrink-0">
                                            <i class="fas fa-thumbtack text-amber-600"></i>
                                        </div>
                                        <div>
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full font-medium">PINNED</span>
                                                <span class="category-announcement text-xs px-2 py-0.5 rounded-full">Announcement</span>
                                            </div>
                                            <a href="#" class="font-semibold text-gray-800 hover:text-amber-600 transition mt-1 block">
                                                Barangay Assembly Schedule: March 30, 2026
                                            </a>
                                            <p class="text-xs text-gray-500 mt-1">by <span class="font-medium text-amber-600">Kapitan Reyes</span> • 2 days ago</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="md:col-span-2 text-center text-sm text-gray-600">24</div>
                                <div class="md:col-span-2 text-center text-sm text-gray-600">156</div>
                                <div class="md:col-span-2 text-center">
                                    <p class="text-xs text-gray-500">2 hours ago</p>
                                    <p class="text-xs text-gray-400">by Maria Santos</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Emergency Topic -->
                    <div class="forum-card bg-white rounded-xl shadow-md border-l-4 border-red-500 border border-gray-200 overflow-hidden">
                        <div class="p-4">
                            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                                <div class="md:col-span-6">
                                    <div class="flex items-start gap-3">
                                        <div class="bg-red-100 p-2 rounded-lg flex-shrink-0">
                                            <i class="fas fa-exclamation-triangle text-red-600"></i>
                                        </div>
                                        <div>
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <span class="category-emergency text-xs px-2 py-0.5 rounded-full animate-pulse">EMERGENCY</span>
                                                <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full">High Priority</span>
                                            </div>
                                            <a href="#" class="font-semibold text-gray-800 hover:text-amber-600 transition mt-1 block">
                                                ⚠️ Suspicious Person in Phase 3 - Please Be Alert
                                            </a>
                                            <p class="text-xs text-gray-500 mt-1">by <span class="font-medium text-amber-600">Juan Dela Cruz</span> • 30 mins ago</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="md:col-span-2 text-center text-sm text-gray-600">12</div>
                                <div class="md:col-span-2 text-center text-sm text-gray-600">89</div>
                                <div class="md:col-span-2 text-center">
                                    <p class="text-xs text-gray-500">15 mins ago</p>
                                    <p class="text-xs text-gray-400">by Pedro Santos</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Regular Topics (Sample loop) -->
                    <% 
                    const forumTopics = [
                        {
                            id: 1,
                            title: 'Looking for recommendations for a reliable electrician',
                            category: 'general',
                            categoryLabel: 'General Discussion',
                            author: 'Maria Santos',
                            authorAvatar: 'M',
                            time: '3 hours ago',
                            replies: 8,
                            views: 45,
                            lastActivity: '1 hour ago',
                            lastUser: 'Rey Martinez',
                            isHot: true,
                            isOfficial: false
                        },
                        {
                            id: 2,
                            title: 'Proposed weekend Zumba classes at covered court',
                            category: 'suggestion',
                            categoryLabel: 'Suggestion',
                            author: 'Elena Rodriguez',
                            authorAvatar: 'E',
                            time: '5 hours ago',
                            replies: 23,
                            views: 112,
                            lastActivity: '30 mins ago',
                            lastUser: 'Carla Reyes',
                            isHot: true,
                            isOfficial: false
                        },
                        {
                            id: 3,
                            title: 'Free Medical Mission this Saturday at Barangay Hall',
                            category: 'event',
                            categoryLabel: 'Event',
                            author: 'Kapitan Reyes',
                            authorAvatar: 'K',
                            time: '1 day ago',
                            replies: 15,
                            views: 234,
                            lastActivity: '2 hours ago',
                            lastUser: 'Dr. Santos',
                            isHot: false,
                            isOfficial: true
                        },
                        {
                            id: 4,
                            title: 'Water interruption advisory - March 20',
                            category: 'announcement',
                            categoryLabel: 'Announcement',
                            author: 'Barangay Secretary',
                            authorAvatar: 'MS',
                            time: '1 day ago',
                            replies: 7,
                            views: 189,
                            lastActivity: '5 hours ago',
                            lastUser: 'Lito Cruz',
                            isHot: false,
                            isOfficial: true
                        },
                        {
                            id: 5,
                            title: 'Street light broken in Phase 2 near basketball court',
                            category: 'concern',
                            categoryLabel: 'Concern',
                            author: 'Juan Dela Cruz',
                            authorAvatar: 'J',
                            time: '2 days ago',
                            replies: 5,
                            views: 67,
                            lastActivity: '1 day ago',
                            lastUser: 'Kagawad Torres',
                            isHot: false,
                            isOfficial: false
                        }
                    ];
                    %>

                    <% forumTopics.forEach(function(topic) { %>
                        <!-- Topic Row -->
                        <div class="forum-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                            <div class="p-4">
                                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                                    <div class="md:col-span-6">
                                        <div class="flex items-start gap-3">
                                            <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center text-gray-700 font-bold text-sm flex-shrink-0">
                                                <%= topic.authorAvatar %>
                                            </div>
                                            <div>
                                                <div class="flex items-center gap-2 flex-wrap">
                                                    <% if (topic.category === 'general') { %>
                                                        <span class="category-general text-xs px-2 py-0.5 rounded-full">General</span>
                                                    <% } else if (topic.category === 'suggestion') { %>
                                                        <span class="category-suggestion text-xs px-2 py-0.5 rounded-full">Suggestion</span>
                                                    <% } else if (topic.category === 'event') { %>
                                                        <span class="category-event text-xs px-2 py-0.5 rounded-full">Event</span>
                                                    <% } else if (topic.category === 'announcement') { %>
                                                        <span class="category-announcement text-xs px-2 py-0.5 rounded-full">Announcement</span>
                                                    <% } else if (topic.category === 'concern') { %>
                                                        <span class="category-concern text-xs px-2 py-0.5 rounded-full">Concern</span>
                                                    <% } %>
                                                    
                                                    <% if (topic.isOfficial) { %>
                                                        <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full">
                                                            <i class="fas fa-check-circle text-xs"></i> Official
                                                        </span>
                                                    <% } %>
                                                    
                                                    <% if (topic.isHot) { %>
                                                        <span class="bg-orange-100 text-orange-700 text-xs px-2 py-0.5 rounded-full">
                                                            <i class="fas fa-fire"></i> Hot
                                                        </span>
                                                    <% } %>
                                                </div>
                                                <a href="#" class="font-semibold text-gray-800 hover:text-amber-600 transition mt-1 block">
                                                    <%= topic.title %>
                                                </a>
                                                <p class="text-xs text-gray-500 mt-1">
                                                    by <span class="font-medium text-amber-600"><%= topic.author %></span> • <%= topic.time %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="md:col-span-2 text-center">
                                        <span class="font-bold text-gray-800"><%= topic.replies %></span>
                                        <span class="text-xs text-gray-500 block md:hidden">replies</span>
                                    </div>
                                    <div class="md:col-span-2 text-center">
                                        <span class="font-bold text-gray-800"><%= topic.views %></span>
                                        <span class="text-xs text-gray-500 block md:hidden">views</span>
                                    </div>
                                    <div class="md:col-span-2 text-center">
                                        <p class="text-xs text-gray-500"><%= topic.lastActivity %></p>
                                        <p class="text-xs text-gray-400">by <%= topic.lastUser %></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>

                    <!-- Load More Button -->
                    <div class="text-center py-4">
                        <button class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                            <i class="fas fa-spinner mr-2"></i> Load More Topics
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- CREATE TOPIC MODAL -->
    <div id="createTopicModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <!-- Modal Header -->
            <div class="bg-gradient-to-r from-blue-900 to-amber-800 p-6 text-white">
                <div class="flex items-center justify-between">
                    <h3 class="text-xl font-bold flex items-center gap-2">
                        <i class="fas fa-plus-circle"></i>
                        Create New Forum Topic
                    </h3>
                    <button onclick="document.getElementById('createTopicModal').classList.add('hidden')" class="text-white/80 hover:text-white">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <p class="text-blue-100 text-sm mt-1">Makisali at makibahagi sa iyong barangay community</p>
            </div>

            <!-- Modal Body -->
            <div class="p-6">
                <form action="/client/forum/create" method="POST">
                    <!-- Title -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            <i class="fas fa-heading text-amber-600 mr-1"></i> Topic Title
                        </label>
                        <input type="text" name="title" required
                               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400 focus:border-transparent"
                               placeholder="e.g., Looking for recommendations, Community concern, etc.">
                    </div>

                    <!-- Category and Tags -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                <i class="fas fa-tag text-amber-600 mr-1"></i> Category
                            </label>
                            <select name="category" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400">
                                <option value="general">General Discussion</option>
                                <option value="concern">Community Concern</option>
                                <option value="suggestion">Suggestion</option>
                                <option value="event">Event</option>
                                <option value="announcement">Announcement</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                <i class="fas fa-flag text-amber-600 mr-1"></i> Urgency (Optional)
                            </label>
                            <select name="urgency" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400">
                                <option value="low">🟢 Low</option>
                                <option value="medium">🟡 Medium</option>
                                <option value="high">🟠 High</option>
                                <option value="emergency">🔴 Emergency</option>
                            </select>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            <i class="fas fa-pen text-amber-600 mr-1"></i> Content
                        </label>
                        <textarea name="content" rows="6" required
                                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400 focus:border-transparent resize-none"
                                  placeholder="Share your thoughts, concerns, or suggestions..."></textarea>
                    </div>

                    <!-- Tags -->
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            <i class="fas fa-hashtag text-amber-600 mr-1"></i> Tags (comma separated)
                        </label>
                        <input type="text" name="tags" 
                               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400 focus:border-transparent"
                               placeholder="e.g., barangay, safety, event">
                    </div>

                    <!-- Form Actions -->
                    <div class="flex items-center justify-end gap-3 border-t pt-4">
                        <button type="button" onclick="document.getElementById('createTopicModal').classList.add('hidden')"
                                class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-6 py-2 bg-gradient-to-r from-amber-600 to-amber-700 text-white rounded-lg hover:from-amber-700 hover:to-amber-800 transition">
                            <i class="fas fa-paper-plane mr-2"></i> Create Topic
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

   
    <%- include('../partials/chatbot') %>

    <!-- Include footer -->
    <%- include('../partials/footer') %>

    <!-- JavaScript for Chatbot Functionality -->
    
</body>
</html>