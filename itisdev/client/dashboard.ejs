<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Community Dashboard</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }
        /* Post hover effect */
        .post-card {
            transition: all 0.2s ease;
        }
        .post-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        /* Urgency badges */
        .urgency-low { background-color: #e6f7e6; color: #2e7d32; }
        .urgency-medium { background-color: #fff3e0; color: #ef6c00; }
        .urgency-high { background-color: #ffebee; color: #c62828; }
        .urgency-emergency { background-color: #fce4ec; color: #880e4f; animation: pulse 2s infinite; }
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/client/dashboard', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Welcome Banner -->
        <div class="bg-gradient-to-r from-blue-900 to-amber-800 rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl font-bold flex items-center gap-2">
                        <i class="fas fa-home"></i> 
                        Barangay Community Board
                    </h1>
                    <p class="text-blue-100 mt-1 text-sm md:text-base">
                        <i class="fas fa-map-marker-alt mr-1"></i> 
                        <%= user.barangay || 'Barangay San Antonio' %>, <%= user.city || 'Quezon City' %>
                    </p>
                </div>
                <div class="mt-3 md:mt-0 flex items-center gap-3">
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-users mr-2"></i>1,234 residents
                    </span>
                    <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                        <i class="fas fa-file-alt mr-2"></i><%= posts ? posts.length : 0 %> posts today
                    </span>
                </div>
            </div>
        </div>

        <!-- Success Message (if any) -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>

        <!-- Main Grid: Left Sidebar + Feed + Right Sidebar -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- LEFT SIDEBAR - Quick Actions & Info -->
            <div class="lg:col-span-3 space-y-5">
                <!-- User Quick Profile -->
                <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-700 h-16 relative">
                        <div class="absolute -bottom-8 left-4">
                            <div class="w-16 h-16 bg-white rounded-full border-4 border-white shadow-md flex items-center justify-center">
                                <span class="text-2xl font-bold text-blue-800">
                                    <%= user.full_name ? user.full_name.charAt(0).toUpperCase() : 'U' %>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="pt-10 px-4 pb-4">
                        <h3 class="font-bold text-gray-800"><%= user.full_name %></h3>
                        <p class="text-xs text-gray-500 flex items-center gap-1 mt-1">
                            <i class="fas fa-map-pin text-amber-600"></i> <%= user.barangay || 'Barangay San Antonio' %>
                        </p>
                        <div class="flex justify-between mt-3 text-xs">
                            <div class="text-center">
                                <span class="font-bold text-gray-800">12</span>
                                <p class="text-gray-500">Posts</p>
                            </div>
                            <div class="text-center">
                                <span class="font-bold text-gray-800">8</span>
                                <p class="text-gray-500">Requests</p>
                            </div>
                            <div class="text-center">
                                <span class="font-bold text-gray-800">34</span>
                                <p class="text-gray-500">Helpful</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Barangay Info Card -->
                <div class="bg-white rounded-xl shadow-md p-4 border border-gray-100">
                    <h4 class="font-semibold text-gray-700 flex items-center gap-2 mb-3">
                        <i class="fas fa-landmark text-amber-600"></i> Barangay Hall
                    </h4>
                    <div class="space-y-2 text-sm">
                        <p class="flex items-start gap-2 text-gray-600">
                            <i class="fas fa-map-marker-alt text-amber-600 mt-1"></i>
                            <span>123 Barangay Hall St., <%= user.barangay || 'San Antonio' %></span>
                        </p>
                        <p class="flex items-center gap-2 text-gray-600">
                            <i class="fas fa-phone-alt text-amber-600"></i>
                            <span>(02) 8123-4567</span>
                        </p>
                        <p class="flex items-center gap-2 text-gray-600">
                            <i class="fas fa-clock text-amber-600"></i>
                            <span>8:00 AM - 5:00 PM (Mon-Fri)</span>
                        </p>
                    </div>
                    <button class="mt-3 w-full bg-blue-50 hover:bg-blue-100 text-blue-700 text-sm font-medium py-2 rounded-lg transition">
                        <i class="fas fa-directions mr-1"></i> Get Directions
                    </button>
                </div>

                <!-- Quick Links -->
                <div class="bg-white rounded-xl shadow-md p-4 border border-gray-100">
                    <h4 class="font-semibold text-gray-700 flex items-center gap-2 mb-2">
                        <i class="fas fa-link text-amber-600"></i> Quick Links
                    </h4>
                    <div class="space-y-1">
                        <a href="#" class="flex items-center gap-3 p-2 hover:bg-gray-50 rounded-lg text-sm text-gray-700 transition">
                            <i class="fas fa-file-pdf text-red-500 w-5"></i> Barangay Clearance Form
                        </a>
                        <a href="#" class="flex items-center gap-3 p-2 hover:bg-gray-50 rounded-lg text-sm text-gray-700 transition">
                            <i class="fas fa-hand-holding-heart text-green-600 w-5"></i> Report an Issue
                        </a>
                        <a href="#" class="flex items-center gap-3 p-2 hover:bg-gray-50 rounded-lg text-sm text-gray-700 transition">
                            <i class="fas fa-calendar-alt text-amber-600 w-5"></i> Community Events
                        </a>
                        <a href="#" class="flex items-center gap-3 p-2 hover:bg-gray-50 rounded-lg text-sm text-gray-700 transition">
                            <i class="fas fa-phone-volume text-blue-600 w-5"></i> Emergency Hotlines
                        </a>
                    </div>
                </div>
            </div>

            <!-- MAIN FEED - Posts and Create Post -->
            <div class="lg:col-span-6 space-y-5">
                
                <!-- Create Post Card -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="p-4 border-b border-gray-100 bg-gray-50">
                        <h3 class="font-semibold text-gray-700 flex items-center gap-2">
                            <i class="fas fa-pen-alt text-amber-600"></i> 
                            What's on your mind, <span class="text-amber-700"><%= user.full_name ? user.full_name.split(' ')[0] : 'Kabayan' %></span>?
                        </h3>
                    </div>
                    <div class="p-4">
                        <form action="/client/posts/create" method="POST">
                            <input type="text" name="title" placeholder="Post title (optional)" 
                                   class="w-full px-4 py-2 mb-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
                            <textarea name="content" rows="3" 
                                      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400 focus:border-amber-400 resize-none"
                                      placeholder="Share a concern, suggestion, or update with your barangay..." required></textarea>
                            
                            <div class="flex flex-wrap items-center justify-between mt-3 gap-2">
                                <div class="flex items-center gap-2">
                                    <select name="type" class="text-sm border border-gray-300 rounded-lg px-3 py-2 bg-white focus:ring-amber-400">
                                        <option value="update">📢 Update</option>
                                        <option value="query">❓ Question</option>
                                        <option value="suggestion">💡 Suggestion</option>
                                        <option value="complaint">⚠️ Concern</option>
                                    </select>
                                    <select name="urgency" class="text-sm border border-gray-300 rounded-lg px-3 py-2 bg-white focus:ring-amber-400">
                                        <option value="low">🟢 Low</option>
                                        <option value="medium">🟡 Medium</option>
                                        <option value="high">🟠 High</option>
                                        <option value="emergency">🔴 Emergency</option>
                                    </select>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button type="submit" 
                                            class="bg-amber-600 hover:bg-amber-700 text-white px-5 py-2 rounded-lg text-sm font-medium flex items-center gap-1 transition">
                                        <i class="fas fa-paper-plane"></i> Post
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Filter Tabs -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-1 flex flex-wrap">
                    <button class="flex-1 px-4 py-2 text-sm font-medium rounded-lg bg-amber-600 text-white">All Posts</button>
                    <button class="flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition">Urgent</button>
                    <button class="flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition">Official</button>
                    <button class="flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition">Near You</button>
                </div>

                <!-- POSTS FEED -->
                <div class="space-y-4">
                    <% 
                    // Sample posts data
                    const displayPosts = posts || [
                        {
                            id: 1,
                            user_name: 'Maria Santos',
                            user_role: 'Barangay Secretary',
                            user_avatar: 'M',
                            time_ago: '2 hours ago',
                            type: 'announcement',
                            urgency: 'medium',
                            title: 'Barangay Clearance Processing Update',
                            content: 'Good news! We now have a faster processing time for Barangay Clearances. Please expect your documents within 2-3 working days. Walk-in applications are accepted from 8AM to 3PM only.',
                            likes: 24,
                            comments: 7,
                            shares: 3,
                            is_official: true
                        },
                        {
                            id: 2,
                            user_name: 'Juan Dela Cruz',
                            user_role: 'Resident',
                            user_avatar: 'J',
                            time_ago: '5 hours ago',
                            type: 'concern',
                            urgency: 'high',
                            title: 'Broken Street Light in Phase 2',
                            content: 'The street light near the basketball court in Phase 2 has been broken for 3 days now. It\'s very dark at night and poses a safety risk. Can the barangay please look into this?',
                            likes: 15,
                            comments: 4,
                            shares: 2,
                            is_official: false
                        },
                        {
                            id: 3,
                            user_name: 'Kapitan Reyes',
                            user_role: 'Barangay Captain',
                            user_avatar: 'K',
                            time_ago: '1 day ago',
                            type: 'announcement',
                            urgency: 'low',
                            title: 'Free Medical Mission this Saturday',
                            content: 'In partnership with DOH, we will be holding a free medical mission at the Barangay Hall this Saturday, March 21, from 8AM to 12NN. Services include check-up, dental, and free medicines. First come, first served!',
                            likes: 56,
                            comments: 12,
                            shares: 23,
                            is_official: true
                        },
                        {
                            id: 4,
                            user_name: 'Elena Rodriguez',
                            user_role: 'Resident',
                            user_avatar: 'E',
                            time_ago: '2 days ago',
                            type: 'suggestion',
                            urgency: 'low',
                            title: 'Proposed Weekend Zumba Classes',
                            content: 'Would anyone be interested in weekend Zumba classes at the covered court? I\'m a certified instructor and could offer free sessions if we get at least 15 participants. Let me know in the comments!',
                            likes: 32,
                            comments: 18,
                            shares: 5,
                            is_official: false
                        },
                        {
                            id: 5,
                            user_name: 'Barangay DRRM',
                            user_role: 'Disaster Risk Reduction',
                            user_avatar: 'D',
                            time_ago: '3 days ago',
                            type: 'emergency',
                            urgency: 'emergency',
                            title: '⚠️ Typhoon Preparedness Reminder',
                            content: 'As Typhoon "Amang" approaches, please secure your homes and prepare emergency kits. Evacuation centers are open at Barangay Hall and San Antonio Elementary School. For emergencies, call 161 or 911.',
                            likes: 89,
                            comments: 24,
                            shares: 67,
                            is_official: true
                        }
                    ];
                    %>

                    <% displayPosts.forEach(function(post) { %>
                        <!-- Post Card -->
                        <div class="post-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                            <!-- Post Header -->
                            <div class="p-4 pb-2">
                                <div class="flex items-start justify-between">
                                    <div class="flex items-start gap-3">
                                        <!-- Avatar -->
                                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0 
                                            <%= post.is_official ? 'bg-gradient-to-br from-blue-600 to-amber-600' : 'bg-gray-400' %>">
                                            <%= post.user_avatar || post.user_name.charAt(0) %>
                                        </div>
                                        <!-- User Info -->
                                        <div>
                                            <div class="flex items-center flex-wrap gap-2">
                                                <span class="font-semibold text-gray-800"><%= post.user_name %></span>
                                                <% if (post.is_official) { %>
                                                    <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full flex items-center gap-1">
                                                        <i class="fas fa-check-circle text-xs"></i> Official
                                                    </span>
                                                <% } %>
                                                <span class="text-xs text-gray-500"><%= post.user_role %></span>
                                            </div>
                                            <div class="flex items-center gap-2 text-xs text-gray-500 mt-1">
                                                <span><i class="far fa-clock"></i> <%= post.time_ago %></span>
                                                <!-- Urgency Badge -->
                                                <% if (post.urgency === 'low') { %>
                                                    <span class="urgency-low px-2 py-0.5 rounded-full text-xs font-medium">Low</span>
                                                <% } else if (post.urgency === 'medium') { %>
                                                    <span class="urgency-medium px-2 py-0.5 rounded-full text-xs font-medium">Medium</span>
                                                <% } else if (post.urgency === 'high') { %>
                                                    <span class="urgency-high px-2 py-0.5 rounded-full text-xs font-medium">High</span>
                                                <% } else if (post.urgency === 'emergency') { %>
                                                    <span class="urgency-emergency px-2 py-0.5 rounded-full text-xs font-medium">🚨 EMERGENCY</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Post Type Icon -->
                                    <div class="text-gray-400">
                                        <% if (post.type === 'announcement') { %>
                                            <i class="fas fa-bullhorn text-blue-500"></i>
                                        <% } else if (post.type === 'concern') { %>
                                            <i class="fas fa-exclamation-triangle text-amber-600"></i>
                                        <% } else if (post.type === 'suggestion') { %>
                                            <i class="fas fa-lightbulb text-yellow-600"></i>
                                        <% } else if (post.type === 'emergency') { %>
                                            <i class="fas fa-exclamation-circle text-red-600"></i>
                                        <% } else { %>
                                            <i class="fas fa-comment text-gray-400"></i>
                                        <% } %>
                                    </div>
                                </div>

                                <!-- Post Title -->
                                <% if (post.title) { %>
                                    <h3 class="font-bold text-gray-800 mt-3 text-lg"><%= post.title %></h3>
                                <% } %>

                                <!-- Post Content -->
                                <p class="text-gray-700 mt-2 text-sm leading-relaxed"><%= post.content %></p>
                            </div>

                            <!-- Post Stats -->
                            <div class="px-4 py-2 border-t border-b border-gray-100 flex items-center gap-4 text-xs text-gray-500">
                                <span><i class="far fa-thumbs-up mr-1"></i> <%= post.likes %> likes</span>
                                <span><i class="far fa-comment mr-1"></i> <%= post.comments %> comments</span>
                                <span><i class="far fa-share-square mr-1"></i> <%= post.shares %> shares</span>
                            </div>

                            <!-- Post Actions -->
                            <div class="px-4 py-2 flex items-center justify-around text-sm">
                                <button class="flex items-center gap-2 text-gray-600 hover:text-blue-600 transition flex-1 justify-center py-2">
                                    <i class="far fa-thumbs-up"></i>
                                    <span class="hidden sm:inline">Like</span>
                                </button>
                                <button class="flex items-center gap-2 text-gray-600 hover:text-green-600 transition flex-1 justify-center py-2">
                                    <i class="far fa-comment"></i>
                                    <span class="hidden sm:inline">Comment</span>
                                </button>
                                <button class="flex items-center gap-2 text-gray-600 hover:text-amber-600 transition flex-1 justify-center py-2">
                                    <i class="far fa-share-square"></i>
                                    <span class="hidden sm:inline">Share</span>
                                </button>
                            </div>
                        </div>
                    <% }) %>

                    <!-- Load More Button -->
                    <div class="text-center py-4">
                        <button class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                            <i class="fas fa-spinner mr-2"></i> Load More Posts
                        </button>
                    </div>
                </div>
            </div>

            <!-- RIGHT SIDEBAR - Announcements and Info -->
            <div class="lg:col-span-3 space-y-5">
                <!-- Official Announcements -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-4 py-3">
                        <h3 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-bullhorn"></i> Official Announcements
                        </h3>
                    </div>
                    <div class="p-3 space-y-3 max-h-96 overflow-y-auto">
                        <div class="border-l-4 border-amber-500 pl-3 py-1">
                            <p class="text-xs text-amber-600">2 hours ago</p>
                            <p class="text-sm font-medium">Barangay Hall closed on March 25 for training</p>
                        </div>
                        <div class="border-l-4 border-blue-500 pl-3 py-1">
                            <p class="text-xs text-blue-600">Yesterday</p>
                            <p class="text-sm font-medium">New garbage collection schedule effective April 1</p>
                        </div>
                        <div class="border-l-4 border-green-500 pl-3 py-1">
                            <p class="text-xs text-green-600">3 days ago</p>
                            <p class="text-sm font-medium">Free vaccination for seniors this Friday</p>
                        </div>
                        <div class="border-l-4 border-purple-500 pl-3 py-1">
                            <p class="text-xs text-purple-600">1 week ago</p>
                            <p class="text-sm font-medium">Barangay Assembly on March 30, 4PM</p>
                        </div>
                    </div>
                    <div class="p-3 border-t border-gray-100">
                        <a href="#" class="text-sm text-amber-600 hover:text-amber-700 flex items-center justify-between">
                            View all announcements
                            <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Upcoming Events -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-4 py-3">
                        <h3 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-calendar-alt"></i> Upcoming Events
                        </h3>
                    </div>
                    <div class="p-3">
                        <div class="flex items-start gap-3 mb-3">
                            <div class="bg-amber-100 text-amber-800 rounded-lg px-2 py-1 text-center min-w-[50px]">
                                <span class="block font-bold text-lg">21</span>
                                <span class="text-xs">MAR</span>
                            </div>
                            <div>
                                <p class="font-medium text-sm">Medical Mission</p>
                                <p class="text-xs text-gray-500">8:00 AM - Barangay Hall</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 mb-3">
                            <div class="bg-blue-100 text-blue-800 rounded-lg px-2 py-1 text-center min-w-[50px]">
                                <span class="block font-bold text-lg">25</span>
                                <span class="text-xs">MAR</span>
                            </div>
                            <div>
                                <p class="font-medium text-sm">Barangay Assembly</p>
                                <p class="text-xs text-gray-500">4:00 PM - Covered Court</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="bg-green-100 text-green-800 rounded-lg px-2 py-1 text-center min-w-[50px]">
                                <span class="block font-bold text-lg">30</span>
                                <span class="text-xs">MAR</span>
                            </div>
                            <div>
                                <p class="font-medium text-sm">Clean-up Drive</p>
                                <p class="text-xs text-gray-500">7:00 AM - Phase 2</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Emergency Contacts -->
                <div class="bg-red-50 rounded-xl shadow-md border border-red-200 overflow-hidden">
                    <div class="bg-red-600 px-4 py-3">
                        <h3 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-phone-alt"></i> Emergency Hotlines
                        </h3>
                    </div>
                    <div class="p-4 space-y-2">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium">Barangay Hall</span>
                            <span class="text-sm font-bold text-red-700">8123-4567</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium">Police</span>
                            <span class="text-sm font-bold text-red-700">117 or 911</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium">Fire Dept</span>
