    <script>
        // Toggle comments visibility
        function toggleComments(postId) {
            const commentsSection = document.getElementById(`comments-${postId}`);
            if (commentsSection) {
                commentsSection.classList.toggle('hidden');
            }
        }

        // Auto-expand comments if URL has hash
        window.addEventListener('load', function() {
            if (window.location.hash) {
                const targetId = window.location.hash.substring(1);
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    targetElement.classList.remove('hidden');
                    targetElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }
        });

        // Track emergency number clicks for analytics
        document.querySelectorAll('a[href^="tel:"]').forEach(link => {
            link.addEventListener('click', function(e) {
                const phoneNumber = this.getAttribute('href').replace('tel:', '');
                console.log('Emergency call initiated:', phoneNumber);
                
                // You can add analytics tracking here
                fetch('/api/contacts/track-click', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        phone_number: phoneNumber,
                        source: 'dashboard_emergency'
                    })
                }).catch(err => console.error('Tracking error:', err));
            });
        });

        // Filter buttons functionality
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const filter = this.dataset.filter;
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('bg-amber-600', 'text-white'));
                this.classList.add('bg-amber-600', 'text-white');
                this.classList.remove('text-gray-600', 'hover:bg-gray-100');
            });
        });
    </script>
