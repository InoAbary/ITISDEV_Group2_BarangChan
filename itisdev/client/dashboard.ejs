<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarangChan · Community Dashboard</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .bg-pattern {
            background-color: #f8fafc;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60"><path fill="%23e2e8f0" d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></svg>');
            background-repeat: repeat;
        }
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }
        .post-card {
            transition: all 0.2s ease;
        }
        .post-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        .urgency-low { background-color: #e6f7e6; color: #2e7d32; }
        .urgency-medium { background-color: #fff3e0; color: #ef6c00; }
        .urgency-high { background-color: #ffebee; color: #c62828; }
        .urgency-emergency { background-color: #fce4ec; color: #880e4f; animation: pulse 2s infinite; }
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }
        .baliuag-banner {
            background: linear-gradient(135deg, #1e3a8a 0%, #b45309 100%);
        }
        .official-badge {
            background: linear-gradient(135deg, #2563eb, #1e40af);
        }
        .info-card {
            transition: all 0.2s ease;
        }
        .info-card:hover {
            transform: translateY(-2px);
        }
        .emergency-number {
            font-family: 'Courier New', monospace;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .emergency-btn {
            transition: all 0.2s ease;
        }
        .emergency-btn:hover {
            transform: scale(1.05);
            background-color: #dc2626;
        }
    </style>
</head>
<body class="bg-pattern font-sans antialiased min-h-screen flex flex-col">

    <!-- Include navigation -->
    <%- include('../partials/topnavigation', { currentPath: '/client/dashboard', currentUser: user }) %>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Welcome Banner with Barangay Info -->
        <div class="baliuag-banner rounded-2xl shadow-lg mb-6 overflow-hidden">
            <div class="px-6 py-5 text-white">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <i class="fas fa-map-marker-alt text-amber-300"></i>
                            <span class="text-amber-200 text-sm font-semibold">
                                <%= user.city || 'Baliuag' %>, <%= user.province || 'Bulacan' %>
                            </span>
                        </div>
                        <h1 class="text-2xl font-bold flex items-center gap-2">
                            <i class="fas fa-home"></i> 
                            Barangay <%= user.barangay || 'San Antonio' %> Community Board
                        </h1>
                        <p class="text-blue-100 mt-1 text-sm md:text-base">
                            <i class="fas fa-hand-peace mr-1"></i> 
                            Magandang araw, <span class="font-semibold"><%= user.full_name ? user.full_name.split(' ')[0] : 'Kabayan' %></span>! 
                            Welcome to your community dashboard
                        </p>
                    </div>
                    <div class="mt-3 md:mt-0 flex items-center gap-3">
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-users mr-2"></i><%= stats?.totalResidents || '1,234' %> residents
                        </span>
                        <span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-file-alt mr-2"></i><%= posts ? posts.length : 0 %> posts today
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Emergency Alert Banner -->
        <div class="mb-6 bg-red-600 rounded-xl shadow-lg overflow-hidden animate-pulse">
            <div class="px-6 py-4 text-white flex flex-col md:flex-row md:items-center md:justify-between">
                <div class="flex items-center gap-4">
                    <div class="bg-white/20 p-3 rounded-full">
                        <i class="fas fa-exclamation-triangle text-2xl"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold">🚨 FOR EMERGENCIES, CALL:</h2>
                        <p class="text-red-100">Tumawag agad kung may emergency | Call immediately for emergencies</p>
                    </div>
                </div>
                <div class="mt-3 md:mt-0 flex gap-2">
                    <a href="tel:911" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition emergency-btn">
                        911
                    </a>
                    <a href="tel:117" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition emergency-btn">
                        117
                    </a>
                    <a href="tel:160" class="bg-white text-red-600 px-6 py-3 rounded-lg font-bold text-xl hover:bg-red-50 transition emergency-btn">
                        160
                    </a>
                </div>
            </div>
        </div>

        <!-- Success/Error Messages -->
        <% if (locals.success) { %>
            <div class="mb-4 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-check-circle mt-0.5 text-green-600"></i>
                <p class="text-sm font-medium"><%= success %></p>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg flex items-start gap-3 shadow-md">
                <i class="fas fa-exclamation-circle mt-0.5 text-red-600"></i>
                <p class="text-sm font-medium"><%= error %></p>
            </div>
        <% } %>

        <!-- Main Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- LEFT SIDEBAR - Barangay Info & Officials -->
            <div class="lg:col-span-3 space-y-5">
                
                <!-- User Quick Profile -->
                <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-700 h-16 relative">
                        <div class="absolute -bottom-8 left-4">
                            <div class="w-16 h-16 bg-white rounded-full border-4 border-white shadow-md flex items-center justify-center">
                                <span class="text-2xl font-bold text-blue-800">
                                    <%= user.full_name ? user.full_name.charAt(0).toUpperCase() : 'U' %>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="pt-10 px-4 pb-4">
                        <h3 class="font-bold text-gray-800"><%= user.full_name %></h3>
                        <p class="text-xs text-gray-500 flex items-center gap-1 mt-1">
                            <i class="fas fa-map-pin text-amber-600"></i> 
                            Barangay <%= user.barangay || 'San Antonio' %>, <%= user.city || 'Baliuag' %>
                        </p>
                        <p class="text-xs text-blue-600 mt-1">Barangay ID: BRGY-<%= user.id || '2026' %>-<%= user.barangay ? user.barangay.substring(0,3).toUpperCase() : 'SAN' %></p>
                    </div>
                </div>

                <!-- Barangay Captain Info -->
                <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden info-card">
                    <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-4 py-3">
                        <h4 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-user-tie"></i> Barangay Captain
                        </h4>
                    </div>
                    <div class="p-4">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 text-xl">
                                <i class="fas fa-crown"></i>
                            </div>
                            <div>
                                <p class="font-bold text-gray-800"><%= barangayInfo?.barangay_captain || 'Hon. Maria Concepcion R. Santos' %></p>
                                <p class="text-xs text-gray-500">Barangay Captain</p>
                            </div>
                        </div>
                        <div class="space-y-2 text-sm border-t pt-3">
                            <p class="flex items-center gap-2 text-gray-600">
                                <i class="fas fa-phone-alt text-amber-600 w-5"></i>
                                <a href="tel:<%= barangayInfo?.captain_contact || '09171234567' %>" class="text-blue-600 hover:text-blue-700">
                                    <%= barangayInfo?.captain_contact || '0917 123 4567' %>
                                </a>
                            </p>
                            <p class="flex items-center gap-2 text-gray-600">
                                <i class="fas fa-envelope text-amber-600 w-5"></i>
                                <span class="text-sm">captain@barangay.gov.ph</span>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Barangay Hall Info -->
                <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden info-card">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-4 py-3">
                        <h4 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-landmark"></i> Barangay Hall
                        </h4>
                    </div>
                    <div class="p-4 space-y-3">
                        <div class="flex items-start gap-2">
                            <i class="fas fa-map-marker-alt text-amber-600 mt-1"></i>
                            <p class="text-sm text-gray-600">
                                <%= barangayInfo?.hall_address || 'Purok 3, Barangay San Antonio, Baliuag, Bulacan' %>
                            </p>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-phone-alt text-amber-600"></i>
                            <a href="tel:<%= barangayInfo?.hall_phone || '0441234567' %>" class="text-sm text-blue-600 hover:text-blue-700">
                                <%= barangayInfo?.hall_phone || '(044) 123-4567' %>
                            </a>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-envelope text-amber-600"></i>
                            <span class="text-sm text-gray-600"><%= barangayInfo?.hall_email || 'barangay@sanantonio.gov.ph' %></span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-clock text-amber-600"></i>
                            <span class="text-sm text-gray-600"><%= barangayInfo?.office_hours || '8:00 AM - 5:00 PM (Mon-Fri)' %></span>
                        </div>
                        <div class="flex items-center gap-2 mt-2 pt-2 border-t">
                            <i class="fab fa-facebook text-blue-600"></i>
                            <a href="<%= barangayInfo?.facebook_page || '#' %>" class="text-sm text-blue-600 hover:underline" target="_blank">
                                Barangay Facebook Page
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Barangay Officials Quick List -->
                <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
                    <div class="bg-gradient-to-r from-green-600 to-green-700 px-4 py-3">
                        <h4 class="font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-users"></i> Barangay Officials
                        </h4>
                    </div>
                    <div class="p-3 space-y-2 max-h-64 overflow-y-auto">
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm font-medium">Barangay Secretary</span>
                            <span class="text-sm text-gray-600"><%= barangayInfo?.secretary || 'Juan Miguel A. Dela Cruz' %></span>
                        </div>
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm font-medium">Barangay Treasurer</span>
                            <span class="text-sm text-gray-600"><%= barangayInfo?.treasurer || 'Teresita M. Reyes' %></span>
                        </div>
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm font-medium">SK Chairman</span>
                            <span class="text-sm text-gray-600">John Patrick M. Santos</span>
                        </div>
                        <div class="flex items-center justify-between py-2">
                            <span class="text-sm font-medium">Barangay Tanod Head</span>
                            <span class="text-sm text-gray-600">Rodel M. Garcia</span>
                        </div>
                    </div>
                    <div class="px-3 pb-3">
                        <a href="/contacts" class="text-xs text-blue-600 hover:text-blue-700 flex items-center gap-1">
                            <i class="fas fa-address-book"></i> View all officials
                        </a>
                    </div>
                </div>
            </div>

            <!-- MAIN FEED - Posts and Create Post -->
            <div class="lg:col-span-6 space-y-5">
                
                <!-- Create Post Card -->
                <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="p-4 border-b border-gray-100 bg-gray-50">
                        <h3 class="font-semibold text-gray-700 flex items-center gap-2">
                            <i class="fas fa-pen-alt text-amber-600"></i> 
                            What's on your mind, <span class="text-amber-700"><%= user.full_name ? user.full_name.split(' ')[0] : 'Kabayan' %></span>?
                        </h3>
                    </div>
                    <div class="p-4">
                        <form action="/client/dashboard/create" method="POST">
                            <input type="text" name="title" placeholder="Post title (optional)" 
                                class="w-full px-4 py-2 mb-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-transparent">
                            <textarea name="content" rows="3" 
                                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-400 focus:border-transparent"
                                placeholder="Share a concern, suggestion, or update..." required></textarea>
                            
                            <div class="flex flex-wrap items-center justify-between mt-3 gap-2">
                                <div class="flex items-center gap-2">
                                    <select name="type" class="text-sm border border-gray-300 rounded-lg px-3 py-2">
                                        <option value="update">📢 Update</option>
                                        <option value="query">❓ Question</option>
                                        <option value="suggestion">💡 Suggestion</option>
                                        <option value="complaint">⚠️ Concern</option>
                                    </select>
                                    <select name="urgency" class="text-sm border border-gray-300 rounded-lg px-3 py-2">
                                        <option value="low">🟢 Low</option>
                                        <option value="medium">🟡 Medium</option>
                                        <option value="high">🟠 High</option>
                                        <option value="emergency">🔴 Emergency</option>
                                    </select>
                                </div>
                                <button type="submit" 
                                        class="bg-amber-600 hover:bg-amber-700 text-white px-5 py-2 rounded-lg transition">
                                    <i class="fas fa-paper-plane"></i> Post
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Filter Tabs -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-1 flex flex-wrap">
                    <button class="flex-1 px-4 py-2 text-sm font-medium rounded-lg bg-amber-600 text-white">All Posts</button>
                    <button class="flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition">Urgent</button>
                    <button class="flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition">Official</button>
                    <button class="flex-1 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition">Near You</button>
                </div>
               
                <!-- POSTS FEED -->
                <div class="space-y-4">
                    <% if (posts && posts.length > 0) { %>
                        <% posts.forEach(function(post) { %>
                            <!-- Post Card -->
                            <div class="post-card bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                                <!-- Post Header -->
                                <div class="p-4 pb-2">
                                    <div class="flex items-start justify-between">
                                        <div class="flex items-start gap-3">
                                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0 
                                                <%= post.is_official ? 'bg-gradient-to-br from-blue-600 to-amber-600' : 'bg-gray-400' %>">
                                                <%= post.user_avatar || (post.user_name ? post.user_name.charAt(0) : 'U') %>
                                            </div>
                                            <div>
                                                <div class="flex items-center flex-wrap gap-2">
                                                    <span class="font-semibold text-gray-800">
                                                        <%= post.user_name || 'Unknown User' %>
                                                    </span>
                                                    <% if (post.is_official) { %>
                                                        <span class="official-badge text-white text-xs px-2 py-0.5 rounded-full">
                                                            <i class="fas fa-check-circle"></i> Official
                                                        </span>
                                                    <% } %>
                                                    <span class="text-xs text-gray-500"><%= post.user_role || 'Resident' %></span>
                                                </div>
                                                <div class="flex items-center gap-2 text-xs text-gray-500 mt-1">
                                                    <span><i class="far fa-clock"></i> <%= post.time_ago || 'Just now' %></span>
                                                    <% if (post.urgency === 'low') { %>
                                                        <span class="urgency-low px-2 py-0.5 rounded-full">Low</span>
                                                    <% } else if (post.urgency === 'medium') { %>
                                                        <span class="urgency-medium px-2 py-0.5 rounded-full">Medium</span>
                                                    <% } else if (post.urgency === 'high') { %>
                                                        <span class="urgency-high px-2 py-0.5 rounded-full">High</span>
                                                    <% } else if (post.urgency === 'emergency') { %>
                                                        <span class="urgency-emergency px-2 py-0.5 rounded-full">🚨 EMERGENCY</span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="text-gray-400">
                                            <% if (post.type === 'announcement') { %>
                                                <i class="fas fa-bullhorn text-blue-500"></i>
                                            <% } else if (post.type === 'complaint') { %>
                                                <i class="fas fa-exclamation-triangle text-amber-600"></i>
                                            <% } else if (post.type === 'suggestion') { %>
                                                <i class="fas fa-lightbulb text-yellow-600"></i>
                                            <% } else if (post.type === 'emergency') { %>
                                                <i class="fas fa-exclamation-circle text-red-600"></i>
                                            <% } else { %>
                                                <i class="fas fa-comment text-gray-400"></i>
                                            <% } %>
                                        </div>
                                    </div>

                                    <% if (post.title) { %>
                                        <h3 class="font-bold text-gray-800 mt-3 text-lg">
                                            <a href="/client/dashboard/<%= post.id %>" class="hover:text-amber-600 hover:underline">
                                                <%= post.title %>
                                            </a>
                                        </h3>
                                    <% } %>

                                    <p class="text-gray-700 mt-2 text-sm leading-relaxed"><%= post.content %></p>
                                </div>

                                <!-- Post Stats -->
                                <div class="px-4 py-2 border-t border-b border-gray-100 flex items-center gap-4 text-xs text-gray-500">
                                    <span><i class="far fa-thumbs-up mr-1"></i> <%= post.likes || 0 %> likes</span>
                                    <span>
                                        <i class="far fa-comment mr-1"></i> 
                                        <a href="#comments-<%= post.id %>" class="hover:text-green-600" onclick="toggleComments(<%= post.id %>); return false;">
                                            <%= post.comments_count || 0 %> comments
                                        </a>
                                    </span>
                                    <span><i class="far fa-share-square mr-1"></i> <%= post.shares || 0 %> shares</span>
                                </div>

                                <!-- Post Actions -->
                                <div class="px-4 py-2 flex items-center justify-around text-sm border-b border-gray-100">
                                    <form action="/client/dashboard/<%= post.id %>/like" method="POST" class="flex-1">
                                        <button type="submit" class="flex items-center gap-2 text-gray-600 hover:text-blue-600 transition justify-center py-2 w-full">
                                            <i class="far fa-thumbs-up"></i>
                                            <span class="hidden sm:inline">Like (<%= post.likes || 0 %>)</span>
                                        </button>
                                    </form>
                                    
                                    <button onclick="toggleComments(<%= post.id %>)" 
                                            class="flex items-center gap-2 text-gray-600 hover:text-green-600 transition flex-1 justify-center py-2">
                                        <i class="far fa-comment"></i>
                                        <span class="hidden sm:inline">Comment</span>
                                    </button>
                                    
                                    <button class="flex items-center gap-2 text-gray-600 hover:text-amber-600 transition flex-1 justify-center py-2">
                                        <i class="far fa-share-square"></i>
                                        <span class="hidden sm:inline">Share</span>
                                    </button>
                                </div>

                                <!-- COMMENTS SECTION -->
                                <div id="comments-<%= post.id %>" class="hidden bg-gray-50 px-4 py-3">
                                    <div class="mb-3 max-h-60 overflow-y-auto space-y-3">
                                        <% if (post.comments && post.comments.length > 0) { %>
                                            <% post.comments.forEach(function(comment) { %>
                                                <div class="flex gap-2 text-sm">
                                                    <div class="w-6 h-6 rounded-full bg-gray-300 flex items-center justify-center text-white font-bold text-xs flex-shrink-0">
                                                        <%= comment.user_avatar || (comment.user_name ? comment.user_name.charAt(0) : 'U') %>
                                                    </div>
                                                    <div class="flex-1 bg-white rounded-lg p-2 shadow-sm">
                                                        <div class="flex items-center gap-2 mb-1">
                                                            <span class="font-medium text-gray-800 text-xs">
                                                                <%= comment.user_name || 'Unknown User' %>
                                                            </span>
                                                            <span class="text-xs text-gray-400">
                                                                <%= comment.time_ago || 'Just now' %>
                                                            </span>
                                                        </div>
                                                        <p class="text-gray-700 text-xs"><%= comment.content %></p>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p class="text-center text-gray-400 text-sm py-2">No comments yet. Be the first to comment!</p>
                                        <% } %>
                                    </div>

                                    <form action="/client/dashboard/<%= post.id %>/comment" method="POST" class="flex gap-2">
                                        <input type="text" name="content" placeholder="Write a comment..." 
                                            class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-green-400 focus:border-transparent"
                                            required>
                                        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm transition whitespace-nowrap">
                                            Post
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="bg-white rounded-xl shadow-md p-8 text-center">
                            <i class="fas fa-pen-alt text-4xl text-gray-300 mb-3"></i>
                            <p class="text-gray-500">No posts yet. Be the first to share!</p>
                        </div>
                    <% } %>

                    <div class="text-center py-4">
